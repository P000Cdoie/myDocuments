        End If
        'AMIT RANA 

        'If UCase(cmbInvType.Text) = "NORMAL INVOICE" And UCase(CmbCategory.Text) <> "SCRAP" Then
        '    If optInvYes(0).Checked = True Then
        '        strInvoicestatus = "TEMPORARY INVOICE"
