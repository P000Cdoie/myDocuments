    Private Function LEARASNFileGeneration(ByVal pintdocno As Double, ByVal pstraccountcode As String) As String
        On Error GoTo ErrHandler
        Dim intCount As Short
        Dim strLocation As String
        Dim strFileName As String
        Dim intLineNo As Short
        Dim strSql As String
        Dim strRecord As String
        Dim rsgetData As New ClsResultSetDB
        Dim rsEx_Cess As ClsResultSetDB
        Dim rsSalesDtl As ClsResultSetDB
        Dim strInvoice_item As String
        Dim dblTotalExciseAmt As Double
        Dim FSO As New Scripting.FileSystemObject

        strLocation = Trim(Find_Value("SELECT ISNULL(Learlocation,'') FROM customer_mst (nolock) WHERE UNIT_CODE='" + gstrUNITID + "' and customer_code='" & pstraccountcode & "'"))
        If Len(strLocation) = 0 Then
            LEARASNFileGeneration = False
            Exit Function
        Else
            If Not FSO.FolderExists(strLocation) Then
                FSO.CreateFolder(strLocation)
            End If
            If Mid(Trim(strLocation), Len(Trim(strLocation))) <> "\" Then
                strLocation = strLocation & "\"
            End If
            strFileName = pintdocno & ".csv"
            strFileName = strLocation & strFileName
            On Error Resume Next
            Kill(strFileName & "*.csv")
            FileClose(1)
            On Error GoTo ErrHandler
            FileOpen(1, strFileName, OpenMode.Append)
        End If

        If Len(pintdocno) > 0 Then
            strSql = ""
            strSql = "select * from dbo.FN_GETASNDETAIL_LEAR(" & pintdocno & ",'" & gstrUNITID & "')"
            rsgetData.GetResult(strSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            rsgetData.MoveFirst()
            Do While Not rsgetData.EOFRecord
                strRecord = ""
                strRecord = rsgetData.GetValue("cust_vendor_code").ToString
                strRecord = strRecord & "," & rsgetData.GetValue("CUSTOMERCODE").ToString
                strRecord = strRecord & "," & pintdocno
                strRecord = strRecord & "," & VB6.Format(rsgetData.GetValue("INVOICE_DATE").ToString(), "yyyymmddhhmm")
                strRecord = strRecord & "," & VB6.Format(rsgetData.GetValue("INVOICE_DATE").ToString(), "yyyymmddhhmm")
                strRecord = strRecord & "," & ""
                strRecord = strRecord & "," & ""
                strRecord = strRecord & "," & rsgetData.GetValue("CUST_PLANTCODE").ToString
                strRecord = strRecord & "," & rsgetData.GetValue("SHIP_PLANTCODE").ToString
                strRecord = strRecord & "," & rsgetData.GetValue("PLACE_OF_DISCHARGE").ToString 'Place/Port of Discharge
                strRecord = strRecord & "," & rsgetData.GetValue("TRANSPORT_TYPE").ToString 'TRANSPORT TYPE
                strRecord = strRecord & "," & rsgetData.GetValue("Carrier_code").ToString 'CARRIER SCAC CODE
                strRecord = strRecord & "," & rsgetData.GetValue("CARRIER_NAME").ToString 'Carrier name
                strRecord = strRecord & "," & rsgetData.GetValue("CONTAINER_DESP_QTY").ToString 'Number of packages
                strRecord = strRecord & "," & rsgetData.GetValue("Container").ToString 'Type of packages
                strRecord = strRecord & "," & rsgetData.GetValue("Qty_per_pkg").ToString 'Quantity per package
                strRecord = strRecord & "," & rsgetData.GetValue("cust_item_code").ToString 'Part Number
                strRecord = strRecord & "," & rsgetData.GetValue("sales_quantity").ToString 'Despatch Qty
                strRecord = strRecord & "," & rsgetData.GetValue("MEASURE_UNIT").ToString 'Measurement Unit
                strRecord = strRecord & "," & rsgetData.GetValue("cust_ref").ToString 'ORDER NUMBER
                PrintLine(1, strRecord) : intLineNo = intLineNo + 1
                rsgetData.MoveNext()
            Loop
            FileClose(1)
            'Kill(strFileName)
            LEARASNFileGeneration = True
            Exit Function
        End If
        Exit Function
ErrHandler:
        FileClose(1)
        'Kill(strFileName)
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
