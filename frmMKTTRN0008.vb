    Public Sub removePagesFromPdf(ByVal sourceFile As String, ByVal destinationFile As String, ByVal ParamArray pagesToKeep As Integer())
        Dim r As PdfReader = New PdfReader(sourceFile)

        Dim fs As FileStream = New FileStream(destinationFile, FileMode.Create, FileAccess.Write, FileShare.None)

        Dim doc As iTextSharp.text.Document = New iTextSharp.text.Document()

        Dim w As PdfWriter = PdfWriter.GetInstance(doc, fs)

        doc.Open()
        For Each page As Integer In pagesToKeep
            doc.NewPage()
            w.DirectContent.AddTemplate(w.GetImportedPage(r, page), 0, 0)
        Next
        doc.Close()

    End Sub
