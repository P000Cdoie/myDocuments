            If DataExist("SELECT TOP 1 1 FROM SALES_DTL  WHERE UNIT_CODE = '" & gstrUNITID & "' and doc_no= " & Trim(Ctlinvoice.Text) & " HAVING COUNT(*)> " & mintmaxnoofitems_barcodeToyota) = True Then
