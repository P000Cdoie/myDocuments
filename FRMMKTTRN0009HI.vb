                    Else
                        strBRString = frmMKTTRN0021A.SelectDataFromCustOrd_Dtl(Trim(txtCustCode.Text), Trim(txtRefNo.Text), mstrAmmNo, Trim(CmbInvSubType.Text), Trim(CmbInvType.Text), strStockLocation)
                    End If
                    If Len(strBRString) > 0 Then
                        strBarCodeMainString = Split(strBRString, "*")
                        For intLoopCounter = 0 To UBound(strBarCodeMainString)
