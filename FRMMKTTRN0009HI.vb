            ' Code by Sandeep To Update the Form_DTL Table
            mP_Connection.Execute("Update FORMS_DTL Set Po_No='" & Trim(CStr(mInvNo)) & "' where  UNIT_CODE = '" & gstrUNITID & "' and  Po_No='" & Trim(txtChallanNo.Text) & "' and Doc_Type='9999'", , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
