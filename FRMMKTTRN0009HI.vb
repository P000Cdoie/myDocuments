                                    Else
                                        mstrItemCode = frmMKTTRN0021HI.SelectDatafromItem_Mst(Trim(CmbInvType.Text), Trim(CmbInvSubType.Text), rsSaleConf.GetValue("Stock_Location"), Trim(txtCustCode.Text))
                                    End If
                                End If
                            End If
                        Else
                            '''Changes Done by Ashutosh on 29-09-2006,Issue Id:18702
                            strStockLocation = ""
