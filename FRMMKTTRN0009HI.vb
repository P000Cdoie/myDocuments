                bFlag = .GetText(EnumInv.CustPartNo, varRow, varCustPartCode)
                varItemCode = Nothing
                bflag1 = .GetText(EnumInv.enumItemCode, varRow, varItemCode)
            End With
            'm_strSql = "Select cust_drg_desc from Cust_ord_dtl where Item_code ='" & Trim(varItemCode) & "' and cust_drgNo ='" & Trim(varCustPartCode) & "' and cust_ref ='" & Trim(txtRefNo.Text) & "' and amendment_no='" & Trim(txtAmendNo.Text) & "' and account_code='" & Trim(txtCustCode.Text) & "' "
            m_strSql = "select drg_desc from custitem_mst WHERE UNIT_CODE='" + gstrUNITID + "' AND  item_code='" & Trim(varItemCode) & "' and cust_drgNo ='" & Trim(varCustPartCode) & "' and account_code='" & Trim(txtCustCode.Text) & "'"
            Rs.GetResult(m_strSql)
            If Rs.GetNoRows > 0 Then
                lblCustPartDesc.Text = Rs.GetValue("drg_desc")
            End If
            'MsgBox(varItemCode)

            If DataExist("SELECT TOP 1 1 FROM item_mst  WHERE  UNIT_CODE='" & gstrUNITID & "' and status='A' AND fts_item =1 and item_code in('" & varItemCode & "')") Then
                If OptSpareDispatch.Checked = True Then
                    mstrLocationCode = Find_Value("Select FTS_Stock_Location from SaleConf WHERE UNIT_CODE='" + gstrUNITID + "' AND  invoice_type ='" & Trim(mstrInvoiceType) & "' and Sub_Type='" & Trim(mstrInvoiceSubType) & "' and (fin_start_date <= getdate() and fin_end_date >= getdate())")
                ElseIf OptSpareDispatch.Checked = True Then
                    mstrLocationCode = "01P3"
                ElseIf OptRejection.Checked Then
                    mstrLocationCode = Find_Value("Select Transfer_RejectionLoc from sales_parameter WHERE UNIT_CODE='" + gstrUNITID + "'")
                    strItembal = "Select Cur_Bal From ItemBal_Mst WHERE UNIT_CODE='" + gstrUNITID + "' AND  Location_Code ='" & mstrLocationCode & "' and item_Code in('" & varItemCode & "')"
                End If
