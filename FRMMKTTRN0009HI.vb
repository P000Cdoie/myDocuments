                                If lctrFocus Is Nothing Then
                                    lctrFocus = Me.txtAddVAT
                                End If
                                ValidatebeforeSave = False
                            End If
                        End If
                    End If
                    'Added for Issue ID eMpro-20090601-31918 Ends
                    If (Len(Me.txtSurchargeTaxType.Text) = 0) Then
                        ''            txtSurchargeTaxType.Text = "0.00"
                    End If
                End If

        End Select
        Dim dblTotQuantity As Double
        Dim dblTotBatchQuantity As Double
        Dim intLoopCounter As Short
        Dim rsObject As ClsResultSetDB
        Dim StrItemCode As String
