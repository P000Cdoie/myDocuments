                        mstrRGPDtl = mstrRGPDtl & " values('23','" & strDocNo & "','" & StrItemCode & "','0','" & strFromLocation & "'," & dblQuantity * dblItemRate & "," & dblQuantity & ",'" & strItemDesc & "',0,'" & strUOMPur & "'," & dblItemRate & ",getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" & gstrUNITID & "') " & vbCrLf
                       
