    Function CreateNRPGString(ByVal pstrCriteria As String, ByRef pStrInvoiceNo As String) As String
        Dim strMain() As String
        Dim strDet() As String
        Dim intOuterCount As Short
        Dim intInnerCount As Short
        Dim strDocNo As String
        Dim strCustomerLocation As String 'Used for to_location in RGP
        Dim dtGrinDate As Date
        Dim strCheckItem As String
        Dim strGRINNo As String
        Dim strFromLocation As String
        Dim StrItemCode As String
        Dim strItemDesc As String
        Dim dblQuantity As Double
        Dim dblItemRate As Double
        Dim strUOMPur As String
        Dim dblSelectedQuantity As Double
        Dim dblSelectedNRGPQuantity As Double
        Dim i As Short
        Dim strtemp As String
        Dim rsBatch As New ADODB.Recordset
        Dim blnBatchTracking As Boolean
        Dim strSql As String
        blnBatchTracking = CBool(Find_Value("Select FormLevelBatch_Tracking From module_mst where Group_id='STR' AND Form_Name='frmSTRTRN0009'"))
        mstrRGPHdr = ""
        mstrRGPDtl = ""
        mstrNRGPDetail = ""
        CreateNRPGString = ""
        mstrItemBatch = ""
        '--------------
        With SpChEntry
            For i = 1 To .maxRows
                .Col = EnumInv.EnumQuantity
                .Row = i
                strtemp = .Text
                If mblnBatchTrack = True Then
                    .Col = EnumInv.MaxQuantity
                Else
                    .Col = EnumInv.BatchCol
                End If
                .Text = strtemp
            Next
            '--------------
            'used when modifying previuosly saved Invoice
            strDocNo = Find_Value("SELECT NRGPNoInCaseOfServiceInvoice FROM SALESCHALLAN_DTL WHERE DOC_NO='" & Trim(txtChallanNo.Text) & "' and UNIT_CODE = '" & gstrUNITID & "'")
            'ends here
            pstrCriteria = Mid(pstrCriteria, 1, Len(pstrCriteria) - 1)
            strMain = Split(pstrCriteria, ",")
            For intOuterCount = 0 To UBound(strMain)
                strDet = Split(strMain(intOuterCount), "|")
                If Trim(strDocNo) = "" Then
                    If SelectDocumentNumber(strDet(1)) Then
                        strDocNo = CStr(Val(GenerateDocNO(23, dtpDateDesc.Text, eMPowerFunctions.DocTypeEnum.Doc_NRGP, False, True, strDet(1))))
                    Else
                        MsgBox("No Document Series have been Defined. First define the Series.", MsgBoxStyle.Information, ResolveResString(100))
                        CreateNRPGString = ""
                        Exit Function
                    End If
                    strCustomerLocation = Find_Value("SELECT CUST_LOCATION FROM CUSTOMER_MST WHERE CUSTOMER_CODE='" & txtCustCode.Text & "' and UNIT_CODE = '" & gstrUNITID & "'")
                    If Len(strDocNo) = 0 Then
                        MsgBox("No Document Series have been Defined. First define the Series.", MsgBoxStyle.Information, ResolveResString(100))
                        Exit Function
                    End If
                End If
                strGRINNo = strDet(0)
                strFromLocation = strDet(1)
                StrItemCode = strDet(2)
                strItemDesc = strDet(3)
                dblQuantity = CDbl(strDet(7))
                dblItemRate = CDbl(strDet(5))
                strUOMPur = strDet(6)
                'Quantity check
                SpChEntry.Col = EnumInv.enumItemCode
                
                If Len(mstrRGPHdr) = 0 Then
                    mstrRGPHdr = " DELETE FROM Rgp_Hdr WHERE Doc_Type='23' AND Doc_No='" & strDocNo & "' AND From_location='" & strFromLocation & "' and UNIT_CODE = '" & gstrUNITID & "'" & vbCrLf
                    mstrRGPHdr = mstrRGPHdr & " Insert Rgp_Hdr(Doc_Type, Doc_No, Pur_Order_No, Amendment_no, From_location, Doc_category, RGP_date, To_location, Emp_code, exciseTax_flag, Acknowledgement, rgp_closure, Location_to_type, NRGPAgainstServiceInvoice, InvoiceNo, Ent_dt,Ent_UserId,Upd_dt,Upd_UserId,UNIT_CODE)"
                    mstrRGPHdr = mstrRGPHdr & " values('23','" & strDocNo & "','','0','" & strFromLocation & "','J','" & getDateForDB(dtpDateDesc.Value) & "','" & strCustomerLocation & "','" & mP_User & "','0','0','0','C','1','" & pStrInvoiceNo & "', getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" & gstrUNITID & "')"
                End If
                 
                If Len(mstrRGPDtl) = 0 Then
                    mstrRGPDtl = " DELETE FROM Rgp_Dtl WHERE Doc_Type='23' AND Doc_No='" & strDocNo & "' AND From_location='" & strFromLocation & "' and UNIT_CODE = '" & gstrUNITID & "'" & vbCrLf
                    'If dblSelectedQuantity > dblQuantity Then
                    mstrRGPDtl = mstrRGPDtl & " insert Rgp_Dtl(Doc_Type, Doc_No, Item_code, Grin_no, From_location, GRIN_rate, Actual_quantity, description, Excise_duty, UOM_pur, Item_rate, Ent_dt,Ent_UserId,Upd_dt,Upd_UserId,UNIT_CODE)"
                    mstrRGPDtl = mstrRGPDtl & " values('23','" & strDocNo & "','" & StrItemCode & "','0','" & strFromLocation & "'," & dblQuantity * dblItemRate & "," & dblQuantity & ",'" & strItemDesc & "',0,'" & strUOMPur & "'," & dblItemRate & ",getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" & gstrUNITID & "')" & vbCrLf
                   
                Else
