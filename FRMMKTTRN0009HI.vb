            mstrInvoiceSubType = rsGetData.GetValue("Sub_Category")
            
            lblCurrencyDes.Text = rsGetData.GetValue("currency_code")
            'Ends here
            '*****Code added by nisha 20/02/2004 for eNagare Details
            
            txtUsLoc.Text = rsGetData.GetValue("USLoc")
            
            txtSchTime.Text = rsGetData.GetValue("Schtime")
            '*****changes Ends here
            'Code add by Sourabh for Show Ecss on CVD Details
            If blnEOU_FLAG = True Then
                
                Me.txtEcessCVD.Text = rsGetData.GetValue("CVDCESS_Type")
                
                Me.lblEcessCVDPer.Text = rsGetData.GetValue("CVDCESS_Per")
                'Code add by Manoj for Show SEcess on CVD Details,Issue ID 19916 Start
                
                Me.txtSEcessCVD.Text = rsGetData.GetValue("CVDSECESS_Type")
                
                Me.lblSEcessCVDPer.Text = rsGetData.GetValue("CVDSECESS_Per")
                'Code add by Manoj for Show SEcess on CVD Details,Issue ID 19916 End
                'Added for Issue ID eMpro-20080430-18033 Starts
                Me.txtEcessTotalDuty.Text = rsGetData.GetValue("Ecess_TotalDuty_Type")
                Me.lblEcessTotalDutyPer.Text = rsGetData.GetValue("Ecess_TotalDuty_Per")
                Me.txtSEcessTotalDuty.Text = rsGetData.GetValue("SEcess_TotalDuty_Type")
                Me.lblSEcessTotalDutyPer.Text = rsGetData.GetValue("SEcess_TotalDuty_Per")
                'Added for Issue ID eMpro-20080430-18033 Ends
            End If
            'Code Added By Arshad Ali 18/02/2005
            mblnServiceInvoiceWithoutSO = CBool(Find_Value("SELECT ServiceInvoiceWithoutSO FROM SALES_PARAMETER where UNIT_CODE = '" & gstrUNITID & "'"))
            mblnServiceInvoiceWithoutSO = False
            If mstrInvoiceType = "SRC" And mblnServiceInvoiceWithoutSO Then
                strGRINNo = Find_Value("SELECT NRGPNoInCaseOfServiceInvoice FROM SALESCHALLAN_DTL WHERE DOC_NO='" & Trim(txtChallanNo.Text) & "' and UNIT_CODE = '" & gstrUNITID & "'")
                strSql = "SELECT CONVERT(VARCHAR, NRGP.GRIN_NO) +'|' + H.FROM_LOCATION +'|' + D.ITEM_CODE +'|' + D.DESCRIPTION +'|' + CONVERT(VARCHAR, NRGP.ITEM_QTY) +'|' + CONVERT(VARCHAR, NRGP.ITEM_RATE)  +'|' + D.UOM_PUR  + '|' + CONVERT(VARCHAR, NRGP.ITEM_QTY) AS GRIN FROM RGP_HDR H "
                strSql = strSql & " INNER JOIN RGP_DTL D ON H.UNIT_CODE = D.UNIT_CODE AND  H.DOC_TYPE = D.DOC_TYPE AND H.FROM_LOCATION = D.FROM_LOCATION AND H.DOC_NO = D.DOC_NO"
                strSql = strSql & " INNER JOIN NRGP_GRIN_DTL NRGP ON H.UNIT_CODE = NRGP.UNIT_CODE AND H.DOC_NO = NRGP.NRGP_NO AND D.ITEM_CODE = NRGP.ITEM_CODE"
                strSql = strSql & " WHERE H.DOC_TYPE=23 AND H.DOC_CATEGORY='J' AND H.DOC_NO='" & strGRINNo & "' H.UNIT_CODE = '" & gstrUNITID & "'"
                rsgrin.Open(strSql, mp_connection)
                mstrGRINSelected = ""
                While Not rsgrin.EOF
                    mstrGRINSelected = mstrGRINSelected & rsgrin.Fields("GRIN").Value & ","
                    rsgrin.MoveNext()
                End While
                'cmdGRIN.Visible = True: cmdGRIN.Enabled = True
                If rsgrin.State = ADODB.ObjectStateEnum.adStateOpen Then
                    rsgrin.Close()
                    
                    rsgrin = Nothing
                End If
            End If
            'Code Ends here
        Else
            GetDataInViewMode = False
        End If
        rsGetData.ResultSetClose()
        '***To Display invoice Address of Customer
        If Len(Trim(txtCustCode.Text)) > 0 Then
            rsCustMst = New ClsResultSetDB
            strCustMst = "SELECT Bill_Address1 + ', '  +  Bill_Address2 + ', ' + Bill_City + ' - ' + Bill_Pin as  invoiceAddress from Customer_Mst where Customer_code ='" & txtCustCode.Text & "' and UNIT_CODE = '" & gstrUNITID & "'"
            rsCustMst.GetResult(strCustMst)
            If rsCustMst.GetNoRows > 0 Then
                
                lblAddressDes.Text = rsCustMst.GetValue("InvoiceAddress")
            End If
            rsCustMst.ResultSetClose()
        End If
        '***
        ' Add by Sandeep
        If mblnRejTracking = True Then
            strSql = "Select Ref_Doc_No from MKT_INVREJ_DTL " & " Where  UNIT_CODE = '" & gstrUNITID & "' and Invoice_No = " & Trim(txtChallanNo.Text)
            rsGetData = New ClsResultSetDB
            rsGetData.GetResult(strSql)
            If rsGetData.RowCount > 0 Then
                txtRefNo.Text = ""
                Do While Not rsGetData.EOFRecord
                    If Len(Trim(txtRefNo.Text)) = 0 Then
                        
                        txtRefNo.Text = rsGetData.GetValue("Ref_Doc_No")
                    Else
                        
                        txtRefNo.Text = Trim(txtRefNo.Text) & "," & rsGetData.GetValue("Ref_Doc_No")
                    End If
                    rsGetData.MoveNext()
                Loop
            End If
            rsGetData.ResultSetClose()
        End If
        'End
        Exit Function
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, err.Source, Err.Description, mp_connection) 'Function called, if error occurred
    End Function
    Private Function DisplayDetailsInSpread(ByRef pstrCurrency As String) As Boolean
