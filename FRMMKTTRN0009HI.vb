                                Else
                                    mstrItemCode = frmMKTTRN0021HI.SelectDataFromCustOrd_Dtl(Trim(txtCustCode.Text), Trim(txtRefNo.Text), mstrAmmNo, Trim(CmbInvSubType.Text), Trim(CmbInvType.Text), strStockLocation)
                                End If
                            Else
                                If Len(Trim(strItemNotIn)) > 0 Then
                                    mstrItemCode = frmMKTTRN0021HI.SelectDatafromItem_Mst(Trim(CmbInvType.Text), Trim(CmbInvSubType.Text), rsSaleConf.GetValue("Stock_Location"), Trim(txtCustCode.Text), strItemNotIn, SpChEntry.MaxRows, mblnFtsitem, mblnFTSBarcode)
                                Else
                                    mstrItemCode = frmMKTTRN0021HI.SelectDatafromItem_Mst(Trim(CmbInvType.Text), Trim(CmbInvSubType.Text), rsSaleConf.GetValue("Stock_Location"), Trim(txtCustCode.Text))
