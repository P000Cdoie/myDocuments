                strRetVal = CheckString(strRetVal)
                objDrCr = Nothing
            Else
                strRetVal = "Y"
            End If
            If Not strRetVal = "Y" Then
                MsgBox(strRetVal, MsgBoxStyle.Information, ResolveResString(100))
                mp_connection.RollBackTrans()
                Exit Sub
            Else
                '''Changes done by Ashutosh on 12 Jun 2007, Issue Id:19934
                rsInvDataInFin = New ClsResultSetDB
                If VerifyInvPostingFlag = True Then
                    If InvoicePostingFlag = True Then
                        If UCase(Trim(mstrInvoiceType)) <> "REJ" Then
                            rsInvDataInFin.GetResult("Select top 1 * from ar_docMaster where docm_vono='" & Trim(CStr(mInvNo)) & "' and docM_unit = '" & gstrUNITID & "'")
                            If rsInvDataInFin.GetNoRows > 0 Then
