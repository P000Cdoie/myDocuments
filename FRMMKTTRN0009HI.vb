        If CmdGrpChEnt.Mode <> UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW Then
            If e.keyCode = System.Windows.Forms.Keys.F1 And SpChEntry.ActiveCol = 8 Then
                With SpChEntry
                    .Row = .ActiveRow
                    .Col = .ActiveCol
