    Private Function SelectDocumentNumber(Optional ByRef pstrLocation As String = "") As Boolean '   !!
        '------------------------------------------------------------------------------------
        'Created By     -   Arshad ALi
        'Description    -   To Select max(document number) from document number master and increase the count by 1
        '                   for next document number
        '------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        SelectDocumentNumber = False
        Dim rsDocNo As ClsResultSetDB 'To fetch the max.document no acc.to doc type
        Dim strDocSql As String
        Dim blnLocationWiseNRGPSeries As Boolean
        rsDocNo = New ClsResultSetDB
        blnLocationWiseNRGPSeries = LocationWiseNRGPSeries
        If blnLocationWiseNRGPSeries = True Then
            strDocSql = "SELECT Current_no from documenttype_mst where  UNIT_CODE = '" & gstrUNITID & "' and doc_type=23 and location_code = '" & Trim(pstrLocation)
            strDocSql = strDocSql & "' AND fin_start_date <=  '" & getDateForDB(dtpDateDesc.Value) & "'  "
            strDocSql = strDocSql & " And Fin_End_date >=  '" & getDateForDB(dtpDateDesc.Value) & "'  "
        Else
            strDocSql = "Select Current_No from documenttype_mst  where  UNIT_CODE = '" & gstrUNITID & "' and doc_type=23"
            strDocSql = strDocSql & " AND fin_start_date <=  '" & getDateForDB(dtpDateDesc.Value) & "'  "
            strDocSql = strDocSql & " And Fin_End_date >=  '" & getDateForDB(dtpDateDesc.Value) & "'  "
        End If
        rsDocNo.GetResult(strDocSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
        If rsDocNo.GetNoRows > 0 Then
            rsDocNo.MoveFirst()
            SelectDocumentNumber = True
        Else
            SelectDocumentNumber = False
        End If
        rsDocNo.ResultSetClose()
        Exit Function
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, err.Source, Err.Description, mp_connection) 'Function called, if error occurred
        Exit Function
    End Function
