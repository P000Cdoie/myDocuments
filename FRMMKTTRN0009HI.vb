                                    strsaledtl = strsaledtl & " Status = 'A' and Hold_flag <> 1 and Item_Code in (" & mstrItemCode & ") and UNIT_CODE = '" & gstrUNITID & "'"
                                End If
                            Else
                                If chkRejType.Text <> "LRN" Then
                                    strsaledtl = ""
                                    strsaledtl = "SELECT Item_Code,standard_Rate from Item_Mst where "
                                    strsaledtl = strsaledtl & " Status = 'A' and Hold_flag <> 1 and Item_Code in (" & mstrItemCode & ") and UNIT_CODE = '" & gstrUNITID & "'"
                                Else
