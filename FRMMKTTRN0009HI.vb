                        If MsgBox("Warning! Labels are Scanned For this Invoice, Once Deleted Record can not be retrieved", MsgBoxStyle.OkCancel, "eMPro") = MsgBoxResult.Ok Then

                            Dim objCmd As New ADODB.Command
                            With objCmd
                                .ActiveConnection = mP_Connection
                                .CommandType = ADODB.CommandTypeEnum.adCmdStoredProc
                                .CommandText = "USP_FTS_LABELADJUST_INVOICE"
                                .CommandTimeout = 0
                                .Parameters.Append(.CreateParameter("@UNIT_CODE", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInput, 20, gstrUNITID))
                                .Parameters.Append(.CreateParameter("@Doc_No", ADODB.DataTypeEnum.adInteger, ADODB.ParameterDirectionEnum.adParamInput, , txtChallanNo.Text.Trim))
                                .Parameters.Append(.CreateParameter("@ERRMSG", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInputOutput, 8000, ""))
                                .Execute(, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                            End With

                            If objCmd.Parameters(objCmd.Parameters.Count - 1).Value.ToString().Trim.Length <> 0 Then
                                MsgBox(objCmd.Parameters(objCmd.Parameters.Count - 1).Value.ToString(), MsgBoxStyle.OkOnly + MsgBoxStyle.Information, ResolveResString(100))
                                objCmd = Nothing
                                mP_Connection.RollbackTrans()
                                Exit Sub
                            End If
                            objCmd = Nothing
                        Else
                            mP_Connection.RollbackTrans()
                            Exit Sub
                        End If
                        'Len(Com.Parameters("@ERR").Value) > 0 
                    End If
                    'FTS RELATED CHANGES

                    If InvAgstBarCode() = True And mstrFGDomestic = "1" Then
                        If BarCodeTracking(Trim(txtChallanNo.Text), "DELETE") = True Then
                            mP_Connection.Execute(mstrupdateBarBondedStockFlag, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                        End If
                    End If
                    'Added for Issue ID 21105 Ends
                    mP_Connection.Execute(strupSaleDtl, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    mP_Connection.Execute(strupSalechallan, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    If Len(Trim(strBatch)) > 0 Then
                        mP_Connection.Execute(strBatch, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    End If
                    If Len(Trim(mstrUpdDispatchSql)) > 0 Then
                        mP_Connection.Execute(mstrUpdDispatchSql, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    End If
                    If UCase(strInvoiceType) = "SRC" And mblnServiceInvoiceWithoutSO Then
                        If Len(strRGPHdr) > 0 Then mP_Connection.Execute(strRGPHdr, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                        If Len(strRgpDtl) > 0 Then mP_Connection.Execute(strRgpDtl, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                        If Len(strNRGPDtl) > 0 Then mP_Connection.Execute(strNRGPDtl, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                        If Len(strItemBatch) > 0 Then mP_Connection.Execute(strItemBatch, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                        If Len(strDocNoUpdate) > 0 Then mP_Connection.Execute(strDocNoUpdate, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    End If
                     If mblnRejTracking = True And strInvoiceType = "REJ" Then
                        strINVREJ_DTL = "DELETE From MKT_INVREJ_DTL where Invoice_No='" & Trim(txtChallanNo.Text) & "' and UNIT_CODE = '" & gstrUNITID & "'"
                        mP_Connection.Execute(strINVREJ_DTL, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    End If
 
                    mP_Connection.Execute("DELETE From FORMS_DTL where PO_No='" & Trim(txtChallanNo.Text) & "' and Doc_Type='9999' and UNIT_CODE = '" & gstrUNITID & "'", , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    mP_Connection.CommitTrans()
                    Call EnableControls(False, Me, True)
                    txtLocationCode.Enabled = True
                    txtLocationCode.BackColor = System.Drawing.Color.White
                    CmdLocCodeHelp.Enabled = True
                    txtChallanNo.Enabled = True
                    txtChallanNo.BackColor = System.Drawing.Color.White
                    CmdChallanNo.Enabled = True
                    mstrGRINSelected = ""
                    mstrFormDetails = ""
                    InvoiceFormDetails = ""
                    'Added for Issue ID 19992 Starts
                    lblCreditTermDesc.Text = ""
                    spitems.MaxRows = 0
                    lblCustPartDesc.Text = ""
                    'Added for Issue ID 19992 Ends
                End If
            Case UCActXCtl.clsDeclares.ButtonEnum.BUTTON_PRINT
                If Trim(txtChallanNo.Text) = "" Then
                    MsgBox("Please select a Challan Number first.", MsgBoxStyle.Information, ResolveResString(100))
                    Exit Sub
                End If
                'Changed and Part Added By Arshad on 23/04/2004 for Dos Based Printing
                System.Windows.Forms.Cursor.Current = System.Windows.Forms.Cursors.WaitCursor
                frmReportViewer = New eMProCrystalReportViewer()
                objRpt = frmReportViewer.GetReportDocument()
                If CBool(Find_Value("select TextPrinting from sales_parameter where UNIT_CODE = '" & gstrUNITID & "' ")) Then
                    Call PrintingInvoice()
                Else
                     
                    Call PrintingInvoiceRPT()
                    frmReportViewer.Show()
                  
                End If
                 If UCase(Trim(GetPlantName)) = "HILEX" Then
                    If Find_Value("Select Cust_name from saleschallan_dtl where  UNIT_CODE = '" & gstrUNITID & "' and Account_code='" & Trim(txtCustCode.Text) & "' and doc_no ='" & Trim(txtChallanNo.Text) & "' and cust_name like '%toyota%' ") <> "" Then
                        strMessage = ToyotaTextFile(Trim(txtChallanNo.Text))
                    End If
                End If
 
                System.Windows.Forms.Cursor.Current = System.Windows.Forms.Cursors.Default
                'Changes By Arshad Ends Here
            Case UCActXCtl.clsDeclares.ButtonEnum.BUTTON_CLOSE
                Me.Close()
        End Select
        Exit Sub
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection) 'Function called, if error occurred
        Exit Sub
    End Sub
