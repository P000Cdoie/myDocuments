    Private Sub txtChallanNo_Validating(ByVal eventSender As System.Object, ByVal eventArgs As System.ComponentModel.CancelEventArgs) Handles txtChallanNo.Validating
        Dim Cancel As Boolean = eventArgs.Cancel
        '****************************************************
        'Created By     -  Nisha
        'Description    -  Check Validity Of Challan No. In SalesChallan_Dtl
        '****************************************************
        Dim strCondition As String
        Dim rsChallanEntry As ClsResultSetDB
        Dim strInvoiceType As String
        'Added for Issue ID 19992 Starts
        Dim strInvoiceSubType As String
        'Added for Issue ID 19992 End
        On Error GoTo ErrHandler
        Select Case Me.CmdGrpChEnt.Mode
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW
                If Len(txtChallanNo.Text) > 0 Then
                    'Check Existance Of Doc No In The SalesChallan_Dtl
                    If InStr(txtChallanNo.Text, "/", CompareMethod.Text) Then
                        Call ConfirmWindow(10404, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                        txtChallanNo.Text = ""
                        Exit Sub
                    End If
                    If blnEOU_FLAG = True Then
                        strCondition = "Invoice_type <> 'EXP'"
                    Else
                        strCondition = ""
                    End If
                    If CheckExistanceOfFieldData((txtChallanNo.Text), "Doc_No", "SalesChallan_Dtl", strCondition) Then
                        'If Challan No. Exists
                        'Get Data From Challan_Dtl,Cust_Ord_Dtl,Sales_Dtl
                        If Len(txtLocationCode.Text) > 0 Then
                            If GetDataInViewMode() Then 'if record found
                                rsChallanEntry = New ClsResultSetDB
                                rsChallanEntry.GetResult("Select a.Description,a.Sub_Type_Description from SaleConf a,SalesChallan_Dtl b where a.UNIT_CODE = b.UNIT_CODE and a.UNIT_CODE = '" & gstrUNITID & "' AND  Doc_No = " & txtChallanNo.Text & " and a.Invoice_Type = b.Invoice_type and a.Sub_type = b.Sub_Category and a.Location_code = b.Location_code and (fin_start_date <= getdate() and fin_end_date >= getdate())")
                                
                                strInvoiceType = UCase(rsChallanEntry.GetValue("Description"))
                                'Added for Issue ID 19992 Starts
                                
                                strInvoiceSubType = UCase(rsChallanEntry.GetValue("Sub_Type_Description"))
                                'Added for Issue ID eMpro-20080930-22159 Starts
                                mstrInvsubTypeDesc = UCase(rsChallanEntry.GetValue("Sub_Type_Description"))
                                'Added for Issue ID eMpro-20080930-22159 Ends
                                Call CheckMultipleSOAllowed(strInvoiceType, strInvoiceSubType)
                                If mblnMultipleSOAllowed = True Then
                                    Call ShowMultipleSOItemHelp()
                                    If mblnCheckArray = True Then
                                        Call FillSelectedItemInGrid()
                                    Else
                                        GoTo EventExitSub
                                    End If
                                    If CDbl(Trim(txtChallanNo.Text)) > 99000000 Then
                                        
                                        '''Me.CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_EDIT) = True
                                        Me.CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_EDIT) = True
                                        
                                        Me.CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_SAVE) = True
                                    End If
                                End If
                                rsChallanEntry.ResultSetClose()
                                'Added for Issue ID 19992 Ends
                                'Code added by nisha for service type of invoice to change th lable of Sale Tax to service tax
                                If UCase(strInvoiceType) = "SERVICE INVOICE" Then
                                    lblSaleTaxType.Text = "Service Tax Code"
                                Else
                                    lblSaleTaxType.Text = "Sale Tax    Code"
                                End If
                                'strInvoiceSubType = UCase(rsChallanEntry.GetValue("sub_type_Description"))
                                'Changed for Issue ID 20918 Starts
                                If mblnInvoiceMTLSharjah = False Then
                                    If UCase(strInvoiceType) <> "SAMPLE INVOICE" And UCase(strInvoiceType) <> "TRANSFER INVOICE" Then
                                        With SpChEntry
                                            .Col = EnumInv.ToolCost_PerUnit : .Col2 = EnumInv.ToolCost_PerUnit : .BlockMode = True : .ColHidden = True : .BlockMode = False
                                        End With
                                    Else
                                        With SpChEntry
                                            .Col = EnumInv.ToolCost_PerUnit : .Col2 = EnumInv.ToolCost_PerUnit : .BlockMode = True : .ColHidden = False : .BlockMode = False
                                            .Col = EnumInv.ToolCost_PerUnit : .Col2 = EnumInv.ToolCost_PerUnit : .BlockMode = True : .Lock = False : .BlockMode = False
                                        End With
                                    End If
                                    'Added for Issue ID eMpro-20080508-18500 Starts
                                    If blnEOU_FLAG = False And mstrInvoiceType = "TRF" Then
                                        With SpChEntry
                                            .Col = EnumInv.SAD : .Col2 = EnumInv.SAD : .BlockMode = True : .ColHidden = False : .BlockMode = False
                                        End With
                                    End If
                                    'Added for Issue ID eMpro-20080508-18500 Ends
                                End If
                                'Changed for Issue ID 20918 Ends
                                Me.cmdForms.Enabled = True
                                Cmditems.Enabled = True
                                Cmditems.Focus()
                            Else 'if no record found then display message
                                Call ConfirmWindow(10414, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                                Cmditems.Enabled = False
                                txtLocationCode.Focus()
                            End If
                        Else 'if location code field is blank
                            Call ConfirmWindow(10239, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                            txtLocationCode.Focus()
                        End If
                    Else 'If Doc_No Is Invalid
                        Call ConfirmWindow(10404, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                        txtChallanNo.Text = ""
                    End If
                End If
        End Select
        '******Check For Temporary Challan No.
        If Val(txtChallanNo.Text) > 9900000 Then
            'CmdGrpChEnt.Enabled(1) = True: CmdGrpChEnt.Enabled(2) = True
            Cmditems.Enabled = True
        Else
            
            CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_EDIT) = False
            
            CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_SAVE) = False
            ''CmdGrpChEnt.Enabled(5) = True
        End If
        '''Changes done by ashutosh on 10 May 2007 ,issue Id:19934
        'Changed for Issue ID 20918 Starts
        'If UCase(Trim(GetPlantName)) = "SHOWPLA" Then
        If UCase(Trim(GetPlantName)) = "SHOWPLA" Or mblnInvoiceMTLSharjah = True Then
            
            '''Me.CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_PRINT) = False
            Me.CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_PRINT) = False
        Else
            
            Me.CmdGrpChEnt.Enabled(UCActXCtl.clsDeclares.ButtonEnum.BUTTON_PRINT) = False
        End If
        '''Changes for Issue Id:19934 end here.
        'Added for Issue ID 20052 Starts
        lblSECSStax_Per.BackColor = System.Drawing.ColorTranslator.FromOle(glngCOLOR_DISABLED)
        If UCase(strInvoiceType) = "JOBWORK INVOICE" Then
            lblServiceTaxType.Visible = True
            txtServiceTaxType.Visible = True
            cmdServiceTaxType.Visible = True
            lblServiceTax.Visible = True
            lblServiceTax_Per.Visible = True
            lblServiceTax_Per.BackColor = System.Drawing.ColorTranslator.FromOle(glngCOLOR_DISABLED)
            lblSECESSonServicePer.Visible = True
            lblSECESSonServicetax.Visible = True
            lblSECESSonServiceTaxPer.Visible = True
            txtSECESSOnServiceTaxType.Visible = True
            cmdSECESSonServiceTaxType.Visible = True
            lblSECESSonServiceTaxPer.BackColor = System.Drawing.ColorTranslator.FromOle(glngCOLOR_DISABLED)
        Else
            lblServiceTaxType.Visible = False
            txtServiceTaxType.Visible = False
            cmdServiceTaxType.Visible = False
            lblServiceTax.Visible = False
            lblServiceTax_Per.Visible = False
            lblSECESSonServicePer.Visible = False
            lblSECESSonServicetax.Visible = False
            lblSECESSonServiceTaxPer.Visible = False
            txtSECESSOnServiceTaxType.Visible = False
            cmdSECESSonServiceTaxType.Visible = False
        End If
        GoTo EventExitSub
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection) 'Function called, if error occurred
EventExitSub:
        eventArgs.Cancel = Cancel
    End Sub
