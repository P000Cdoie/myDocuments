            End If
            If UCase(mstrInvoiceType) = "REJ" Then
                If Len(Trim(mCust_Ref)) > 0 Then
                    mP_Connection.Execute(strupdateGrinhdr, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
