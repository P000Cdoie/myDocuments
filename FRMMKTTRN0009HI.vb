                            If Cmditems.Enabled Then Cmditems.Focus()
                            Exit Sub
                        End If
                        mstrLocationCode = rsSaleConf.GetValue("Stock_Location")
                        If CBool(UCase(CStr(Trim(CmbInvType.Text) = "REJECTION"))) Then
                            ' changed by sandeep
                            If mblnRejTracking = False Then
