                                MsgBox("Invoice not posted to accounts. Try Again!!! ", MsgBoxStyle.Information, ResolveResString(100))
                                mp_connection.RollBackTrans()
                                Exit Sub
                            End If
                        Else
                            If blnRejInvNoEffectAcc = False Then
                                rsInvDataInFin.GetResult("Select top 1 apdocm_venprdocNo from ap_docMaster where apdocm_venprdocNo='" & Trim(CStr(mInvNo)) & "' and apDocM_unit = '" & gstrUNITID & "'")
                                If rsInvDataInFin.GetNoRows > 0 Then
                                    mp_connection.CommitTrans()
                                Else
                                    MsgBox("Invoice not posted to accounts. Try Again!!! ", MsgBoxStyle.Information, ResolveResString(100))
                                    mp_connection.RollBackTrans()
                                    Exit Sub
                                End If
                            Else
                                mp_connection.CommitTrans()
                            End If
                        End If
                    Else
                        mp_connection.CommitTrans()
                    End If
                Else
                    mp_connection.CommitTrans()
                End If
                '''Changes for Issue Id:19934 end here.
                '''mP_Connection.CommitTrans
