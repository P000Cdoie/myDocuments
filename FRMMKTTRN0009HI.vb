        'Changed for Issue ID eMpro-20090506-31083 Ends
        With SpChEntry
            For Intcounter = 1 To .MaxRows
                .Col = EnumInv.Excise
                .Row = Intcounter
                If Trim(.Text) <> "" Then
                    strWhereClause = " WHERE unit_code ='" & gstrUNITID & "' and  TxRt_Rate_No='" & Trim(.Text) & "' AND Tx_TaxeID='EXC'"
                    lstrReturnVal = SelectDataFromTable("TxRt_Rate_No", "Gen_TaxRate", strWhereClause)
                    If Len(lstrReturnVal) = 0 Then
                        .Col = EnumInv.enumItemCode
                        lstrControls = lstrControls & vbCrLf & lNo & " Invalid Excise Tax Code For Item Code " & .Text
                        lNo = lNo + 1
                        ValidatebeforeSave = False
                    End If
                End If
            Next
        End With
Complete_Validation:
        If Not ValidatebeforeSave Then
            MsgBox(lstrControls, MsgBoxStyle.Information, ResolveResString(10059))
            'Changed for Issue ID eMpro-20080930-22159 Starts
            If lctrFocus Is Nothing Then
            Else
                lctrFocus.Focus()
            End If
            'Changed for Issue ID eMpro-20080930-22159 Ends
        End If
        Exit Function
