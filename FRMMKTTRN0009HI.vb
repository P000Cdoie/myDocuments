                                        strbatchdtl = strbatchdtl & " Batch_ReInspected_Qty,Ent_Userid,Ent_Dt,Upd_Userid,Upd_Dt,unit_code)"
                                        strbatchdtl = strbatchdtl & " Values (9999,'" & Trim(txtChallanNo.Text) & "','" & getDateForDB(GetServerDate()) & "','" & mstrLocationCode & "','" & strToLocation & "','" & lstrItemCode & "','" & lstrItemDrgno & "',1,'" & strBatchNo & "','" & getDateForDB(GetServerDate()) & "'," & dblBatchQty & "," & dblBatchQty & ",0,0,'" & mP_User & "','" & getDateForDB(GetServerDate()) & "','" & mP_User & "','" & getDateForDB(GetServerDate()) & "','" & gstrUNITID & "') "
                                    Next
                                Else
                                    strbatchdtl = strbatchdtl & " Delete from ItemBatch_Dtl Where UNIT_CODE = '" & gstrUNITID & "' and  Doc_no = " & Trim(Me.txtChallanNo.Text) & " and From_Location = '" & mstrLocationCode & "' and cust_Item_Code  = '" & lstrItemDrgno & "' and Doc_Type = 9999 "
                                End If
                            End If
                        End If
                        'Ends here
                        ' Add by Sandeep to Save Rejection Tracking Detail
                        If mblnRejTracking = True And mstrInvType = "REJ" Then
                            strSQLREJINV_DTL = strSQLREJINV_DTL & MakeSQL_REJINVTRACKING(lintLoopCounter)
                        End If
                    Next
                End With
        End Select
        ' Add by Sandeep To Make SQL Statement For FormDetails..
        strSQLForm_DTL = MakeSQLStatement_FormDetail()
        ' Code add by sourabh on 22 nov 2005 against issue id PRJ-2004-04-003-16261
        Dim strBarCodeStringForCon As String
        If Me.chkInvoiceAgaistBarCode.Visible = True And Me.chkInvoiceAgaistBarCode.CheckState = 1 Then
            'Changed for Issue ID 19992 Starts
            'strBarCodeStringForCon = UpdateDispatchSlip
            strBarCodeStringForCon = UpdateDispatchSlip(grid)
            'Changed for Issue ID 19992 Ends
        End If
        With mP_Connection
            blnActiveTrans = False
            If .State = 1 Then .Close() : .Open()
            .BeginTrans()
            blnActiveTrans = True
            'Added for Issue ID eMpro-20080624-19801 Starts
            If mblnMultipleSOAllowed = True Then
                If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                    If UpdateMktSchedules("+") = False Then
                        .RollbackTrans()
                        GoTo ErrHandler
                    End If
                ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                    If UpdateMktSchedules("-") = False Then
                        .RollbackTrans()
                        GoTo ErrHandler
                    End If
                    If UpdateMktSchedules("+") = False Then
                        .RollbackTrans()
                        GoTo ErrHandler
                    End If
                End If
                'Added for Issue ID  eMpro-20080930-22159 Starts
            ElseIf ((UCase(Trim(CmbInvType.Text)) = "NORMAL INVOICE") And (UCase((Trim(CmbInvSubType.Text)) = "FINISHED GOODS") Or (UCase(Trim(CmbInvSubType.Text)) = "TRADING GOODS"))) Or (UCase(Trim(CmbInvType.Text)) = "JOBWORK INVOICE") Or (UCase(Trim(CmbInvType.Text)) = "EXPORT INVOICE") Or (UCase(Trim(CmbInvType.Text)) = "SERVICE INVOICE") Or ((UCase(Trim(CmbInvType.Text)) = "TRANSFER INVOICE") And mblnSORequired = True) Then
                If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                    If UCase(CmbInvType.Text) = "TRANSFER INVOICE" And CmbInvSubType.Text <> "SUB ASSEMBLY" Then
                        If UpdateForSchedules("+") = False Then
                            .RollbackTrans()
                            GoTo ErrHandler
                        End If
                    End If
                ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                    If UCase(CmbInvType.Text) = "TRANSFER INVOICE" And CmbInvSubType.Text <> "SUB ASSEMBLY" Then
                        If UpdateForSchedules("-") = False Then
                            .RollbackTrans()
                            GoTo ErrHandler
                        End If
                        If UpdateForSchedules("+") = False Then
                            .RollbackTrans()
                            GoTo ErrHandler
                        End If
                    End If
                End If
                'Added for Issue ID  eMpro-20080930-22159 Ends
            End If
            'Added for Issue ID eMpro-20080624-19801 Ends
            .Execute(strSalesChallan, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            If Len(Trim(strupSalechallan)) > 0 Then
                .Execute(strupSalechallan, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            End If
            .Execute(strSalesDtl, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            If Len(Trim(mstrUpdDispatchSql)) > 0 Then
                .Execute(mstrUpdDispatchSql, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            End If
            If Len(Trim(strSQLForm_DTL)) > 0 Then
                .Execute(strSQLForm_DTL, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            End If
            ' Add by Sandeep Save Data
            If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                If mblnRejTracking = True And CmbInvType.Text = "REJECTION" Then
                    If Len(Trim(strSQLREJINV_DTL)) > 0 Then
                        .Execute(strSQLREJINV_DTL, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    End If
                End If
            ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                If mblnRejTracking = True And strInvType = "REJ" Then
                    If Len(Trim(strSQLREJINV_DTL)) > 0 Then
                        .Execute(strSQLREJINV_DTL, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    End If
                End If
            End If
            'Code add by Sourabh---------------
            If Len(Trim(strbatchdtl)) > 0 Then
                .Execute(strbatchdtl, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            End If
            '----------------------------------
            If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                If Len(Trim(strSalesDtlDelete)) > 0 Then
                    .Execute(strSalesDtlDelete, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                End If
            End If
            'Code Added By Arshad Ali on 18/02/2005
            If (UCase(CmbInvType.Text) = "SERVICE INVOICE" Or mstrInvoiceType = "SRC") And mblnServiceInvoiceWithoutSO Then
                If Len(mstrGRINSelected) > 0 Then
                    If Len(mstrRGPHdr) > 0 Then .Execute(mstrRGPHdr, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    If Len(mstrRGPDtl) > 0 Then .Execute(mstrRGPDtl, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    If Len(mstrNRGPDetail) > 0 Then .Execute(mstrNRGPDetail, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                    If Len(mstrItemBatch) > 0 Then .Execute(mstrItemBatch, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                End If
            End If
            'Ends here
            If Len(Trim(strBarCodeStringForCon)) > 0 Then
                .Execute(strBarCodeStringForCon, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            End If
            'Added for Issue ID 21105 Starts
            If InvAgstBarCode() = True And CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT And mstrFGDomestic = "1" Then
                If BarCodeTracking(Trim(txtChallanNo.Text), "EDIT") = True And Len(Trim(mstrupdateBarBondedStockFlag)) > 0 Then
                    mP_Connection.Execute(mstrupdateBarBondedStockFlag, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
                End If
            End If
            'Added for Issue ID 21105 Ends
            .CommitTrans()
            blnActiveTrans = False
            'Code Added By Arshad Ali on 18/02/2005
            If (UCase(CmbInvType.Text) = "SERVICE INVOICE" Or mstrInvoiceType = "SRC") And mblnServiceInvoiceWithoutSO Then
                If Len(mstrGRINSelected) > 0 And Len(strNRGPNo) > 0 Then
                    MsgBox("NRGP saved with Document Number " & strNRGPNo & ".", MsgBoxStyle.Information + MsgBoxStyle.OkOnly, ResolveResString(100))
                End If
            End If
        End With
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        If blnActiveTrans Then mP_Connection.RollbackTrans()
        SaveData_GST = False
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
	Private Function MakeSQL_REJINVTRACKING(ByRef intRow As Short) As String
		' Add by Sandeep
		On Error GoTo ErrHandler
		Dim strSql As String
		Dim varCompileData As Object
		
		Dim strallbatches() As String
		Dim strBatch As Object
		Dim strBatchDetail() As String
		Dim strBatDetail As Object
		
		Dim strLocation_Code As String
		Dim intRejType As Short
		Dim strItem_code As Object
		Dim strcustpartcode As Object
		Dim strDoc_No As String
		Dim strbatch_no As String
		Dim dblQuantity As String
		Dim strInvNo As String
		
		strLocation_Code = Trim(txtLocationCode.Text)
		
		strInvNo = txtChallanNo.Text
        'Added for Issue ID eMpro-20090506-31083 Starts
        Dim varQty As Object
        varQty = Nothing
        SpChEntry.GetText(EnumInv.EnumQuantity, intRow, varQty)
        'Added for Issue ID eMpro-20090506-31083 Ends
        varCompileData = Nothing
        SpChEntry.GetText(EnumInv.Doc_Detail, intRow, varCompileData)
        strItem_code = Nothing
        SpChEntry.GetText(EnumInv.enumItemCode, intRow, strItem_code)
        strcustpartcode = Nothing
		SpChEntry.GetText(EnumInv.CustPartNo, intRow, strcustpartcode)
		
        If CmdGrpChEnt.mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
            '1-GRN;2-LRN
            If chkRejType.Text = "GRN" Then
                intRejType = 1
            Else
                intRejType = 2
            End If
            strSql = ""
        ElseIf CmdGrpChEnt.mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
            intRejType = Val(Find_Value("Select REJ_TYPE from MKT_INVREJ_DTL where UNIT_CODE = '" & gstrUNITID & "' and  INvoice_No=" & Trim(txtChallanNo.Text)))
            
            strSql = "Delete From MKT_INVREJ_DTL where UNIT_CODE = '" & gstrUNITID & "' and  Item_code='" & strItem_code & "' and Invoice_No='" & Trim(txtChallanNo.Text) & "'" & vbCrLf
        End If
        
        'Changed for Issue ID eMpro-20090506-31083 Starts
        If mblnBatchTracking = True Then
            If Len(Trim(varCompileData)) <> 0 Then
                
                strallbatches = Split(varCompileData, "¶")
                For Each strBatch In strallbatches
                    
                    If Len(Trim(strBatch)) <> 0 Then
                        
                        strBatchDetail = Split(strBatch, "§")
                        strDoc_No = strBatchDetail(0)
                        strbatch_no = strBatchDetail(1)
                        dblQuantity = CStr(CDbl(strBatchDetail(3)))
                        strSql = Trim(strSql) & "Insert Into  MKT_INVREJ_DTL" & " (Location_code, Invoice_No, REJ_Type, Item_Code, Cust_Part_Code, Ref_Doc_No, Batch_No, Quantity, Cancel_Flag, END_DT, END_USERID,UPD_DT, UPD_USERID,unit_code) " & " values ('" & strLocation_Code & "'," & strInvNo & "," & intRejType & ", '" & strItem_code & "', '" & strcustpartcode & "', " & strDoc_No & ",'" & strbatch_no & "', " & dblQuantity & ", 0, Getdate(), '" & mP_User & "',Getdate(), '" & mP_User & "','" & gstrUNITID & "') "
                    End If
                Next strBatch
            End If
        Else
            strSql = Trim(strSql) & "Insert Into  MKT_INVREJ_DTL" & " (Location_code, Invoice_No, REJ_Type, Item_Code, Cust_Part_Code, Ref_Doc_No, Batch_No, Quantity, Cancel_Flag, END_DT, END_USERID,UPD_DT, UPD_USERID,unit_code) " & " values ('" & strLocation_Code & "'," & strInvNo & "," & intRejType & ", '" & strItem_code & "', '" & strcustpartcode & "', " & Trim(txtRefNo.Text) & ",'', " & CDbl(varQty) & ", 0, Getdate(), '" & mP_User & "',Getdate(), '" & mP_User & "','" & gstrUNITID & "') "
        End If
        'Changed for Issue ID eMpro-20090506-31083 Ends
        MakeSQL_REJINVTRACKING = strSql
        Exit Function ' This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateBasicValue(ByVal pintRowNo As Short, ByVal blnRoundoff As Boolean, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        '---------------------------------------------------------------------------------------
        'Name       :   CalculateBasicValue
        'Type       :   Function
        'Author     :   Tapan Jain
        'Arguments  :
        'Return     :
        'Purpose    :
        'Revised By : Manoj Kr. Vaish Issue ID 19992
        'Revision History : Add one more paramtere for Grid control
        '---------------------------------------------------------------------------------------
        Dim ldblPkg_Per As Double
        Dim ldblRate As Double
        Dim lintQty As Double
        'Added By Arshad Ali
        Dim intBasicRoundOffDecimal As Short
        'Ends here
        On Error GoTo ErrHandler
        With grid
            
            .Row = pintRowNo
            
            .Col = EnumInv.Rate_PerUnit
            
            ldblRate = Val(.Text) / Val(ctlPerValue.Text)
            
            .Col = EnumInv.Packing
            ldblPkg_Per = Val(.Text)
            
            .Col = EnumInv.EnumQuantity
            lintQty = Val(.Text)
            
            .Col = EnumInv.CustSuppMat_perunit
            intBasicRoundOffDecimal = Val(Find_Value("select basic_roundoff_decimal from sales_parameter where UNIT_CODE = '" & gstrUNITID & "' "))
            If blnRoundoff = True Then
                '''Changes done By ashutosh on 22-08-2006,Issue Id:18477
                '''CalculateBasicValue = Round(((ldblRate + ((ldblPkg_Per * ldblRate) / 100)) * lintQty))
                CalculateBasicValue = System.Math.Round(ldblRate * lintQty)
            Else
                '''CalculateBasicValue = Round(((ldblRate + ((ldblPkg_Per * ldblRate) / 100)) * lintQty), intBasicRoundOffDecimal)
                CalculateBasicValue = System.Math.Round(ldblRate * lintQty, intBasicRoundOffDecimal)
                '''changes for Issue Id:18477 end here.
            End If
        End With
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateAccessibleValue(ByVal pintRowNo As Short, ByVal pdblInsurenceValue As Double, ByVal pblnISInsAdd As Boolean, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        '---------------------------------------------------------------------------------------
        'Name       :   CalculateAccessibleValue
        'Type       :   Function
        'Author     :   Tapan Jain
        'Arguments  :
        'Return     :
        'Purpose    :
        'Revised By : Manoj Kr. Vaish Issue ID 19992
        'Revision History : Add one more paramtere for Grid control
        '---------------------------------------------------------------------------------------
        Dim ldblRate As Double
        Dim ldblCustMat As Double
        Dim ldblToolCost As Double
        Dim ldblPkg_Per As Double
        Dim lintQty As Double
        Dim RSAccessibleVal As ClsResultSetDB
        Dim strSql As String
        Dim dblMRP As Double
        Dim dblAbatment As Double
        On Error GoTo ErrHandler
        With grid
            
            .Row = pintRowNo
            
            .Col = EnumInv.Rate_PerUnit
            
            ldblRate = Val(.Text) / Val(ctlPerValue.Text)
            
            .Col = EnumInv.Packing
            ldblPkg_Per = Val(.Text)
            
            .Col = EnumInv.EnumQuantity
            lintQty = Val(.Text)
            
            .Col = EnumInv.CustSuppMat_perunit
            
            ldblCustMat = Val(.Text) / Val(ctlPerValue.Text)
            'Added by Arshad on 12/07/2004 to allow user to enter tool cost incase of Sample invoice
            ' Code add by Sourabh on 16 July 2005
            If UCase(mstrInvoiceType) = "SMP" Or UCase(mstrInvoiceType) = "TRF" Then
                
                .Col = EnumInv.ToolCost_PerUnit
                
                ldblToolCost = Val(.Text) / Val(ctlPerValue.Text)
            Else
                
                .Col = EnumInv.ToolCost
                
                ldblToolCost = Val(.Text) / Val(ctlPerValue.Text)
            End If
            'Ends here
            '''***** Changes done by Ashutosh on 01-06-2006, Issue Id:17929
            If CheckSOType(pintRowNo) = "M" Then
                RSAccessibleVal = New ClsResultSetDB
                strSql = "select  isnull(AccessibleRateforMRP,0) as MRPValue from Cust_Ord_Dtl COH where UNIT_CODE = '" & gstrUNITID & "' and  Account_code = '" & Trim(txtCustCode.Text) & "' and Cust_Ref='" & Trim(txtRefNo.Text) & "'"
                strSql = strSql & " and COH.Amendment_No='" & Trim(txtAmendNo.Text) & "'"
                
                .Col = EnumInv.enumItemCode
                strSql = strSql & " and COH.Item_Code = '" & .Text & "'"
                
                .Col = EnumInv.CustPartNo
                strSql = strSql & " and COH.Cust_Drgno = '" & .Text & "'"
                RSAccessibleVal.GetResult(strSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If RSAccessibleVal.GetNoRows > 0 Then
                    
                    dblMRP = RSAccessibleVal.GetValue("MRPValue")
                    CalculateAccessibleValue = System.Math.Round((dblMRP * lintQty) - ((dblMRP * lintQty) * dblAbatment / 100), 2)
                End If
                RSAccessibleVal.ResultSetClose()
                '''***** Changes for Issue id: 17929 end here.
            Else
                If pblnISInsAdd = True Then
                    'changes don by nisha insurance calculation on 24/06/2003
                    '''Changes doen By Ashutosh on 22-08-2006,Issue Id:18477
                    '''CalculateAccessibleValue = Round(((ldblRate + ldblCustMat + ldblToolCost + ((ldblPkg_Per * ldblRate) / 100)) * lintQty) + pdblInsurenceValue, 2)
                    If gblnGSTUnit Then
                        CalculateAccessibleValue = System.Math.Round((ldblRate + ldblCustMat + ldblToolCost) * lintQty, 2)
                    Else
                        CalculateAccessibleValue = System.Math.Round(((ldblRate + ldblCustMat + ldblToolCost) * lintQty) + pdblInsurenceValue, 2)
                    End If
                Else
                    '''CalculateAccessibleValue = Round((ldblRate + ldblCustMat + ldblToolCost + ((ldblPkg_Per * ldblRate) / 100)) * lintQty, 2)
                    CalculateAccessibleValue = System.Math.Round((ldblRate + ldblCustMat + ldblToolCost) * lintQty, 2)
                    '''Changes for Issue Id:18477 end here.
                End If

            End If
        End With
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateExciseValue(ByVal pintRowNo As Short, ByVal pdblAccessibleValue As Double, ByVal penumTaxType As enumExciseType, ByRef pblnEOU_FLAG As Boolean, ByRef blnExciseFlag As Boolean, ByRef pdblLoadingCharges As Double, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        '---------------------------------------------------------------------------------------
        'Name       :   CalculateExciseValue
        'Type       :   Function
        'Author     :   Tapan Jain
        'Arguments  :
        'Return     :
        'Purpose    :
        '=======================================================================================
        'Revision  By       : Ashutosh , Issue Id :17400
        'Revision On        : 23-03-2006
        'History            : Change Excise duty as 25% of excise percentage in case of Scrap Invoice at MSSLED .
        'Revised By : Manoj Kr. Vaish Issue ID 19992
        'Revision History : Add one more paramtere for Grid control
        '=======================================================================================
        Dim strTableSql As String 'Declared To Make Select Query
        Dim rsGetTaxRate As ClsResultSetDB
        Dim ldblTaxRate As Double
        Dim ldblCVDRate As Double
        Dim ldblSADRate As Double
        Dim ldblTempTotalExcise As Double
        Dim ldblTempTotalCVD As Double
        Dim ldblTempTotalSAD As Double
        Dim ldblTempAllExcise As Double
        'Code add by Sourabh
        Dim ldblTempEcssOnCVD As Double
        'Code end here
        'Code add by Manoj
        Dim ldblSTempEcssOnCVD As Double
        'Code end here
        On Error GoTo ErrHandler
        ldblTempTotalExcise = 0
        ldblTempTotalCVD = 0
        ldblTempTotalSAD = 0
        ldblTempAllExcise = 0
        ldblTempEcssOnCVD = 0
        ldblSTempEcssOnCVD = 0
        Dim strCompCode As String
        Dim strInvoiceType As String
        With grid
            
            .Row = pintRowNo
            
            .Col = EnumInv.Excise
            rsGetTaxRate = New ClsResultSetDB
            strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No='" & Trim(.Text) & "' and UNIT_CODE = '" & gstrUNITID & "' "
            rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            If rsGetTaxRate.GetNoRows > 0 Then
                
                ldblTaxRate = rsGetTaxRate.GetValue("TxRt_Percentage")
            Else
                ldblTaxRate = 0
            End If
            rsGetTaxRate.ResultSetClose()
            If pblnEOU_FLAG Then
                
                .Col = EnumInv.CVD
                strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No='" & Trim(.Text) & "' and UNIT_CODE = '" & gstrUNITID & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    
                    ldblCVDRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                Else
                    ldblCVDRate = 0
                End If
                rsGetTaxRate.ResultSetClose()
                
                .Col = EnumInv.SAD
                strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No='" & Trim(.Text) & "' and UNIT_CODE = '" & gstrUNITID & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    
                    ldblSADRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                Else
                    ldblSADRate = 0
                End If
                rsGetTaxRate.ResultSetClose()
                'changes done by nisha to add Loading charges
                ldblTempTotalExcise = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                '''***** Changes done By Ashutosh on 23-03-2006 ,Issue Id :17400
                strCompCode = "select plant_name from ProductionConf where UNIT_CODE = '" & gstrUNITID & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strCompCode, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    
                    If rsGetTaxRate.GetValue("Plant_name") = "MSSLED" Then
                        rsGetTaxRate.ResultSetClose()
                        If Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                            strInvoiceType = "Select Invoice_Type,Sub_Category from Saleschallan_Dtl where doc_no='" & Trim(txtChallanNo.Text) & "' and UNIT_CODE = '" & gstrUNITID & "' "
                            rsGetTaxRate = New ClsResultSetDB
                            rsGetTaxRate.GetResult(strInvoiceType, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                            
                            If UCase(Trim(rsGetTaxRate.GetValue("Invoice_Type"))) = "INV" And UCase(Trim(rsGetTaxRate.GetValue("sub_Category"))) = "L" Then
                                ldblTempTotalExcise = (ldblTempTotalExcise * 25) / 100
                            End If
                            rsGetTaxRate.ResultSetClose()
                        ElseIf Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                            If UCase(Trim(CmbInvType.Text)) = "NORMAL INVOICE" And UCase(Trim(CmbInvSubType.Text)) = "SCRAP" Then
                                ldblTempTotalExcise = (ldblTempTotalExcise * 25) / 100
                            End If
                        End If
                    Else
                        rsGetTaxRate.ResultSetClose()
                    End If
                Else
                    rsGetTaxRate.ResultSetClose()
                End If
                '''***** Changes on 23-03-2006 end here.
                If blnExciseFlag = True Then
                    ldblTempTotalExcise = System.Math.Round(ldblTempTotalExcise, 0)
                End If
                '**********changed by Nisha on 29/08/2033 for DTA invoice Excise
                'Code add by Sourabh
                ldblTempAllExcise = ldblTempTotalExcise * (Val(Me.txtEouExcisePer.Text) / 100)
                '*********changes ends here
                '********changed by nisha on 13/10/2002
                'changes done by nisha to add Loading charges
                ldblTempTotalCVD = (((ldblTempTotalExcise + (pdblAccessibleValue + pdblLoadingCharges)) * ldblCVDRate) / 100)
                ''ldblTempTotalCVD = ((ldblTempTotalExcise * ldblCVDRate) / 100)
                ''ldblTempTotalSAD = ((ldblTempTotalCVD * ldblSADRate) / 100)
                If blnExciseFlag = True Then
                    ldblTempTotalCVD = System.Math.Round(ldblTempTotalCVD, 0)
                End If
                '**********changed by Nisha on 29/08/2033 for DTA invoice Excise
                ldblTempAllExcise = ldblTempAllExcise + (ldblTempTotalCVD * (Val(Me.txtEouExcisePer.Text) / 100))
                '*********changes ends here
                'changes done by nisha to add Loading charges
                ldblTempTotalSAD = (((ldblTempTotalCVD + ldblTempTotalExcise + (pdblAccessibleValue + pdblLoadingCharges)) * ldblSADRate) / 100)
                If blnExciseFlag = True Then
                    ldblTempTotalSAD = System.Math.Round(ldblTempTotalSAD, 0)
                End If
                ldblTempEcssOnCVD = (ldblTempTotalCVD * Val(Me.lblEcessCVDPer.Text)) / 100
                'Code Added by Manoj on 04 May 2007 for Issue Id : 19916 Start
                ldblSTempEcssOnCVD = (ldblTempTotalCVD * Val(Me.lblSEcessCVDPer.Text)) / 100
                'Code Added by Manoj on 04 May 2007 for Issue Id : 19916 Ends
                If blnExciseFlag = True Then
                    ldblTempEcssOnCVD = System.Math.Round(ldblTempEcssOnCVD, 0)
                    ldblSTempEcssOnCVD = System.Math.Round(ldblSTempEcssOnCVD, 0)
                End If
                '************
                '**********changed by Nisha on 29/08/2033 for DTA invoice Excise
                'Code add by Sourabh
                ldblTempAllExcise = ldblTempAllExcise + (ldblTempTotalSAD * (Val(Me.txtEouExcisePer.Text) / 100))
                If blnExciseFlag = True Then
                    ldblTempAllExcise = System.Math.Round(ldblTempAllExcise, 0)
                End If
                If penumTaxType = enumExciseType.RETURN_EXCISE Then
                    ''CalculateExciseValue = (ldblTempTotalExcise + ldblTempTotalCVD + ldblTempTotalSAD) / 2
                    ''Changed At MSSLED by tapan to incorporated in new form of invoice entry
                    CalculateExciseValue = (ldblTempTotalExcise)
                ElseIf penumTaxType = enumExciseType.RETURN_CVD Then
                    CalculateExciseValue = ldblTempTotalCVD
                ElseIf penumTaxType = enumExciseType.RETURN_SAD Then
                    CalculateExciseValue = ldblTempTotalSAD
                Else
                    CalculateExciseValue = ldblTempAllExcise + (ldblTempEcssOnCVD) + (ldblSTempEcssOnCVD)
                End If
            Else
                If penumTaxType = enumExciseType.RETURN_EXCISE Then
                    'changes done by nisha to add Loading charges
                    CalculateExciseValue = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                ElseIf penumTaxType = enumExciseType.RETURN_CVD Then
                    CalculateExciseValue = 0
                ElseIf penumTaxType = enumExciseType.RETURN_SAD Then
                    'CalculateExciseValue = 0
                    'Changed for Issue ID eMpro-20080508-18500 Starts
                    .Col = EnumInv.SAD
                    strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No='" & Trim(.Text) & "' and UNIT_CODE = '" & gstrUNITID & "'"
                    rsGetTaxRate = New ClsResultSetDB
                    rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly) ' adOpenStatic, adLockReadOnly)
                    If rsGetTaxRate.GetNoRows > 0 Then
                        ldblSADRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                    Else
                        ldblSADRate = 0
                    End If
                    rsGetTaxRate.ResultSetClose()
                    If mstrInvoiceType = "TRF" Then
                        CalculateExciseValue = (((pdblAccessibleValue) * ldblSADRate) / 100)
                    Else
                        CalculateExciseValue = 0
                    End If
                    'Changed for Issue ID eMpro-20080508-18500 Ends
                Else
                    ' 07/11/2003 code change by nisha on for retunning Total Excise Value
                    CalculateExciseValue = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                    'Changes Ends here
                End If
            End If
        End With
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateSalesTaxValue(ByVal pdblTotalBasicValue As Double, ByVal pdblTotalExciseValue As Double, ByRef pblnIncStax As Boolean, ByRef pdblInsurance As Double) As Double
        '---------------------------------------------------------------------------------------
        'Name       :   CalculateSalesTaxValue
        'Type       :   Function
        'Author     :   Tapan Jain
        'Arguments  :
        'Return     :
        'Purpose    :
        '---------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        '24/06/2003 changes for insurance in S Tax claculation
        '*** code added by preety for calculation of discount
        Dim dbldiscountamount As Double
        ' to calculate discount only id discount amount is available
        
        If System.Math.Round(Val(txtDiscountAmt.Text)) > 0 Then
            ' to calculate Discount Amount by value
            If OptDiscountValue.Checked = True Then
                
                dbldiscountamount = System.Math.Round(Val(txtDiscountAmt.Text), 0)
            Else
                If chkExciseExumpted.CheckState = System.Windows.Forms.CheckState.Unchecked Then
                    ' to calculate Discount Amount by Percentage if Excise Duty is available
                    
                    dbldiscountamount = ((pdblTotalBasicValue + pdblTotalExciseValue) * Val(txtDiscountAmt.Text)) / 100
                Else
                    ' to calculate Discount Amount by Percentage if Excise Duty is not available
                    
                    dbldiscountamount = ((pdblTotalBasicValue) * Val(txtDiscountAmt.Text)) / 100
                End If
            End If
        Else
            ' if discount amount is not available
            dbldiscountamount = 0
        End If
        '****
        If pblnIncStax = True Then
            '*********09/07/2003 changes done by nisha for Excise Exumpted
            ' *** code edited by preety - Sales Tax is calculated on Basic value + Insurance value + excise value + Discount Amount
            If chkExciseExumpted.CheckState = System.Windows.Forms.CheckState.Unchecked Then
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue + pdblInsurance - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            Else
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblInsurance - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            End If
        Else
            If chkExciseExumpted.CheckState = System.Windows.Forms.CheckState.UnChecked Then
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            Else
                CalculateSalesTaxValue = ((pdblTotalBasicValue - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            End If
            '*********09/07/2003 changes Ends here
        End If
        '24/06/2003 changes for insurance in S Tax claculation
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, err.Source, Err.Description, mp_connection)
    End Function
