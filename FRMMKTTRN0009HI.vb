            UpdateDispatchSlip = "update tbl_barcode_materialout Set invoice_no = '" & Me.txtChallanNo.Text & "' where  UNIT_CODE = '" & gstrUNITID & "' and doc_no in (" & strString & ") and OEM_Code in (" & strstring1 & ")"
