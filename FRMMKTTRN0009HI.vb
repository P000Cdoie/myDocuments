            If OptRejection.Checked Then
                mstrLocationCode = Find_Value("Select Transfer_RejectionLoc from sales_parameter WHERE UNIT_CODE='" + gstrUNITID + "'")
                strItembal = "Select Cur_Bal From ItemBal_Mst WHERE UNIT_CODE='" + gstrUNITID + "' AND  Location_Code ='" & mstrLocationCode & "' and item_Code in('" & varItemCode & "')"
            Else
                strItembal = "Select Cur_Bal From ItemBal_Mst where  UNIT_CODE='" + gstrUNITID + "' AND Location_Code ='" & mstrLocationCode & "' and item_Code ='" & varItemCode & "'"
            End If
            rsMktSchedule = New ClsResultSetDB
            rsMktSchedule.GetResult(strItembal, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            strcurbal = CStr(Val(rsMktSchedule.GetValue("Cur_Bal")))
            txtcurrentstock.Text = strcurbal
            rsMktSchedule.ResultSetClose()
            Rs.ResultSetClose()
        End If
