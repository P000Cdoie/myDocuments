    Private Function ValidateTariff_CESS(ByRef grid As AxFPSpreadADO.AxfpSpread) As Boolean
        '----------------------------------------------------------------------------------
        'Created By     -   Ashutosh Verma
        'Description    -   Check for tariff code and Ecess.
        'Created On     -   13 Apr 2006 , Issue Id: 17355
        'Arguments      -
        'Revised By     -   Manoj Kr. Vaish Issue ID 19992
        'Revision History-  Check for tariff code and Ecess by passing parameterized grid control
        '----------------------------------------------------------------------------------
        Dim intItem As Short
        Dim strItemList As String
        Dim blnExcisableItem As Boolean
        Dim strExciseTax As String
        Dim strECESSTax As String
        Dim rsECESSTax_Percentage As ClsResultSetDB
        Dim rsExcise_Percentage As ClsResultSetDB
        Dim dblExcisePercentage As Double
        Dim dblTemp As Double
        '''Added By Ashutosh on 22-08-2006,Issue Id:18477
        Dim rsPacking As ClsResultSetDB
        Dim strPackingTax As String
        Dim dblPackingPercentage As Double
        Dim dblPackingTemp As Double
        'Added for Issue ID 19992 Starts
        Dim rsSECESSTax_Percentage As ClsResultSetDB
        Dim strSECESSTax As String
        Dim Excise_Tax_Type As Object
        Dim Packing_Tax_Type As Object
        'Added for Issue ID 19992 Ends
        On Error GoTo ErrHandler
        
        For intItem = 1 To grid.maxRows
            
            grid.Col = EnumInv.Excise
            
            grid.Row = intItem
            strExciseTax = Trim(grid.Text)
            Excise_Tax_Type = Nothing
            grid.GetText(grid.Col, grid.Row, Excise_Tax_Type)
            '''Added By Ashutosh on 22-08-2006,Issue Id:18477
            
            grid.Col = EnumInv.Packing
            
            grid.Row = intItem
            Packing_Tax_Type = Nothing
            grid.GetText(grid.Col, grid.Row, Packing_Tax_Type)
            strPackingTax = Trim(grid.Text)
            '''End here.
            If Trim(Excise_Tax_Type) = "" Then
                MsgBox("Excise Tax Can't be blank for Item. Please enter Valid Excise Tax.", MsgBoxStyle.Information, ResolveResString(100))
                ValidateTariff_CESS = False
                Exit Function
            End If
            '''Changes done by Ashutosh on 22-08-2006 ,Issue Id:18477
            If Trim(Packing_Tax_Type) = "" Then
                MsgBox("Packing Tax Can't be blank for Item. Please enter Valid Packing Tax.", MsgBoxStyle.Information, ResolveResString(100))
                ValidateTariff_CESS = False
                Exit Function
            End If
            rsPacking = New ClsResultSetDB
            rsPacking.GetResult("SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No ='" & Trim(Packing_Tax_Type) & "' AND Tx_TaxeID='PKT'  and UNIT_CODE = '" & gstrUNITID & "'", ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            If rsPacking.GetNoRows > 0 Then
                If intItem = 1 Then
                    
                    dblPackingTemp = rsPacking.GetValue("TxRt_Percentage")
                Else
                    
                    dblPackingPercentage = rsPacking.GetValue("TxRt_Percentage")
                End If
            End If
            If intItem > 1 Then
                If dblPackingPercentage <> dblPackingTemp Then
                    MsgBox("Packing percentage should be same for all items.", MsgBoxStyle.Information, "eMpro")
                    ValidateTariff_CESS = False
                    rsPacking.ResultSetClose()
                    Exit Function
                End If
            End If
            
            rsPacking.ResultSetClose()
            '''Changes fro Issue Id:18477 end here.
            rsExcise_Percentage = New ClsResultSetDB
            rsExcise_Percentage.GetResult("SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No ='" & Trim(Excise_Tax_Type) & "' AND Tx_TaxeID='EXC'  and UNIT_CODE = '" & gstrUNITID & "'", ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            If intItem = 1 Then
                
                dblTemp = rsExcise_Percentage.GetValue("TxRt_Percentage")
            Else
                
                dblExcisePercentage = rsExcise_Percentage.GetValue("TxRt_Percentage")
            End If
            If intItem > 1 Then
                If dblExcisePercentage <> dblTemp Then
                    MsgBox("Excise percentage should be same for all items.", MsgBoxStyle.Information, ResolveResString(100))
                    ValidateTariff_CESS = False
                    Exit Function
                End If
            End If
            
            If rsExcise_Percentage.GetValue("TxRt_Percentage") <> 0 Then
                blnExcisableItem = True
                
                grid.Col = EnumInv.enumItemCode
                
                grid.Row = intItem
                If ValidateTariffCode(Trim(grid.Text)) = False Then
                    If Len(strItemList) = 0 Then
                        strItemList = Trim(grid.Text)
                    Else
                        strItemList = strItemList & "," & Trim(grid.Text)
                    End If
                End If
            End If
            rsExcise_Percentage.ResultSetClose()
        Next intItem
        If Len(strItemList) > 1 Then
            MsgBox("Tariff Code is required for Item(s)-- " & strItemList, MsgBoxStyle.Information, ResolveResString(100))
            ValidateTariff_CESS = False
            Exit Function
        End If
        '''***** ECESS can't be zero for excisable items.
        strECESSTax = (Me.txtECSSTaxType.Text)
        If Trim(strECESSTax) = "" Then
            MsgBox("Ecess Can't be blank. Please enter Valid Ecess.", MsgBoxStyle.Information, ResolveResString(100))
            ValidateTariff_CESS = False
            Exit Function
        End If
        rsECESSTax_Percentage = New ClsResultSetDB
        rsECESSTax_Percentage.GetResult("SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No ='" & Trim(strECESSTax) & "' AND Tx_TaxeID='ECS'  and UNIT_CODE = '" & gstrUNITID & "'", ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
        If blnExcisableItem = True Then

            '10238605
            'If rsECESSTax_Percentage.GetValue("TxRt_Percentage") = 0 Then
            '    MsgBox("Ecess can not be zero for Excisable Items.", MsgBoxStyle.Information, ResolveResString(100))
            '    ValidateTariff_CESS = False
            '    rsECESSTax_Percentage.ResultSetClose()
            '    Exit Function
            'End If
        Else
            
            If rsECESSTax_Percentage.GetValue("TxRt_Percentage") <> 0 Then
                MsgBox("Ecess can not be Charged for Non Excisable Items.", MsgBoxStyle.Information, ResolveResString(100))
                ValidateTariff_CESS = False
                Me.txtECSSTaxType.Text = ""
                Me.txtECSSTaxType.Focus()
                rsECESSTax_Percentage.ResultSetClose()
                Exit Function
            End If
        End If
        rsECESSTax_Percentage.ResultSetClose()
        'Added for Issue ID 19992 Starts
        '''***** SHECESS can't be zero for excisable items.
        strSECESSTax = (Me.txtSECSSTaxType.Text)
        If Trim(strSECESSTax) = "" Then
            MsgBox("SHEcess Can't be blank. Please enter Valid SHEcess.", MsgBoxStyle.Information, ResolveResString(100))
            ValidateTariff_CESS = False
            Exit Function
        End If
        rsSECESSTax_Percentage = New ClsResultSetDB
        rsSECESSTax_Percentage.GetResult("SELECT TxRt_Percentage FROM Gen_TaxRate WHERE TxRt_Rate_No ='" & Trim(strSECESSTax) & "' AND Tx_TaxeID='ECSSH'  and UNIT_CODE = '" & gstrUNITID & "'", ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
        If blnExcisableItem = True Then
            '10238605
            'If rsSECESSTax_Percentage.GetValue("TxRt_Percentage") = 0 Then
            '    MsgBox("SHEcess can not be zero for Excisable Items.", MsgBoxStyle.Information, ResolveResString(100))
            '    ValidateTariff_CESS = False
            '    rsSECESSTax_Percentage.ResultSetClose()
            '    Exit Function
            'End If
        Else
            
            If rsSECESSTax_Percentage.GetValue("TxRt_Percentage") <> 0 Then
                MsgBox("SHEcess can not be Charged for Non Excisable Items.", MsgBoxStyle.Information, ResolveResString(100))
                ValidateTariff_CESS = False
                Me.txtSECSSTaxType.Text = ""
                Me.txtSECSSTaxType.Focus()
                rsSECESSTax_Percentage.ResultSetClose()
                Exit Function
            End If
        End If
        rsSECESSTax_Percentage.ResultSetClose()
        'Added for Issue ID 19992 Ends
        ValidateTariff_CESS = True
        Exit Function
ErrHandler:
        gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
