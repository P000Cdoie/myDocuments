                End If
                'CHANGED ON 15/07/2002 FOR EXPORT INVOICE
                'changes done by nisha to add service type of invoice
                ' Code add by sourabh on 22 nov 2005 against issue id PRJ-2004-04-003-16261
                If Me.chkInvoiceAgaistBarCode.Visible = True And Me.chkInvoiceAgaistBarCode.CheckState = 1 Then
