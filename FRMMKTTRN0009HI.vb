    Public Function FillSelectedItemInGrid() As Object
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : NIL
        ' Return Value  : NIL
        ' Function      : Fill the grid with selected item for multiplt SO
        ' Datetime      : 13 June 2007
        'Issue ID       : 19992
        '--------------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        Dim intArrCtr As Short
        Dim varFromBox As Object
        Dim VarToBox As Object
        Dim varCumulativeBoxes As Object
        Call AddColumnsInSpread()
        Select Case CmdGrpChEnt.mode
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_ADD
                With spitems
                    For intArrCtr = 1 To UBound(mItemSODtlArr) Step 1
                        Call AddBlankRowinGrid(mItemSODtlArr(intArrCtr).Decimal_1, mItemSODtlArr(intArrCtr).NoOfDeci)
                        Call .SetText(EnumInv.enumItemCode, .maxRows, mItemSODtlArr(intArrCtr).ItemCode) : .Lock = True
                        Call .SetText(EnumInv.CustPartNo, .maxRows, mItemSODtlArr(intArrCtr).CustDrgNo) : .Lock = True
                        Call .SetText(EnumInv.CustRef, .maxRows, mItemSODtlArr(intArrCtr).CustRef) : .Lock = True
                        Call .SetText(EnumInv.AmendmentNo, .maxRows, mItemSODtlArr(intArrCtr).AmendmentNo) : .Lock = True
                        Call .SetText(EnumInv.BalQuantity, .MaxRows, Val(mItemSODtlArr(intArrCtr).balqty)) : .Lock = True
                        Call .SetText(EnumInv.EnumQuantity, .maxRows, "")
                        
                        .CtlEditMode = True : .Lock = False
                        
                        Call .SetText(EnumInv.Rate_PerUnit, .MaxRows, Val(mItemSODtlArr(intArrCtr).Rate) * Val(ctlPerValue.Text)) : .Lock = True
                        
                        .CtlEditMode = False
                        Call .SetText(EnumInv.Excise, .maxRows, mItemSODtlArr(intArrCtr).Excise) : .Lock = True
                        Call .SetText(EnumInv.Packing, .maxRows, mItemSODtlArr(intArrCtr).Packing) : .Lock = True
                        
                        Call .SetText(EnumInv.CustSuppMat_perunit, .MaxRows, Val(mItemSODtlArr(intArrCtr).Cust_Mtrl) * Val(ctlPerValue.Text)) : .Lock = True
                        
                        Call .SetText(EnumInv.Others_PerUnit, .MaxRows, Val(mItemSODtlArr(intArrCtr).Others) * Val(ctlPerValue.Text)) : .Lock = True
                        Call .SetText(EnumInv.FromBox, .maxRows, "")
                        
                        .CtlEditMode = True : .Lock = False
                        Call .SetText(EnumInv.ToBox, .maxRows, "")
                        
                        .CtlEditMode = True : .Lock = False
                        Call .SetText(EnumInv.CumulativeBoxes, .maxRows, "") : .Lock = True
                        Call .SetText(EnumInv.BinQty, .MaxRows, Val(mItemSODtlArr(intArrCtr).BinQty))
                        Call .SetText(EnumInv.CurrentStock, .MaxRows, Val(mItemSODtlArr(intArrCtr).CurrentStock)) : .Lock = True
                        Call .SetText(EnumInv.ScheduleQuantity, .MaxCols, Val(mItemSODtlArr(intArrCtr).ScheduleQty))
                        Call .SetText(EnumInv.Rate, .MaxRows, Val(mItemSODtlArr(intArrCtr).Rate)) : .Lock = True
                        Call .SetText(EnumInv.CustMtrl, .MaxRows, Val(mItemSODtlArr(intArrCtr).Cust_Mtrl)) : .Lock = True
                        Call .SetText(EnumInv.Others, .MaxRows, Val(mItemSODtlArr(intArrCtr).Others)) : .Lock = True
                    Next
                    If UBound(mItemSODtlArr) > 0 Then
                        txtCreditTerms.Enabled = True
                        cmdCreditHelp.Enabled = True
                        txtCreditTerms.Text = mstrCreditTerm
                        lblCurrencyDes.Text = mstrCurrency
                        
                        ctlPerValue.Text = mintPerValue
                        Call SelectDescriptionForField("crTrm_desc", "crtrm_termID", "Gen_CreditTrmMaster", lblCreditTermDesc, (txtCreditTerms.Text))
                    End If
                End With
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW, UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT
                With spitems
                    For intArrCtr = 1 To UBound(mItemSODtlArr) Step 1
                        If CmdGrpChEnt.mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                            Call AddBlankRowinGrid(mItemSODtlArr(intArrCtr).Decimal_1, mItemSODtlArr(intArrCtr).NoOfDeci)
                        Else
                            Call AddBlankRowinGrid(True, 2)
                        End If
                        Call .SetText(EnumInv.enumItemCode, .maxRows, mItemSODtlArr(intArrCtr).ItemCode)
                        Call .SetText(EnumInv.CustPartNo, .maxRows, mItemSODtlArr(intArrCtr).CustDrgNo)
                        Call .SetText(EnumInv.CustRef, .maxRows, mItemSODtlArr(intArrCtr).CustRef)
                        Call .SetText(EnumInv.AmendmentNo, .maxRows, mItemSODtlArr(intArrCtr).AmendmentNo)
                        Call .SetText(EnumInv.BalQuantity, .MaxRows, Val(mItemSODtlArr(intArrCtr).balqty))
                        Call .SetText(EnumInv.EnumQuantity, .MaxRows, Val(mItemSODtlArr(intArrCtr).SaleQuantity))
                        Call .SetText(EnumInv.Rate_PerUnit, .MaxRows, Val(mItemSODtlArr(intArrCtr).Rate))
                        Call .SetText(EnumInv.Excise, .maxRows, mItemSODtlArr(intArrCtr).Excise)
                        Call .SetText(EnumInv.Packing, .maxRows, mItemSODtlArr(intArrCtr).Packing)
                        Call .SetText(EnumInv.CustSuppMat_perunit, .MaxRows, Val(mItemSODtlArr(intArrCtr).Cust_Mtrl))
                        Call .SetText(EnumInv.Others_PerUnit, .MaxRows, Val(mItemSODtlArr(intArrCtr).Others))
                        Call .SetText(EnumInv.FromBox, .MaxRows, Val(mItemSODtlArr(intArrCtr).FromBox))
                        Call .SetText(EnumInv.ToBox, .MaxRows, Val(mItemSODtlArr(intArrCtr).ToBox))
                        Call .SetText(EnumInv.CurrentStock, .MaxRows, Val(mItemSODtlArr(intArrCtr).CurrentStock))
                        Call .SetText(EnumInv.ScheduleQuantity, .MaxCols, Val(mItemSODtlArr(intArrCtr).ScheduleQty))
                        varFromBox = Nothing
                        Call .GetText(EnumInv.FromBox, .MaxRows, varFromBox)
                        VarToBox = Nothing
                        Call .GetText(EnumInv.ToBox, .maxRows, VarToBox)
                        If intArrCtr = 1 Then
                            
                            If Len(Trim(varFromBox)) Then
                                
                                If Len(Trim(VarToBox)) Then
                                    
                                    
                                    Call .SetText(EnumInv.CumulativeBoxes, .maxRows, (Val(VarToBox) - Val(varFromBox)) + 1)
                                End If
                            End If
                        Else
                            varCumulativeBoxes = Nothing
                            Call .GetText(EnumInv.CumulativeBoxes, intArrCtr - 1, varCumulativeBoxes)
                            
                            If Len(Trim(varCumulativeBoxes)) Then
                                
                                If Len(Trim(varFromBox)) Then
                                    
                                    If Len(Trim(VarToBox)) Then
                                        
                                        
                                        
                                        Call .SetText(EnumInv.CumulativeBoxes, intArrCtr, varCumulativeBoxes + ((Val(VarToBox) - Val(varFromBox)) + 1))
                                    End If
                                End If
                            End If
                        End If
                        Call .SetText(EnumInv.BinQty, .MaxRows, Val(mItemSODtlArr(intArrCtr).BinQty))
                        If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW Then .Row = 0 : .Row2 = .MaxRows : .Col = 1 : .Col2 = .MaxCols : .BlockMode = True : .Lock = True : .BlockMode = False
                    Next
                End With
        End Select
        If Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
            SSTab1.SelectedIndex = 1
            
            If ctlInsurance.Enabled Then
                
                If ctlInsurance.Enabled Then ctlInsurance.Focus()
            Else
                System.Windows.Forms.SendKeys.Send("{tab}")
            End If
        Else
            Me.CmdGrpChEnt.Focus()
        End If
        Exit Function
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function ValidateRowData(ByVal Row As Integer, Optional ByRef Col As Integer = 0) As Boolean
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : Active row and column
        ' Return Value  : Boolean
        ' Function      : Validate the grid while entering the invoice quantity
        ' Datetime      : 14 June 2007
        'Issue ID       : 19992
        '---------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        Dim intRowCount As Short
        Dim curCurrentStock As Decimal
        Dim curScheduleStock As Decimal
        Dim curInvoiceQuantity As Decimal
        Dim curBalQuantity As Decimal
        Dim curFromBox As Decimal
        Dim strCustRef As String
        Dim strAmendNo As String
        Dim StrItemCode As String
        Dim strCustItemCode As String
        Dim curdispatchqty As Decimal
        ValidateRowData = True
        With spitems
            If .ActiveCol = EnumInv.EnumQuantity Then
                mblnsetfocus = False
                .Row = Row
                .Col = EnumInv.ScheduleQuantity : curScheduleStock = Val(.Text)
                .Col = EnumInv.EnumQuantity : curInvoiceQuantity = Val(.Text)
                .Col = EnumInv.CurrentStock : curCurrentStock = Val(.Text)
                .Col = EnumInv.BalQuantity : curBalQuantity = Val(.Text)
                .Col = EnumInv.CustRef : strCustRef = Trim(.Text)
                .Col = EnumInv.AmendmentNo : strAmendNo = Trim(.Text)
                .Col = EnumInv.enumItemCode : StrItemCode = Trim(.Text)
                .Col = EnumInv.CustPartNo : strCustItemCode = Trim(.Text)
                Call CalculateInvoceQuantity(.ActiveRow, (EnumInv.EnumQuantity))
                If Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                    For intRowCount = 1 To UBound(marrPrevQty) Step 1
                        If StrComp(StrItemCode, marrPrevQty(intRowCount).ItemCode, CompareMethod.Text) = 0 And StrComp(strCustItemCode, marrPrevQty(intRowCount).CustItemCode, CompareMethod.Text) = 0 Then
                            curScheduleStock = marrPrevQty(intRowCount).PrevQuantity + curScheduleStock
                            Exit For
                        End If
                    Next
                End If
                If curInvoiceQuantity = 0 Then
                    Call ConfirmWindow(10419, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                    ValidateRowData = False
                    Exit Function
                ElseIf CheckOpenSO(StrItemCode, strCustItemCode, strCustRef, strAmendNo) = False And (curInvoiceQuantity > curBalQuantity) Then
                    MsgBox("Quantity should not be Greater then Pending SO Quantity [" & curBalQuantity & "]", MsgBoxStyle.Information, ResolveResString(100))
                    ValidateRowData = False
                    Exit Function
                ElseIf curInvoiceQuantity > curScheduleStock Then
                    MsgBox("Quantity should not be Greater then Schedule Quantity [" & curScheduleStock & "]", MsgBoxStyle.Information, ResolveResString(100))
                    Call SetZeroQuanity(StrItemCode, strCustItemCode)
                    ValidateRowData = False
                    Exit Function
                ElseIf Val(txtdispatchqty.Text) > curScheduleStock Then
                    MsgBox("No sufficient Balance Available for Item in Schedule.", MsgBoxStyle.OkOnly, ResolveResString(100))
                    Call SetZeroQuanity(StrItemCode, strCustItemCode)
                    ValidateRowData = False
                    Exit Function
                ElseIf Val(txtdispatchqty.Text) > Val(txtcurrentstock.Text) Then
                    MsgBox("No sufficient Balance Available for Item in Current Stock.", MsgBoxStyle.OkOnly, ResolveResString(100))
                    Call SetZeroQuanity(StrItemCode, strCustItemCode)
                    ValidateRowData = False
                    Exit Function
                End If
            ElseIf .ActiveCol = EnumInv.FromBox Then
                .Row = Row
                .Col = EnumInv.FromBox
                If (Val(Trim(.Value)) = 0) Then
                    Call ConfirmWindow(10419, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                    ValidateRowData = False
                    Exit Function
                End If
            ElseIf .ActiveCol = EnumInv.ToBox Then
                .Row = Row
                .Col = EnumInv.FromBox
                curFromBox = Val(.Value)
                .Col = EnumInv.ToBox
                'To Check Valid Quantity of From/To Box
                If Val(Trim(.Value)) < curFromBox Then
                    Call ConfirmWindow(10235, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                    ValidateRowData = False
                    Exit Function
                End If
            ElseIf .ActiveCol = EnumInv.BinQty Then
                .Row = Row
                .Col = EnumInv.BinQty
                If (Val(Trim(.Value)) = 0) Then
                    Call ConfirmWindow(10419, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                    ValidateRowData = False
                    Exit Function
                End If
            Else
                ValidateRowData = True
                Exit Function
            End If
        End With
        Exit Function
ErrHandler:
        gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateInvoceQuantity(ByVal Row As Integer, Optional ByRef Col As Integer = 0) As Boolean
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : Row,Col
        ' Return Value  : Boolean
        ' Function      : Calculate the entered quantity of items
        ' Datetime      : 13 June 2007
        'Issue ID       : 19992
        '---------------------------------------------------------------------------------------------
        Dim curTempQty As Decimal
        Dim varItemCode As Object
        Dim intRowCount As Short
        Dim VarDelete As Object
        Dim varCustDrg As Object
        On Error GoTo ErrHandler
        With spitems
            .Row = Row
            .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
            .Col = EnumInv.EnumQuantity
            If Row > 0 Then
                .Col = EnumInv.enumItemCode
                
                varItemCode = Trim(.Text)
                .Col = EnumInv.CustPartNo
                
                varCustDrg = Trim(.Text)
                For intRowCount = 1 To .MaxRows
                    VarDelete = Nothing
                    Call spitems.GetText(EnumInv.enumDelete, intRowCount, VarDelete)
                    
                    If UCase(VarDelete) <> "D" Then
                        .Row = intRowCount
                        .Col = EnumInv.EnumQuantity
                        If Val(.Value) > 0 Then
                            .Col = EnumInv.enumItemCode
                            
                            If Trim(.Text) = varItemCode Then
                                .Col = EnumInv.CustPartNo
                                
                                If Trim(.Text) = varCustDrg Then
                                    .Col = EnumInv.EnumQuantity
                                    curTempQty = curTempQty + Val(.Text)
                                End If
                            End If
                        End If
                    End If
                Next
                txtdispatchqty.Text = CStr(curTempQty)
            Else
                txtdispatchqty.Text = CStr(0)
            End If
        End With
        Exit Function
ErrHandler:
        gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Public Function SetCurrentStock(ByVal action As String, ByVal intRow As Short) As Object
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : Key press Action
        ' Return Value  : NIL
        ' Function      : Set the Current Stock of the item into the text box
        ' Datetime      : 13 June 2007
        'Issue ID       : 19992
        '-------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        With spitems
            Select Case action
                Case "CLICK"
                    txtdispatchqty.Text = ""
                    If intRow <> .MaxRows And intRow <> 1 Then
                        .Row = intRow
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    Else
                        .Row = intRow
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    End If
                Case "ENTER"
                    If .ActiveCol = EnumInv.EnumQuantity Then
                        .Row = .ActiveRow
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    End If
                    If .ActiveCol = EnumInv.BinQty Then
                        .Row = .ActiveRow
                        .Col = EnumInv.BinQty
                        If .ActiveRow <> .MaxRows And Val(.Value) > 0 Then
                            .Row = .ActiveRow + 1
                            .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                            Call CalculateInvoceQuantity(.Row, .Col)
                        End If
                    End If
                Case "KEYUP"
                    txtdispatchqty.Text = ""
                    .Row = .ActiveRow
                    If spitems.ActiveRow <> 1 Then
                        .Row = .ActiveRow - 1
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    Else
                        .Row = .ActiveRow
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    End If
                Case "KEYDOWN"
                    txtdispatchqty.Text = ""
                    .Row = .ActiveRow
                    If .ActiveRow <> .MaxRows Then
                        .Row = .ActiveRow + 1
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    Else
                        .Row = .ActiveRow
                        .Col = EnumInv.CurrentStock : txtcurrentstock.Text = Trim(.Text)
                        Call CalculateInvoceQuantity(.Row, .Col)
                    End If
            End Select
        End With
        Exit Function
ErrHandler:
        gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Public Function QuantityCheckMultipleSO() As Boolean
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : Row,Col
        ' Return Value  : NIL
        ' Function      : Check the schedule quantity,current stock and pending quantity for Multiple SO
        ' Datetime      : 15 June 2007
        'Issue ID       : 19992
        '-------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        QuantityCheckMultipleSO = True
        Dim rsMktSchedule As ClsResultSetDB
        Dim rsSaleConf As ClsResultSetDB
        Dim strQuantity As String
        Dim intRwCount As Short 'To Count No. Of Rows
        Dim varItemQty As Object 'To Get Quantity Acc. To Drawing No and Item Code
        Dim varItemCode As Object
        Dim varDrgNo As Object
        Dim VarDelete As Object
        Dim strItembal As String
        Dim intcol As Short
        Dim strInvoiceType As String
        Dim strInvoiceSubType As String
        Dim intFromBox As Double
        Dim varRefNo As Object
        Dim varAmendmentNo As Object
        Dim strScheduleCheck As String
        Dim strGetSchType As String
        'To Check Proper value in Quantity,From/To Box
        mstrUpdDispatchSql = ""
        For intRwCount = 1 To spitems.MaxRows
            VarDelete = Nothing
            Call spitems.GetText(EnumInv.enumDelete, intRwCount, VarDelete)
            '****Delete Flag Check
            
            If UCase(VarDelete) <> "D" Then
                For intcol = 1 To spitems.MaxCols
                    spitems.Col = intcol
                    If (spitems.Col = EnumInv.EnumQuantity) Or (spitems.Col = EnumInv.Rate_PerUnit) Or (spitems.Col = EnumInv.ToBox) Or (spitems.Col = EnumInv.FromBox) Or (spitems.Col = EnumInv.BinQty) Then
                        If (Val(Trim(spitems.Text)) = 0) Then
                            QuantityCheckMultipleSO = False
                            Call ConfirmWindow(10419, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                            spitems.Row = intRwCount : spitems.Col = intcol : spitems.Action = FPSpreadADO.ActionConstants.ActionActiveCell : spitems.Focus()
                            Exit Function
                        End If
                        If (spitems.Col = EnumInv.ToBox) Then
                            spitems.Row = intRwCount : spitems.Col = EnumInv.FromBox : intFromBox = Val(Trim(spitems.Text))
                            spitems.Row = intRwCount : spitems.Col = EnumInv.ToBox
                            'To Check Valid Quantity of From/To Box
                            If Val(Trim(spitems.Text)) < intFromBox Then
                                QuantityCheckMultipleSO = False
                                Call ConfirmWindow(10235, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                                spitems.Row = intRwCount : spitems.Col = EnumInv.ToBox : spitems.Action = FPSpreadADO.ActionConstants.ActionActiveCell : spitems.Focus()
                                Exit Function
                            End If
                        End If
                    End If
                Next intcol
            End If
        Next intRwCount
        '**************************Check for Pending SO Quantity at Item Level*******************
        For intRwCount = 1 To spitems.MaxRows
            varItemCode = Nothing
            Call spitems.GetText(EnumInv.enumItemCode, intRwCount, varItemCode)
            varDrgNo = Nothing
            Call spitems.GetText(EnumInv.CustPartNo, intRwCount, varDrgNo)
            varItemQty = Nothing
            Call spitems.GetText(EnumInv.EnumQuantity, intRwCount, varItemQty)
            VarDelete = Nothing
            Call spitems.GetText(EnumInv.enumDelete, intRwCount, VarDelete)
            varRefNo = Nothing
            Call spitems.GetText(EnumInv.CustRef, intRwCount, varRefNo)
            varAmendmentNo = Nothing
            Call spitems.GetText(EnumInv.AmendmentNo, intRwCount, varAmendmentNo)
            If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                
                If UCase(VarDelete) <> "D" Then
                    
                    txtRefNo.Text = varRefNo
                    
                    txtAmendNo.Text = varAmendmentNo
                    
                    
                    
                    If CheckcustorddtlQty("ADD", CStr(varItemCode), CStr(varDrgNo), CDbl(varItemQty)) = True Then
                        QuantityCheckMultipleSO = True
                    Else
                        QuantityCheckMultipleSO = False
                        spitems.Col = EnumInv.EnumQuantity : spitems.Row = intRwCount : spitems.Focus()
                        Exit Function
                    End If
                End If
            ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                
                If UCase(VarDelete) <> "D" Then
                    
                    txtRefNo.Text = varRefNo
                    
                    txtAmendNo.Text = varAmendmentNo
                    
                    
                    
                    If CheckcustorddtlQty("EDIT", CStr(varItemCode), CStr(varDrgNo), CDbl(varItemQty)) = True Then
                        QuantityCheckMultipleSO = True
                    Else
                        QuantityCheckMultipleSO = False
                        spitems.Col = EnumInv.EnumQuantity : spitems.Row = intRwCount : spitems.Focus()
                        Exit Function
                    End If
                End If
            End If
        Next
        '*****************************************************************************************
        '*********************GET SCHEDULE TYPE TO KNOCKOFF SCHEDULE ON EDIT MODE*****************
        If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
            
            strGetSchType = GetScheduelTypeonEdit()
            If Len(Trim(strGetSchType)) > 0 Then
                If strGetSchType = "Error" Then
                    GoTo ErrHandler
                End If
                QuantityCheckMultipleSO = False
                Exit Function
            End If
        End If
        '****************************************************************************************
        '******************************CHECK OF DAILY AND MONTHLY SCHEDULE***********************
        strScheduleCheck = CheckMktSchedules()
        If Len(Trim(strScheduleCheck)) > 0 Then
            If strScheduleCheck = "Error" Then
                GoTo ErrHandler
            Else
                MsgBox(Space(20) & "Schedule Status:" & vbCrLf & strScheduleCheck, MsgBoxStyle.Information + MsgBoxStyle.OkOnly, ResolveResString(100))
            End If
            QuantityCheckMultipleSO = False
            Exit Function
        End If
        '****************************************************************************************
        '***************************CHECK CURRENT BALANCE FROM ITEMBAL_MST*********************
        Select Case Me.CmdGrpChEnt.Mode
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT, UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW
                rsSaleConf = New ClsResultSetDB
                rsSaleConf.GetResult(" Select Invoice_type,Sub_Category from SalesChallan_Dtl Where  UNIT_CODE = '" & gstrUNITID & "' and Doc_No=" & txtChallanNo.Text)
                
                mstrInvoiceType = rsSaleConf.GetValue("Invoice_Type")
                
                mstrInvSubType = rsSaleConf.GetValue("Sub_Category")
                rsSaleConf.ResultSetClose()
                rsSaleConf = New ClsResultSetDB
                rsSaleConf.GetResult("select Stock_Location From saleconf where  UNIT_CODE = '" & gstrUNITID & "' and invoice_type ='" & Trim(mstrInvoiceType) & "'  and sub_type='" & Trim(mstrInvSubType) & "' AND Location_Code ='" & Trim(txtLocationCode.Text) & "' and (fin_start_date <= getdate() and fin_end_date >= getdate())")
                
                mstrLocationCode = Trim(rsSaleConf.GetValue("Stock_Location"))
                'Select Query To Check Cur_Bal From ItemBal_Mst
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_ADD
                rsSaleConf = New ClsResultSetDB
                rsSaleConf.GetResult("select Stock_Location From saleconf where  UNIT_CODE = '" & gstrUNITID & "' and Description ='" & Trim(CmbInvType.Text) & "' and sub_type_Description ='" & Trim(CmbInvSubType.Text) & "' AND Location_Code ='" & Trim(txtLocationCode.Text) & "' and (fin_start_date <= getdate() and fin_end_date >= getdate())")
        End Select
        
        If Len(Trim(rsSaleConf.GetValue("Stock_Location"))) = 0 Then
            MsgBox("Please Define Stock Location in Sales Conf First", MsgBoxStyle.OkOnly, ResolveResString(100))
            QuantityCheckMultipleSO = False
            rsSaleConf.ResultSetClose()
            Exit Function
        End If
        Dim varItemCodeinVeiw As Object
        For intRwCount = 1 To Me.spitems.MaxRows
            varItemCodeinVeiw = Nothing
            Call spitems.GetText(EnumInv.enumItemCode, intRwCount, varItemCodeinVeiw)
            VarDelete = Nothing
            Call spitems.GetText(EnumInv.enumDelete, intRwCount, VarDelete)
            
            If UCase(VarDelete) <> "D" Then
                strItembal = "Select Cur_Bal From ItemBal_Mst where Location_Code ='" & Trim(rsSaleConf.GetValue("Stock_Location")) & "' and item_Code ='" & varItemCodeinVeiw & "' and UNIT_CODE = '" & gstrUNITID & "'"
                rsMktSchedule = New ClsResultSetDB
                rsMktSchedule.GetResult(strItembal, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                
                strQuantity = CStr(Val(rsMktSchedule.GetValue("Cur_Bal")))
                rsMktSchedule.ResultSetClose()
                Call CalculateInvoceQuantity(intRwCount, (EnumInv.EnumQuantity))
                If Val(txtdispatchqty.Text) > Val(strQuantity) Then
                    QuantityCheckMultipleSO = False
                    If CDbl(strQuantity) = 0 Then
                        
                        MsgBox("No Balance Available for Item (" & varItemCodeinVeiw & ")", MsgBoxStyle.OkOnly, ResolveResString(100))
                    Else
                        
                        MsgBox("Total Dispatch Quantity should not be Greater then Current Balance  at location -" & rsSaleConf.GetValue("Stock_Location") & " [" & strQuantity & "]", MsgBoxStyle.OkOnly, ResolveResString(100))
                    End If
                    With Me.spitems
                        .Row = intRwCount : .Col = EnumInv.EnumQuantity : .Action = FPSpreadADO.ActionConstants.ActionActiveCell : .Focus()
                    End With
                    Exit Function
                Else
                    QuantityCheckMultipleSO = True
                End If
            End If
        Next intRwCount
        rsSaleConf.ResultSetClose()
        
        
        Exit Function
ErrHandler:
        gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CheckMktSchedules() As String
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : NIL
        ' Return Value  : 'Error'  - If error occured during processing
        '                 Msg if Schedule doesn't exist for Item(s)
        ' Function      : To Check Daily and Monthly Schedules
        ' Datetime      : 16 June 2007
        ' Issue ID      : 19992
        '--------------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        Dim Com As ADODB.Command
        Dim strSql As String
        Dim intCtr As Short
        Dim intCount As Short
        Dim strMSG As String
        Dim strYYYYmm As String
        ReDim mSchTypeArr(0)
        CheckMktSchedules = ""
        strYYYYmm = Year(ConvertToDate(lblDateDes.Text)) & VB.Right("0" & Month(ConvertToDate(lblDateDes.Text)), 2)
        Call FillCurrentScheduleQuantityInArray() 'fill the current quantity
        If Me.CmdGrpChEnt.Mode <> UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT And UBound(marrCurQty) > 0 Then
            ReDim marrPrevQty(UBound(marrCurQty))
        End If
        '------------------Subtract previous quantity of Item in Edit Mode-------------------------
        If Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
            For intCtr = 1 To UBound(marrCurQty) Step 1
                For intCount = 1 To UBound(marrPrevQty) Step 1
                    If StrComp(marrCurQty(intCtr).ItemCode, marrPrevQty(intCount).ItemCode, CompareMethod.Text) = 0 And StrComp(marrCurQty(intCtr).CustItemCode, marrPrevQty(intCount).CustItemCode, CompareMethod.Text) = 0 Then
                        marrCurQty(intCtr).CurQuantity = marrCurQty(intCtr).CurQuantity - marrPrevQty(intCount).PrevQuantity
                    End If
                Next
            Next
        End If
        '-------------------------------------------------------------------------------------------
        For intCtr = 1 To UBound(marrCurQty) Step 1
            ReDim Preserve mSchTypeArr(intCtr)
            Com = New ADODB.Command
            Com.CommandType = ADODB.CommandTypeEnum.adCmdStoredProc
            Com.CommandText = "MKT_SCHEDULE_CHECK_NORTH"
            Com.Parameters.Append(Com.CreateParameter("@UnitCode", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInput, 10, gstrUNITID))
            Com.Parameters.Append(Com.CreateParameter("@CUSTOMER_CODE", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInput, 20, Trim(txtCustCode.Text)))
            Com.Parameters.Append(Com.CreateParameter("@ITEM_CODE", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInput, 20, marrCurQty(intCtr).ItemCode))
            Com.Parameters.Append(Com.CreateParameter("@CUSTDRG_NO", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInput, 30, marrCurQty(intCtr).CustItemCode))
            Com.Parameters.Append(Com.CreateParameter("@REQ_QTY", ADODB.DataTypeEnum.adCurrency, ADODB.ParameterDirectionEnum.adParamInput, ADODB.DataTypeEnum.adCurrency, marrCurQty(intCtr).CurQuantity))
            Com.Parameters.Append(Com.CreateParameter("@YYYYMM", ADODB.DataTypeEnum.adInteger, ADODB.ParameterDirectionEnum.adParamInput, ADODB.DataTypeEnum.adInteger, strYYYYmm))
            Com.Parameters.Append(Com.CreateParameter("@DATE", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamInput, ADODB.DataTypeEnum.adVarChar, getDateForDB(Trim(lblDateDes.Text))))
            Com.Parameters.Append(Com.CreateParameter("@SCH_TYPE", ADODB.DataTypeEnum.adChar, ADODB.ParameterDirectionEnum.adParamOutput, 1))
            Com.Parameters.Append(Com.CreateParameter("@MSG", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamOutput, 500))
            Com.Parameters.Append(Com.CreateParameter("@ERR", ADODB.DataTypeEnum.adVarChar, ADODB.ParameterDirectionEnum.adParamOutput, 100))
            Com.let_ActiveConnection(mP_Connection)
            Com.Execute(, , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
            If Len(Com.Parameters(8).Value) > 0 Then
                MsgBox(Com.Parameters(8).Value, MsgBoxStyle.Information + MsgBoxStyle.OkOnly, ResolveResString(100))
                CheckMktSchedules = "Error"
                
                Com = Nothing
                Exit Function
            End If
            If Len(Com.Parameters(7).Value) > 0 Then
                strMSG = strMSG & Com.Parameters(7).Value
            End If
            mSchTypeArr(intCtr) = Com.Parameters(6).Value
            
            Com = Nothing
        Next intCtr
        CheckMktSchedules = strMSG
        Exit Function
ErrHandler:
        
        Com = Nothing
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function UpdateMktSchedules(ByVal pstrUpdType As String) As Boolean
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : '+' - If Despatch is to be Updated agst Schedule
        '                 '-' - If Reversal is to be made agst Despatched Qty
        ' Return Value  : TRUE  - If Successfull
        '                 FALSE - If error Occured during processing
        ' Function      : To Update Daily and Monthly Schedules
        ' Datetime      : 16 JUNE 2007
        '--------------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        Dim Com As ADODB.Command
        Dim strSql As String
        Dim intCtr As Short
        Dim strMSG As String
        Dim strYYYYmm As String
