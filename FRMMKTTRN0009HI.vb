    Private Sub CalculateGSTTaxes(ByVal rowIndex As Integer)
        If Not gblnGSTUnit Then Exit Sub
        Dim dblDiscountAmt As Double = 0
        Dim dblBasicValue As Double = 0
        Dim dblAssessableValue As Double = 0
        Dim dblCGSTPercent As Double = 0
        Dim dblSGSTPercent As Double = 0
        Dim dblIGSTPercent As Double = 0
        Dim dblUTGSTPercent As Double = 0
        Dim dblCCESSPercent As Double = 0
        Dim dblCGSTAmt As Double = 0
        Dim dblSGSTAmt As Double = 0
        Dim dblIGSTAmt As Double = 0
        Dim dblUTGSTAmt As Double = 0
        Dim dblCCESSAmt As Double = 0
        Try
            LoadSalesParameter()
            With SpChEntry
                .Row = rowIndex
                ' dblBasicValue = CalculateBasicValue(rowIndex, CBool(dtSalesParameter.Rows(0)("Basic_Roundoff")), SpChEntry)
                dblBasicValue = CalculateBasicValue(rowIndex, CBool(dtSalesParameter.Rows(0)("Basic_Roundoff")), SpChEntry)
                .Col = EnumInv.Discount_Amt : dblDiscountAmt = Val(.Text)
                dblAssessableValue = CalculateAccessibleValue(rowIndex, Math.Round(Val(ctlInsurance.Text)), CBool(dtSalesParameter.Rows(0)("InsExc_Excise")), SpChEntry) - dblDiscountAmt
                .Col = EnumInv.Basic_Value : .Text = dblBasicValue
                .Col = EnumInv.Accessible_Amt : .Text = dblAssessableValue

                .Col = EnumInv.CGST_Percent : dblCGSTPercent = Val(.Text)
                .Col = EnumInv.SGST_Percent : dblSGSTPercent = Val(.Text)
                .Col = EnumInv.IGST_Percent : dblIGSTPercent = Val(.Text)
                .Col = EnumInv.UTGST_Percent : dblUTGSTPercent = Val(.Text)
                .Col = EnumInv.CSESS_TAX_Percent : dblCCESSPercent = Val(.Text)


                dblCGSTAmt = (dblAssessableValue * dblCGSTPercent) / 100
                dblSGSTAmt = (dblAssessableValue * dblSGSTPercent) / 100
                dblIGSTAmt = (dblAssessableValue * dblIGSTPercent) / 100
                dblUTGSTAmt = (dblAssessableValue * dblUTGSTPercent) / 100
                dblCCESSAmt = (dblAssessableValue * dblCCESSPercent) / 100

                If CBool(dtSalesParameter.Rows(0)("GSTTAX_ROUNDOFF")) Then
                    .Col = EnumInv.CGST_Amt : .Text = dblCGSTAmt
                    .Col = EnumInv.SGST_Amt : .Text = dblSGSTAmt
                    .Col = EnumInv.IGST_Amt : .Text = dblIGSTAmt
                    .Col = EnumInv.UTGST_Amt : .Text = dblUTGSTAmt
                    .Col = EnumInv.CSESS_TAX_VAL : .Text = dblCCESSAmt
                Else
                    dblCGSTAmt = System.Math.Round(dblCGSTAmt, Convert.ToInt32(dtSalesParameter.Rows(0)("GSTTAX_ROUNDOFF_DECIMAL")))
                    dblSGSTAmt = System.Math.Round(dblSGSTAmt, Convert.ToInt32(dtSalesParameter.Rows(0)("GSTTAX_ROUNDOFF_DECIMAL")))
                    dblIGSTAmt = System.Math.Round(dblIGSTAmt, Convert.ToInt32(dtSalesParameter.Rows(0)("GSTTAX_ROUNDOFF_DECIMAL")))
                    dblUTGSTAmt = System.Math.Round(dblUTGSTAmt, Convert.ToInt32(dtSalesParameter.Rows(0)("GSTTAX_ROUNDOFF_DECIMAL")))
                    dblCCESSAmt = System.Math.Round(dblCCESSAmt, Convert.ToInt32(dtSalesParameter.Rows(0)("GSTTAX_ROUNDOFF_DECIMAL")))

                    .Col = EnumInv.CGST_Amt : .Text = dblCGSTAmt
                    .Col = EnumInv.SGST_Amt : .Text = dblSGSTAmt
                    .Col = EnumInv.IGST_Amt : .Text = dblIGSTAmt
                    .Col = EnumInv.UTGST_Amt : .Text = dblUTGSTAmt
                    .Col = EnumInv.CSESS_TAX_VAL : .Text = dblCCESSAmt
                End If

                ' .Row = 0 : .Col = EnumInv.CSESS_TAX_VAL : .Text = "CSESS TAX (Val)" : .set_ColWidth(EnumInv.CSESS_TAX_VAL, 1200)


                .Col = EnumInv.Item_Total : .Text = dblAssessableValue + dblCGSTAmt + dblSGSTAmt + dblIGSTAmt + dblUTGSTAmt + dblCCESSAmt
            End With
        Catch ex As Exception
            RaiseException(ex)
        End Try
    End Sub
