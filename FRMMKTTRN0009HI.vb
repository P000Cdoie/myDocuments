                                        mstrItemCode = frmMKTTRN0021HI.AddDataFromGrinDtl(Trim(txtCustCode.Text), Trim(txtRefNo.Text), rsSaleConf.GetValue("Stock_Location"), SpChEntry.MaxRows, strItemNotIn)
