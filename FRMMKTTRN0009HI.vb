                            If Len(Trim(strStockLocation)) > 0 Then
                                If CBool(UCase(CStr(Trim(CmbInvSubType.Text) = "SCRAP"))) Then
                                    If Len(Trim(strItemNotIn)) > 0 Then
                                        mstrItemCode = frmMKTTRN0021HI.SelectDatafromItem_Mst(Trim(CmbInvType.Text), Trim(CmbInvSubType.Text), strStockLocation, , strItemNotIn, SpChEntry.MaxRows)
                                    Else
                                        mstrItemCode = frmMKTTRN0021HI.SelectDatafromItem_Mst(Trim(CmbInvType.Text), Trim(CmbInvSubType.Text), strStockLocation)
                                    End If
                                Else
                                    'Added for Issue ID 19992 Starts
