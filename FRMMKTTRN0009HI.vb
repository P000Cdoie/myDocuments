    Private Sub spitems_KeyUpEvent(ByVal sender As Object, ByVal e As AxFPSpreadADO._DSpreadEvents_KeyUpEvent) Handles spitems.KeyUpEvent
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : NIL
        ' Return Value  : NIL
        ' Function      : Delete Row on CTRL+D
        ' Datetime      : 15 June 2007
        'Issue ID       : 19992
        '--------------------------------------------------------------------------------------------
        Dim intRow As Short
        Dim intDelete As Short
        Dim intLoopCount As Short
        Dim intMaxLoop As Short
        Dim VarDelete As Object
        If ((e.shift = 2) And (e.keyCode = System.Windows.Forms.Keys.D)) Then
            If CmdGrpChEnt.Mode <> UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW Then
                With spitems
                    If .MaxRows > 1 Then
                        If MsgBox("Sure to delete the " & .ActiveRow & " Row", MsgBoxStyle.Information + MsgBoxStyle.YesNo, ResolveResString(100)) = MsgBoxResult.Yes Then
                            intRow = .ActiveRow : intMaxLoop = spitems.MaxRows
                            For intLoopCount = 1 To intMaxLoop
                                If intLoopCount <> intRow Then
                                    VarDelete = Nothing
                                    Call .GetText(EnumInv.enumDelete, intLoopCount, VarDelete)
                                    
                                    If UCase(VarDelete) = "D" Then
                                        intDelete = intDelete + 1
                                    End If
                                End If
                            Next
                            If (intMaxLoop - intDelete) > 1 Then
                                Call .SetText(EnumInv.enumDelete, intRow, "D")
                                .Row = .ActiveRow : .Row2 = .ActiveRow : .BlockMode = True : .RowHidden = True : .BlockMode = False
                            End If
                        End If
                    End If
                End With
            End If
        End If
    End Sub
    Private Sub spitems_LeaveCell(ByVal sender As Object, ByVal e As AxFPSpreadADO._DSpreadEvents_LeaveCellEvent) Handles spitems.LeaveCell
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : NIL
        ' Return Value  : NIL
        ' Function      : Show Customer Part Description on mouse click
        ' Datetime      : 14 June 2007
        'Issue ID       : 19992
        '--------------------------------------------------------------------------------------------------
        On Error GoTo ErrHandler
        With spitems
            If e.newRow = -1 Then Exit Sub
            If spitems.ActiveCol = EnumInv.EnumQuantity Or spitems.ActiveCol = EnumInv.FromBox Or spitems.ActiveCol = EnumInv.ToBox Then
                Item_Description(e.newRow, spitems)
                Call SetCurrentStock("CLICK", e.newRow)
                If ValidateRowData(.ActiveRow, (EnumInv.EnumQuantity)) Then
                ElseIf mblnsetfocus = False Then
                    e.cancel = True
                    .Row = .ActiveRow
                    .Col = .ActiveCol
                    .Action = FPSpreadADO.ActionConstants.ActionActiveCell
                    .Focus()
                End If
            End If
        End With
        Exit Sub
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection) 'Function called, if error occurred
    End Sub
    Private Sub SpChEntry_Change(ByVal sender As Object, ByVal e As AxFPSpreadADO._DSpreadEvents_ChangeEvent) Handles SpChEntry.Change
        Dim intRowCount As Short
        Dim intmaxrows As Short
        'Dim rsItemMst As ClsResultSetDB
        Dim varFromBox As Object
        Dim varItem As Object
        Dim VarToBox As Object
        Dim varQty As Object
        '''Dim boxqty As Double
        Dim boxqty As Object
        Dim varCumulativeBoxes As Object
        Dim varMaxQty As Object
        Dim varItemRate As Object

        'added by abhijit
        'Dim varItemRate As Double = 0.0
        Dim varQtyRate As Double = 0.0
        Dim varDiscountRate As Double = 0.0
        Dim varDiscountValue As Double = 0.0
        Dim varBaiscValue As Double = 0.0
        Dim varAccessibleValue As Double = 0.0
        Dim varIGSTRate As Double = 0.0
        Dim varIGSTValue As Double = 0.0
        Dim varCGSTRate As Double = 0.0
        Dim varCGSTValue As Double = 0.0
        Dim varSGSTRate As Double = 0.0
        Dim varSGSTValue As Double = 0.0
        Dim varUTGSTRate As Double = 0.0
        Dim varUTGSTValue As Double = 0.0
        Dim varCcessRate As Double = 0.0
        Dim varCcessValue As Double = 0.0
        Dim varItemTotal As Double = 0.0
        'Added by Abhijit


        With SpChEntry
            '            If e.col = EnumInv.EnumQuantity Or e.col = EnumInv.BinQty Then
            If e.col = EnumInv.EnumQuantity Or e.col = EnumInv.Rate_PerUnit Or e.col = EnumInv.BinQty Or e.col = EnumInv.CustSuppMat_perunit Or e.col = EnumInv.ToolCost_PerUnit Then
                If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                    If mblnRejTracking = True And CmbInvType.Text = "REJECTION" Then
                        varQty = Nothing
                        Call SpChEntry.GetText(EnumInv.EnumQuantity, e.row, varQty)
                        varMaxQty = Nothing
                        Call SpChEntry.GetText(EnumInv.MaxPoss_Qty, e.row, varMaxQty)
                        If Len(Trim(txtRefNo.Text)) <> 0 Then
                            If CDbl(varQty) > CDbl(varMaxQty) Then
                                MsgBox("Quantity should not be greater than " & varMaxQty, MsgBoxStyle.Information, ResolveResString(100))
                                Call SpChEntry.SetText(EnumInv.EnumQuantity, e.row, varMaxQty)
                            End If
                        End If
                    End If
                ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                    If mblnRejTracking = True And strInvType = "REJ" Then
                        varQty = Nothing
                        Call SpChEntry.GetText(EnumInv.EnumQuantity, e.row, varQty)
                        varMaxQty = Nothing
                        Call SpChEntry.GetText(EnumInv.MaxPoss_Qty, e.row, varMaxQty)
                        If CDbl(varQty) > CDbl(varMaxQty) Then
                            MsgBox("Quantity should be greater than " & varMaxQty, MsgBoxStyle.Information, ResolveResString(100))
                            Call SpChEntry.SetText(EnumInv.EnumQuantity, e.row, varMaxQty)
                        End If
                    End If
                End If

                Dim strquantity As String
                If CBool(Find_Value("select dbo.UFN_FTS_INVOICE_LABEL('" & gstrUNITID & "','" & txtChallanNo.Text & "')")) Then
                    With SpChEntry
                        intmaxrows = SpChEntry.MaxRows
                        For intRowCount = 1 To intmaxrows
                            varItem = Nothing
                            Call .GetText(EnumInv.enumItemCode, intRowCount, varItem)
                            varQty = Nothing
                            Call .GetText(EnumInv.EnumQuantity, intRowCount, varQty)
                            strquantity = Find_Value("SELECT sales_quantity FROM sales_dtl WHERE UNIT_CODE='" + gstrUNITID + "' and doc_no='" & txtChallanNo.Text.Trim & "' and item_code='" & varItem & "'")
                            If strquantity <> varQty Then
                                MsgBox("Can't Edit Quantity Picking in Progress ..", MsgBoxStyle.Critical, ResolveResString(100))
                                Call .SetText(EnumInv.EnumQuantity, intRowCount, strquantity)
                            End If
                        Next
                    End With
                End If

                With SpChEntry
                    intmaxrows = SpChEntry.MaxRows
                    For intRowCount = 1 To intmaxrows
                        varItem = Nothing
                        Call .GetText(EnumInv.enumItemCode, intRowCount, varItem)
                        varQty = Nothing
                        Call .GetText(EnumInv.EnumQuantity, intRowCount, varQty)
                        If Len(varItem) = 0 Then Exit For

                        varItemRate = Nothing
                        Call .GetText(EnumInv.Rate_PerUnit, intRowCount, varItemRate)


                        'Added by Abhijit
                        If gblnGSTUnit Then

                            CalculateGSTTaxes(intRowCount)
                            'varBaiscValue = varItemRate * varQty
                            'Call .SetText(EnumInv.Basic_Value, intRowCount, varBaiscValue)

                            '.Col = EnumInv.Discount_Percent : varDiscountRate = Val(.Text)
                            'varDiscountValue = varBaiscValue * (varDiscountRate / 100)
                            'Call .SetText(EnumInv.Discount_Amt, intRowCount, varDiscountValue)

                            'varAccessibleValue = varBaiscValue - varDiscountValue
                            'Call .SetText(EnumInv.Accessible_Amt, intRowCount, varAccessibleValue)

                            '.Col = EnumInv.IGST_Percent : varIGSTRate = Val(.Text)
                            'varIGSTValue = varAccessibleValue * (varIGSTRate / 100)
                            'Call .SetText(EnumInv.IGST_Amt, intRowCount, varIGSTValue)

                            '.Col = EnumInv.CGST_Percent : varCGSTRate = Val(.Text)
                            'varCGSTValue = varAccessibleValue * (varCGSTRate / 100)
                            'Call .SetText(EnumInv.CGST_Amt, intRowCount, varCGSTValue)

                            '.Col = EnumInv.SGST_Percent : varSGSTRate = Val(.Text)
                            'varSGSTValue = varAccessibleValue * (varSGSTRate / 100)
                            'Call .SetText(EnumInv.SGST_Amt, intRowCount, varSGSTValue)


                            '.Col = EnumInv.UTGST_Percent : varUTGSTRate = Val(.Text)
                            'varUTGSTValue = varAccessibleValue * (varUTGSTRate / 100)
                            'Call .SetText(EnumInv.UTGST_Amt, intRowCount, varUTGSTValue)

                            '.Col = EnumInv.CSESS_TAX_Percent : varCcessRate = Val(.Text)
                            'varCcessValue = varAccessibleValue * (varCcessRate / 100)
                            'Call .SetText(EnumInv.CSESS_TAX_VAL, intRowCount, varCcessValue)

                            'varItemTotal = 0.0
                            'varItemTotal = varAccessibleValue + varIGSTValue + varCGSTValue + varSGSTValue + varUTGSTValue + varCcessValue
                            'Call .SetText(EnumInv.Item_Total, intRowCount, varItemTotal)
                            'Added by Abhijit
                        End If

                        boxqty = Nothing
                        Call .GetText(EnumInv.BinQty, intRowCount, boxqty)
                        If boxqty > 0 Then
                            If varQty > 0 Then
                                If (varQty / boxqty) - Int(varQty / boxqty) > 0 Then
                                    ''''--------------------------------Code Changed due to increament in grid colums---------------
                                    If intRowCount = 1 Then
                                        Call .SetText(EnumInv.FromBox, intRowCount, 1)
                                        Call .SetText(EnumInv.ToBox, intRowCount, Int(varQty / boxqty) + 1)
                                        '''*****Call .SetText(EnumInv.CumulativeBoxes, intRowCount, ((Int((varQty / boxqty)) + 1) - 1) + 1)
                                        Call .SetText(EnumInv.CumulativeBoxes, intRowCount, Int(varQty / boxqty) + 1)
                                    Else
                                        VarToBox = Nothing
                                        Call .GetText(EnumInv.ToBox, intRowCount - 1, VarToBox)
                                        varCumulativeBoxes = Nothing
                                        Call .GetText(EnumInv.CumulativeBoxes, intRowCount - 1, varCumulativeBoxes)
                                        Call .SetText(EnumInv.FromBox, intRowCount, VarToBox + 1)
                                        Call .SetText(EnumInv.ToBox, intRowCount, VarToBox + Int(varQty / boxqty) + 1)
                                        Call .SetText(EnumInv.CumulativeBoxes, intRowCount, Val(varCumulativeBoxes) + Int(varQty / boxqty) + 1)
                                    End If
                                Else
                                    If intRowCount = 1 Then
                                        Call .SetText(EnumInv.FromBox, intRowCount, 1)
                                        Call .SetText(EnumInv.ToBox, intRowCount, (Int(varQty / boxqty)))
                                        '''*****Call .SetText(EnumInv.CumulativeBoxes, intRowCount, ((Int((varQty / boxqty)) + 1) - 1))
                                        Call .SetText(EnumInv.CumulativeBoxes, intRowCount, Int(varQty / boxqty))
                                    Else
                                        VarToBox = Nothing
                                        Call .GetText(EnumInv.ToBox, intRowCount - 1, VarToBox)
                                        varCumulativeBoxes = Nothing
                                        Call .GetText(EnumInv.CumulativeBoxes, intRowCount - 1, varCumulativeBoxes)
                                        Call .SetText(EnumInv.FromBox, intRowCount, VarToBox + 1)
                                        Call .SetText(EnumInv.ToBox, intRowCount, VarToBox + Int(varQty / boxqty))
                                        '''Call .SetText(EnumInv.CumulativeBoxes, intRowCount, val(varCumulativeBoxes) + ((val(Int(varQty / boxqty) + 1) - val(varFromBox + 1))))
                                        Call .SetText(EnumInv.CumulativeBoxes, intRowCount, Val(varCumulativeBoxes) + Int(System.Math.Round(varQty / boxqty)))
                                    End If

                                End If
                            End If
                        End If

                    Next
                End With
            End If
            If (e.col = EnumInv.FromBox) Or (e.col = EnumInv.ToBox) Then
                intmaxrows = SpChEntry.MaxRows
                For intRowCount = 1 To intmaxrows
                    varFromBox = Nothing
                    Call .GetText(EnumInv.FromBox, intRowCount, varFromBox)
                    VarToBox = Nothing
                    Call .GetText(EnumInv.ToBox, intRowCount, VarToBox)
                    If intRowCount = 1 Then

                        If Len(Trim(varFromBox)) Then

                            If Len(Trim(VarToBox)) Then


                                Call .SetText(EnumInv.CumulativeBoxes, intRowCount, (Val(VarToBox) - Val(varFromBox)) + 1)
                            End If
                        End If
                    Else
                        varCumulativeBoxes = Nothing
                        Call .GetText(EnumInv.CumulativeBoxes, intRowCount - 1, varCumulativeBoxes)
                        If Len(Trim(varCumulativeBoxes)) Then
                            If Len(Trim(varFromBox)) Then
                                If Len(Trim(VarToBox)) Then
                                    Call .SetText(EnumInv.CumulativeBoxes, intRowCount, varCumulativeBoxes + ((Val(VarToBox) - Val(varFromBox)) + 1))
                                End If
                            End If
                        End If
                    End If
                Next
            End If
        End With
    End Sub
