            End If
            '-------------------------------------------
            ' Code Add by Sandeep To Update the Invno in RejInvDetail Table
            If mblnRejTracking = True Then
                mP_Connection.Execute("Update MKT_INVREJ_DTL Set Invoice_No='" & Trim(CStr(mInvNo)) & "' where  UNIT_CODE = '" & gstrUNITID & "' and  Invoice_No='" & Trim(txtChallanNo.Text) & "'", , ADODB.ExecuteOptionEnum.adExecuteNoRecords)
