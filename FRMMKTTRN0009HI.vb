                                    If mstrLocationCode = "" Then
                                        MsgBox("Define FTS Stock Location in Sales configuration", MsgBoxStyle.Information, ResolveResString(100))
                                        Exit Sub
                                    End If

                                End If
                            End If
                            '''Changes for Issue Id:18702 end here.
                        End If
                        rsSaleConf.ResultSetClose()
                        If Len(Trim(mstrItemCode)) = 0 And Len(Trim(strItemNotIn)) = 0 Then
                            SpChEntry.MaxRows = 0
                        Else
                            If Len(Trim(mstrItemCode)) = 0 Then
                                '  mstrItemCode = strItemNotIn
                            End If
                        End If
                    End If
                End If
        End Select
        Dim intDecimalPlace As Short
        Dim strCurrency As String
        If Len(mstrItemCode) > 0 Then
