    Private Sub txtCreditTerms_Validating(ByVal eventSender As System.Object, ByVal eventArgs As System.ComponentModel.CancelEventArgs) Handles txtCreditTerms.Validating
        Dim Cancel As Boolean = eventArgs.Cancel
        '-------------------------------------------------------------------------------------------
        ' Author        : Manoj Kr. Vaish
        ' Arguments     : NIL
        ' Return Value  : NIL
        ' Function      : Validate the user to enter correct Credit term
        ' Datetime      : 14 June 2007
        'Issue ID       : 19992
        '--------------------------------------------------------------------------------------------
        Dim intCtr As Short
        Dim blnflag As Boolean
        blnflag = False
        On Error GoTo ErrHandler
        Select Case Me.CmdGrpChEnt.mode
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_ADD, UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT
                If Len(txtCreditTerms.Text) > 0 Then
                    If Not CheckExistanceOfFieldData(Trim(txtCreditTerms.Text), "crtrm_termID", "Gen_CreditTrmMaster") Then
                        Cancel = True
                        MsgBox("Credit Term doesn't exist.", MsgBoxStyle.Information, ResolveResString(100))
                        txtCreditTerms.Text = ""
                        lblCreditTermDesc.Text = ""
                        txtCreditTerms.Focus()
                    Else
                        For intCtr = 1 To UBound(mItemSODtlArr) Step 1
                            If Trim(txtCreditTerms.Text) = mItemSODtlArr(intCtr).CreditTerm Then
                                blnflag = True
                            End If
                        Next
                        If blnflag = True Then
                            Call SelectDescriptionForField("crTrm_desc", "crtrm_termID", "Gen_CreditTrmMaster", lblCreditTermDesc, (txtCreditTerms.Text))
                        Else
                            MsgBox("Only selected SO Credit term allowed here.", MsgBoxStyle.Information, ResolveResString(100))
                            txtCreditTerms.Text = ""
                            lblCreditTermDesc.Text = ""
                            txtCreditTerms.Focus()
                            Cancel = True
                        End If
                    End If
                End If
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW
                Call SelectDescriptionForField("crTrm_desc", "crtrm_termID", "Gen_CreditTrmMaster", lblCreditTermDesc, (txtCreditTerms.Text))
        End Select
        GoTo EventExitSub
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, err.Source, Err.Description, mp_connection) 'Function called, if error occurred
EventExitSub:
        eventArgs.Cancel = Cancel
    End Sub
    
    Private Sub txtcurrencytype_TextChanged(ByVal eventSender As System.Object, ByVal eventArgs As System.EventArgs) Handles txtcurrencytype.TextChanged
        '*******************************************************************************
        'Author             :   Manoj Kr. Vaish
        'Argument(s)if any  :
        'Return Value       :   NA
        'Function           :   To Fill the exchange rate
        'Comments           :   NA
        'Creation Date      :   30 Aug 2007
        '**********************************************************************
        If Trim(txtcurrencytype.Text) <> "" Then
            If Trim(txtcurrencytype.Text) = Trim(gstrCURRENCYCODE) Then
                lblExchangeRateValue.Text = CStr(1.0#)
            Else
                'changes done by nisha to add service type invoice
                If UCase(Trim(mstrInvoiceType)) = "INV" Or UCase(Trim(mstrInvoiceType)) = "SMP" Or UCase(Trim(mstrInvoiceType)) = "TRF" Or UCase(Trim(mstrInvoiceType)) = "JOB" Or UCase(Trim(mstrInvoiceType)) = "EXP" Or UCase(Trim(mstrInvoiceType)) = "SRC" Then
                    lblExchangeRateValue.Text = (GetExchangeRate(txtcurrencytype.Text, getDateForDB(dtpDateDesc.Value), True))
                Else
                    lblExchangeRateValue.Text = (GetExchangeRate(txtcurrencytype.Text, getDateForDB(dtpDateDesc.Value), False))
                End If
                If Val(Trim(lblExchangeRateValue.Text)) = 1 Then
                    MsgBox("Exchange Rate for " & Trim(txtcurrencytype.Text) & " is not defined on " & dtpDateDesc.Value, MsgBoxStyle.Information, ResolveResString(100))
                    lblExchangeRateValue.Text = ""
                End If
            End If
        Else
            lblExchangeRateValue.Text = ""
        End If
    End Sub
