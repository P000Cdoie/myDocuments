                If strInvType <> "REJ" Then
                    GoTo Complete_Validation
                End If
            End If
            With SpChEntry
                For Intcounter = 1 To .MaxRows
                    strCompile = Nothing
                    .GetText(EnumInv.Doc_Detail, Intcounter, strCompile)
                    dblqty = Nothing
                    .GetText(EnumInv.EnumQuantity, Intcounter, dblqty)
                    ItemCode = Nothing
                    .GetText(EnumInv.enumItemCode, Intcounter, ItemCode)
                    
                    dblBatchQty = CalculateDocumentQty(CStr(strCompile))
                    
                    If Val(dblqty) <> Val(dblBatchQty) Then
                        
                        lstrControls = lstrControls & vbCrLf & lNo & " Rejection Document Quantity is Not Equal To Issue Quantity For Item Code :- " & ItemCode
