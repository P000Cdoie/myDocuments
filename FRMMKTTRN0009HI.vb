                            lstrControls = lstrControls & vbCrLf & lNo & ". Service Tax."
                            lNo = lNo + 1
                            If lctrFocus Is Nothing Then
                                lctrFocus = Me.txtServiceTaxType
                            End If
                            ValidatebeforeSave = False
                        End If
                    End If
                    If Len(Trim(txtECESSOnServiceTaxType.Text)) > 0 And Len(Trim(txtServiceTaxType.Text)) > 0 Then
                        If Trim(txtSECESSOnServiceTaxType.Text) = "" Then
