    Public Function CHECK_AUTOINVOICE() As Boolean
        '----------------------------------------------------
        'Created By     -  Prashant Rajpal
        'Created Date   -  06 DEC 2012 
        'Description    -  TO CHECK WHETHER THE INVOICE IS FROM AUTO DESPATCH ADVICE OR MANUAL INVOICE
        '----------------------------------------------------
        On Error GoTo ErrHandler

        Dim strsql As String
        Dim oRs As ADODB.Recordset

        CHECK_AUTOINVOICE = False

        'Added By ekta uniyal on 6 Mar 2014
        strsql = " Select Top 1 1" & _
                 " From Advice_Invoice_KnockOff  " & _
                 " Where Unit_Code='" & gstrUNITID & "' And invoice_no =" & txtChallanNo.Text.Trim
        'End Here

        oRs = mP_Connection.Execute(strsql)

        If (oRs.BOF And oRs.EOF) Then
            CHECK_AUTOINVOICE = False
