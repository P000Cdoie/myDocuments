                                Call .SetText(EnumInv.Item_Total, intLoopCounter, rsSalesDtl.GetValue("ITEM_VALUE"))

                            End If
                            'Abhijit()


                            'Changed for Issue ID eMpro-20090506-31083 Starts-Check for batch Track
                            If mblnRejTracking = True And mblnBatchTracking = True Then

                                strCompileString = GetDocumentDetail(rsSalesDtl.GetValue("Item_Code"))
                                Call .SetText(EnumInv.Doc_Detail, intLoopCounter, strCompileString)
