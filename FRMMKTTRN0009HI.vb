    Function CheckforCustSupplyMaterial(ByRef blnUpdateStock As Boolean) As Boolean
        On Error GoTo ErrHandler
        Dim objCust As New cls_JWkInv_Reconcile
        Dim strItemCodes As String
        Dim strQuanity As String
        Dim varItemCode As Object
        Dim varQuanity As Object
        Dim intRow As Short
        For intRow = 1 To SpChEntry.MaxRows
            varItemCode = Nothing
            SpChEntry.GetText(EnumInv.enumItemCode, intRow, varItemCode)
            varQuanity = Nothing
            SpChEntry.GetText(EnumInv.EnumQuantity, intRow, varQuanity)
            If Len(Trim(strItemCodes)) = 0 Then
                
                strItemCodes = varItemCode
                
                strQuanity = varQuanity
            Else
                
                strItemCodes = strItemCodes & "," & varItemCode
                
                strQuanity = strQuanity & "," & varQuanity
            End If
        Next
        objCust.ConnectionString = gstrCONNECTIONSTRING
        objCust.OpenConnection()
        If Len(Trim(strItemCodes)) = 0 Then
            CheckforCustSupplyMaterial = False
            MsgBox("No Item found.", MsgBoxStyle.Information, ResolveResString(100))
            Exit Function
        End If
        If objCust.IsStockExist_Items(strItemCodes, strQuanity, Trim(txtCustCode.Text), Trim(lblRGPDes.Text)) = False Then
            'If objCust.IsStockExist_Items("FG00000001", "100000", "C0000002", "") = False Then
            CheckforCustSupplyMaterial = False
        Else
            CheckforCustSupplyMaterial = True
            If blnUpdateStock = True Then
                objCust.Invoice_No = CStr(mInvNo)
                
                objCust.Invoice_Date = dtpDateDesc.Text
                objCust.Invoice_Type = "o"
                objCust.UserId = mP_User
                If objCust.Update_Customer_Stocks = True Then
                    CheckforCustSupplyMaterial = True
                Else
                    CheckforCustSupplyMaterial = False
                End If
            End If
        End If
        Exit Function
ErrHandler:
        gobjError.RaiseError(Err.Number, err.Source, Err.Description, mp_connection)
    End Function
    Private Sub Item_Description(ByVal varRow As Short, ByRef grid As AxFPSpreadADO.AxfpSpread)
        '----------------------------------------------------------------------------------
        'Created By     -   Ashutosh Verma
        'Description    -   To show item description that is selected in grid.
        'Created On     -   31-08-2005
        'Arguments      -   Current Row Number
        'Revised By     -   Manoj Kr. Vaish Issue ID 19992
        '----------------------------------------------------------------------------------
        Dim bFlag As Object
        Dim bflag1 As Boolean
        Dim varCustPartCode, varItemCode As Object
        Dim Rs As New ClsResultSetDB
        Dim m_strSql As String
        Dim rsMktSchedule As New ClsResultSetDB
        Dim strItembal As String
        Dim strcurbal As String
        lblCustPartDesc.Text = ""
        If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Or CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Or CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW Then
            With grid
