                    '''Optional Posting for Rej invoice should be flag base.
                    If RejInvOptionalPostingFlag() = True Then
                        'Commented by Manoj Kr Vaish on 7 July 2007 because it is posting in accounts without confirmation from user Starts
                        'strRetVal = objDrCr.SetAPDocument(mstrMasterString, mstrDetailString, optInsert, gstrCONNECTIONSTRING)
                        'Commented by Manoj Kr Vaish because it is posting in accounts without confirmation from user Ends
                        'changes done by nisha for Rejection Accounts Posting
                        If MsgBox("No Effects in Accounts.", MsgBoxStyle.YesNo + MsgBoxStyle.Information, ResolveResString(100)) = MsgBoxResult.Yes Then
