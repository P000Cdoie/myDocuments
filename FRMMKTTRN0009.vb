                If mblnDiscountFunctionality = True And mblnDiscount_invoicewise = True Then
                    .Col = EnumInv.Discount_type : .CellType = FPSpreadADO.CellTypeConstants.CellTypeComboBox : .TypeHAlign = FPSpreadADO.TypeHAlignConstants.TypeHAlignLeft : .TypeVAlign = FPSpreadADO.TypeVAlignConstants.TypeVAlignCenter
