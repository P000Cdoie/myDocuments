                .Col = EnumInv.enumDelete : .CellType = FPSpreadADO.CellTypeConstants.CellTypeEdit
                .Col = EnumInv.ToolCost_PerUnit : .CellType = FPSpreadADO.CellTypeConstants.CellTypeFloat : .TypeFloatDecimalPlaces = pintDecimalSize : .TypeFloatMin = CDbl(strMin) : .TypeFloatMax = CDbl(strMax)
                .Col = EnumInv.BinQty : .CellType = FPSpreadADO.CellTypeConstants.CellTypeFloat : .TypeFloatDecimalPlaces = 2 : .TypeFloatMin = CDbl("0.00") : .TypeFloatMax = CDbl("99999999999999.99")

                .CtlEditMode = True : .Enabled = True
                If mblnRejTracking = False Then
                    If mblnBatchTrack = True And UCase(CmbInvType.Text) <> "JOBWORK INVOICE" And UCase(CmbInvType.Text) <> "REJECTION" Then
                        If mblnServiceInvoiceWithoutSO Then
                            .Col = EnumInv.BatchCol : .ColHidden = True
