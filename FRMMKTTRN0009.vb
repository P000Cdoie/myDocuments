        Dim intLoopCount As Short
        Dim varItemQty As Object
        Dim varItemCode As Object
        Dim varDrgNo As Object
        Dim VarDelete As Object
        Dim varToolCost As Object
        Dim strItembal As String
        Dim PresQty As Object
        Dim intcol As Short
        Dim strInvoiceType As String
        Dim strInvoiceSubType As String
        Dim irowcount As Short
        Dim intRwCount1 As Short
        Dim strToolCode As String
        Dim varItemQty1 As Object
        Dim intFromBox As Double
        Dim strScheduleCheckMsg As String
        Dim strGetSchTypeMsg As String
        mstrUpdDispatchSql = ""
        For intRwCount = 1 To SpChEntry.MaxRows
            VarDelete = Nothing
            Call SpChEntry.GetText(EnumInv.enumDelete, intRwCount, VarDelete)
            If UCase(VarDelete) <> "D" Then
                For intcol = 1 To SpChEntry.MaxCols
                    SpChEntry.Col = intcol
                    'issue id 10607523
                    If mblnAllowedZeroBinQuantity = False Then
                        If (SpChEntry.Col = EnumInv.EnumQuantity) Or (SpChEntry.Col = EnumInv.Rate_PerUnit) Or (SpChEntry.Col = EnumInv.ToBox) Or (SpChEntry.Col = EnumInv.FromBox) Then ''Column Changed By Tapan
                            SpChEntry.Row = intRwCount
                            If (Val(Trim(SpChEntry.Text)) = 0) Then
                                QuantityCheck = True
                                Call ConfirmWindow(10419, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                                SpChEntry.Row = intRwCount : SpChEntry.Col = intcol : SpChEntry.Action = 0 : SpChEntry.Focus()
                                Exit Function
                            End If
                            If (SpChEntry.Col = EnumInv.ToBox) Then
                                SpChEntry.Row = intRwCount : SpChEntry.Col = EnumInv.FromBox : intFromBox = Val(Trim(SpChEntry.Text))
                                SpChEntry.Row = intRwCount : SpChEntry.Col = EnumInv.ToBox
                                'To Check Valid Quantity of From/To Box
                                If Val(Trim(SpChEntry.Text)) < intFromBox Then
                                    QuantityCheck = True
                                    Call ConfirmWindow(10235, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                                    SpChEntry.Row = intRwCount : SpChEntry.Col = EnumInv.ToBox : SpChEntry.Action = 0 : SpChEntry.Focus()
                                    Exit Function
                                End If
                            End If
                            'issue id 10607523
                        End If
                    Else
                        If (SpChEntry.Col = EnumInv.EnumQuantity) Or (SpChEntry.Col = EnumInv.Rate_PerUnit) Then
                            SpChEntry.Row = intRwCount
                            If (Val(Trim(SpChEntry.Text)) = 0) Then
                                QuantityCheck = True
                                Call ConfirmWindow(10419, eMPowerFunctions.ConfirmWindowButtonsEnum.BUTTON_OK)
                                SpChEntry.Row = intRwCount : SpChEntry.Col = intcol : SpChEntry.Action = 0 : SpChEntry.Focus()
                                Exit Function
                            End If
                        End If
                    End If
                Next intcol
            End If
        Next intRwCount
        If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
            strInvoiceType = UCase(Trim(CmbInvType.Text))
            strInvoiceSubType = UCase(Trim(CmbInvSubType.Text))
        ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
            rsChallanEntry = New ClsResultSetDB
            rsChallanEntry.GetResult("Select a.Description,a.Sub_Type_Description from SaleConf a,SalesChallan_Dtl b where A.UNIT_CODE=B.UNIT_CODE AND A.UNIT_CODE='" + gstrUNITID + "' AND  Doc_No = " & txtChallanNo.Text & " and a.Invoice_Type = b.Invoice_type and a.Sub_type = b.Sub_Category and a.Location_code = b.Location_code and (fin_start_date <= getdate() and fin_end_date >= getdate())")
            strInvoiceType = UCase(rsChallanEntry.GetValue("Description"))
            strInvoiceSubType = UCase(rsChallanEntry.GetValue("sub_type_Description"))
            rsChallanEntry.ResultSetClose()
        End If
        Dim strMakeDate As String
        'If ((UCase(Trim(strInvoiceType)) = "NORMAL INVOICE") And (UCase(CStr((Trim(strInvoiceSubType)) = "FINISHED GOODS")) Or (UCase(Trim(strInvoiceSubType)) = "TRADING GOODS"))) Or (UCase(Trim(strInvoiceType)) = "JOBWORK INVOICE") Or (UCase(Trim(strInvoiceType)) = "EXPORT INVOICE") Or (UCase(Trim(strInvoiceType)) = "SERVICE INVOICE") Or ((UCase(Trim(strInvoiceType)) = "TRANSFER INVOICE") And mblnSORequired = True) Then
        If ((UCase(Trim(strInvoiceType)) = "NORMAL INVOICE") And (UCase(CStr((Trim(strInvoiceSubType)) = "FINISHED GOODS")) Or (UCase(Trim(strInvoiceSubType)) = "TRADING GOODS"))) Or (UCase(Trim(strInvoiceType)) = "JOBWORK INVOICE") Or (UCase(Trim(strInvoiceType)) = "EXPORT INVOICE") Or (UCase(Trim(strInvoiceType)) = "SERVICE INVOICE") Or ((UCase(Trim(strInvoiceType)) = "TRANSFER INVOICE") And mblnSORequired = True) Or ((UCase(Trim(strInvoiceType)) = "INTER-DIVISION") And mblnSORequired = True) Then
            For intRwCount = 1 To SpChEntry.MaxRows
                varItemCode = Nothing
                Call SpChEntry.GetText(EnumInv.enumItemCode, intRwCount, varItemCode)
                varDrgNo = Nothing
                Call SpChEntry.GetText(EnumInv.CustPartNo, intRwCount, varDrgNo)
                varItemQty = Nothing
                Call SpChEntry.GetText(EnumInv.EnumQuantity, intRwCount, varItemQty)
                VarDelete = Nothing
                Call SpChEntry.GetText(EnumInv.enumDelete, intRwCount, VarDelete)
                If UCase(VarDelete) <> "D" Then
                    If CheckMeasurmentUnit(varItemCode, varItemQty, intRwCount, True) = False Then
                        QuantityCheck = True
                        Exit Function
                    End If
                End If
                If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                    If UCase(VarDelete) <> "D" Then
                        If CheckcustorddtlQty("ADD", CStr(varItemCode), CStr(varDrgNo), CDbl(varItemQty)) = True Then
                            QuantityCheck = False
                        Else
                            QuantityCheck = True
                            SpChEntry.Col = EnumInv.EnumQuantity : SpChEntry.Row = intRwCount : SpChEntry.Focus()
                            Exit Function
                        End If
                    End If
                ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                    If CheckcustorddtlQty("EDIT", CStr(varItemCode), CStr(varDrgNo), CDbl(varItemQty)) = True Then
                        QuantityCheck = False
                    Else
                        QuantityCheck = True
                        SpChEntry.Col = EnumInv.EnumQuantity : SpChEntry.Row = intRwCount : SpChEntry.Focus()
                        Exit Function
                    End If
                End If
            Next
            'GET SCHEDULE TYPE TO KNOCKOFF SCHEDULE ON EDIT MODE
            If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                strGetSchTypeMsg = FillSchedueleTypeonEditMode()
                If Len(Trim(strGetSchTypeMsg)) > 0 Then
                    If strGetSchTypeMsg = "Error" Then
                        GoTo ErrHandler
                    End If
                    QuantityCheck = True
                    Exit Function
                End If
            End If
            'CHECK OF DAILY AND MONTHLY SCHEDULE
            'changes done against issue ID 10776605 by Abhinav
            If CmbInvType.Text <> "SERVICE INVOICE" Then
                strScheduleCheckMsg = CheckforSchedules()
                If Len(Trim(strScheduleCheckMsg)) > 0 Then
                    If strScheduleCheckMsg = "Error" Then
                        GoTo ErrHandler
                    Else
                        MsgBox(Space(20) & "Schedule Status:" & vbCrLf & strScheduleCheckMsg, vbInformation + vbOKOnly, ResolveResString(100))
                    End If
                    QuantityCheck = True
                    Exit Function
                End If
            End If
        End If
        'exterminates here(10776605)
        For intRwCount = 1 To SpChEntry.MaxRows
            varItemCode = Nothing
            Call SpChEntry.GetText(EnumInv.enumItemCode, intRwCount, varItemCode)
            varDrgNo = Nothing
            Call SpChEntry.GetText(EnumInv.CustPartNo, intRwCount, varDrgNo)
            varItemQty = Nothing
            Call SpChEntry.GetText(EnumInv.EnumQuantity, intRwCount, varItemQty)
            VarDelete = Nothing
