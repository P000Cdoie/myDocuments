                        If Len(lstrReturnVal) = 0 Then
                            .Text = ""
                            MsgBox("Invalid Tax Code", MsgBoxStyle.Critical, ResolveResString(100))
                        End If
                    End If
                ElseIf e.col = 7 Then
                    .Col = EnumInv.Excise
                    .Row = .ActiveRow
                    If Trim(.Text) <> "" Then
                        strWhereClause = " WHERE UNIT_CODE='" + gstrUNITID + "'  and ((isnull(deactive_flag,0) <> 1) OR (CAST(getdate() AS DATE) <= deactive_date)) AND  TxRt_Rate_No='" & Trim(.Text) & "' AND Tx_TaxeID='EXC'"
                        lstrReturnVal = SelectDataFromTable("TxRt_Rate_No", "Gen_TaxRate", strWhereClause)
