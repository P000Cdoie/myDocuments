        strSalesconf = "Select UpdatePO_Flag,UpdateStock_Flag,Stock_Location,OpenningBal, report_filename, Single_Series ,Preprinted_Flag,NoCopies from saleconf WHERE UNIT_CODE='" + gstrUNITID + "' AND  "
