LAN,ISCONSOLIDATE,Tot_Add_Excise_Amt,Tot_Add_Excise_PER,CONSIGNEE_CODE,Lorry_No,OTL_No,RefChallan,price_bases,LorryNo_date,dataposted_fin,ConsInvString,bond17OpeningBal,barCodeImage,invoicepicking_status,Ecess_TotalDuty_Type,Ecess_TotalDuty_Per,Ecess_TotalDuty_Amount,SEcess_TotalDuty_Type,SEcess_TotalDuty_Per,SEcess_TotalDuty_Amount,ADDVAT_Type,ADDVAT_Per,ADDVAT_Amount from Saleschallan_Dtl WHERE UNIT_CODE='" + gstrUNITID + "' AND  Doc_No =" & txtChallanNo.Text & "  and Location_Code='" & Trim(txtLocationCode.Text) & "'"
