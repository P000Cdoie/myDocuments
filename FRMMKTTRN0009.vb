    Function MakeSQLStatement_FormDetail() As String
        On Error GoTo ErrHandler
        Dim strSql As String
        Dim arrMain() As String
        Dim arrDet() As String
        Dim intOuterCount As Short
        If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
            strSql = "Delete From Forms_DTL WHERE UNIT_CODE='" + gstrUNITID + "' AND  Doc_Type='9999' and PO_NO='" & Trim(txtChallanNo.Text) & "'" & vbCrLf
        Else
            strSql = ""
        End If
        If Len(InvoiceFormDetails) > 0 Then
            arrMain = Split(InvoiceFormDetails, "^")
            For intOuterCount = 0 To UBound(arrMain) - 1
                arrDet = Split(arrMain(intOuterCount), "|")
                strSql = strSql & vbCrLf & "Insert Into Forms_DTL (Doc_Type, PO_No, Serial_No, Form_Type, Form_No,UNIT_CODE)" & " Values ('9999', " & txtChallanNo.Text & ", " & intOuterCount & ",'" & Trim(arrDet(0)) & "', '" & Trim(arrDet(1)) & "','" + gstrUNITID + "') "
            Next
        End If
        MakeSQLStatement_FormDetail = strSql
        Exit Function
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection) 'Function called, if error occurred
    End Function
