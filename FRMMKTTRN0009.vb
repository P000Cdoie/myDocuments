    Private Function CalculateBasicValue(ByVal pintRowNo As Short, ByVal blnRoundoff As Boolean, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        Dim ldblPkg_Per As Double
        Dim ldblRate As Double
        Dim lintQty As Double
        Dim intBasicRoundOffDecimal As Short
        On Error GoTo ErrHandler
        With grid

            .Row = pintRowNo

            .Col = EnumInv.Rate_PerUnit
            ldblRate = Val(.Text) / Val(ctlPerValue.Text)

            .Col = EnumInv.Packing
            ldblPkg_Per = Val(.Text)

            .Col = EnumInv.EnumQuantity
            lintQty = Val(.Text)

            .Col = EnumInv.CustSuppMat_perunit
            intBasicRoundOffDecimal = Val(Find_Value("select basic_roundoff_decimal from sales_parameter WHERE UNIT_CODE='" + gstrUNITID + "'"))
            If blnRoundoff = True Then
                CalculateBasicValue = System.Math.Round(ldblRate * lintQty)
            Else
                CalculateBasicValue = System.Math.Round(ldblRate * lintQty, intBasicRoundOffDecimal)
            End If
        End With
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateAccessibleValue(ByVal pintRowNo As Short, ByVal pdblInsurenceValue As Double, ByVal pblnISInsAdd As Boolean, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        Dim ldblRate As Double
        Dim ldblCustMat As Double
        Dim ldblToolCost As Double
        Dim ldblPkg_Per As Double
        Dim lintQty As Double
        Dim RSAccessibleVal As ClsResultSetDB
        Dim strSql As String
        Dim dblMRP As Double
        Dim dblAbatment As Double
        Dim strdiscounttype As String
        Dim ldbldiscountvalue As Double
        Dim strmarkuptype As String
        Dim ldblmarkupvalue As Double


        On Error GoTo ErrHandler
        With grid

            .Row = pintRowNo

            .Col = EnumInv.Rate_PerUnit
            ldblRate = Val(.Text) / Val(ctlPerValue.Text)

            .Col = EnumInv.Packing
            ldblPkg_Per = Val(.Text)

            .Col = EnumInv.EnumQuantity
            lintQty = Val(.Text)

            .Col = EnumInv.CustSuppMat_perunit
            ldblCustMat = Val(.Text) / Val(ctlPerValue.Text)
            If UCase(mstrInvoiceType) = "SMP" Or UCase(mstrInvoiceType) = "TRF" Then
                .Col = EnumInv.ToolCost_PerUnit
                ldblToolCost = Val(.Text) / Val(ctlPerValue.Text)
            Else
                .Col = EnumInv.ToolCost
                ldblToolCost = Val(.Text) / Val(ctlPerValue.Text)
            End If
            .Col = EnumInv.Discount_type
            strdiscounttype = .Text

            .Col = EnumInv.Discount_Value
            ldbldiscountvalue = Val(.Text) / Val(ctlPerValue.Text)

            .Col = EnumInv.MarkUptype
            strmarkuptype = .Text

            .Col = EnumInv.MarkUpvalue

            ldblmarkupvalue = Val(.Text) / Val(ctlPerValue.Text)

            If CheckSOType(pintRowNo) = "M" Then
                RSAccessibleVal = New ClsResultSetDB
                strSql = "select  isnull(AccessibleRateforMRP,0) as MRPValue from Cust_Ord_Dtl COH WHERE UNIT_CODE='" + gstrUNITID + "' AND  Account_code = '" & Trim(txtCustCode.Text) & "' and Cust_Ref='" & Trim(txtRefNo.Text) & "'"
                strSql = strSql & " and COH.Amendment_No='" & Trim(txtAmendNo.Text) & "'"

                .Col = EnumInv.enumItemCode
                strSql = strSql & " and COH.Item_Code = '" & .Text & "'"

                .Col = EnumInv.CustPartNo
                strSql = strSql & " and COH.Cust_Drgno = '" & .Text & "'"
                RSAccessibleVal.GetResult(strSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If RSAccessibleVal.GetNoRows > 0 Then
                    dblMRP = RSAccessibleVal.GetValue("MRPValue")
                    CalculateAccessibleValue = System.Math.Round((dblMRP * lintQty) - ((dblMRP * lintQty) * dblAbatment / 100), 2)
                End If
                RSAccessibleVal.ResultSetClose()
            Else
                If pblnISInsAdd = True Then
                    If mblnCSM_Knockingoff_req = True Then
                        CalculateAccessibleValue = System.Math.Round((ldblRate + ldblToolCost + pdblInsurenceValue + ldblPkg_Per) * lintQty, 2) + ldblCustMat
                    Else
                        CalculateAccessibleValue = System.Math.Round(((ldblRate + ldblCustMat + ldblToolCost) * lintQty) + pdblInsurenceValue, 2)
                    End If
                Else
                    If mblnCSM_Knockingoff_req = True Then
                        CalculateAccessibleValue = System.Math.Round((ldblRate + ldblToolCost + ldblPkg_Per) * lintQty, 2) + ldblCustMat
                    Else
                        CalculateAccessibleValue = System.Math.Round((ldblRate + ldblCustMat + ldblToolCost) * lintQty, 2)
                    End If

                End If
            End If

            If mblnDiscountFunctionality = True And mblnDiscount_invoicewise = True Then
                If strdiscounttype = "[V]alue" Then
                    TOTALDISCOUNT_ITEMWISE = TOTALDISCOUNT_ITEMWISE + (ldbldiscountvalue * lintQty)
                    ldbltotaldiscount = ldbldiscountvalue * lintQty
                    CalculateAccessibleValue = CalculateAccessibleValue - (ldbldiscountvalue * lintQty)
                ElseIf strdiscounttype = "[P]ercentage" Then
                    ldbltotaldiscount = System.Math.Round((lintQty * ldblRate) * ldbldiscountvalue / 100, 4)
                    TOTALDISCOUNT_ITEMWISE = TOTALDISCOUNT_ITEMWISE + ldbltotaldiscount
                    CalculateAccessibleValue = CalculateAccessibleValue - ((lintQty * ldblRate) * ldbldiscountvalue / 100)
                Else
                    ldbltotaldiscount = 0
                End If
            End If

            If mblnMarkupFunctionality = True And mblnMarkup_invoicewise = True Then
                If strmarkuptype = "[V]alue" Then
                    CalculateAccessibleValue = CalculateAccessibleValue + (ldblmarkupvalue * lintQty)
                ElseIf strmarkuptype = "[P]ercentage" Then
                    CalculateAccessibleValue = CalculateAccessibleValue + (CalculateAccessibleValue * ldblmarkupvalue / 100)
                End If
            End If

        End With
        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateExciseValue(ByVal pintRowNo As Short, ByVal pdblAccessibleValue As Double, ByVal penumTaxType As enumExciseType, ByRef pblnEOU_FLAG As Boolean, ByRef blnExciseFlag As Boolean, ByRef pdblLoadingCharges As Double, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        Dim strTableSql As String 'Declared To Make Select Query
        Dim rsGetTaxRate As ClsResultSetDB
        Dim ldblTaxRate As Double
        Dim ldblCVDRate As Double
        Dim ldblSADRate As Double
        Dim ldblTempTotalExcise As Double
        Dim ldblTempTotalCVD As Double
        Dim ldblTempTotalSAD As Double
        Dim ldblTempAllExcise As Double
        Dim ldblTempEcssOnCVD As Double
        Dim ldblSTempEcssOnCVD As Double
        On Error GoTo ErrHandler
        ldblTempTotalExcise = 0
        ldblTempTotalCVD = 0
        ldblTempTotalSAD = 0
        ldblTempAllExcise = 0
        ldblTempEcssOnCVD = 0
        ldblSTempEcssOnCVD = 0
        Dim strCompCode As String
        Dim strInvoiceType As String
        Dim strsql As String

        If gblnGSTUnit And blnEOU_FLAG Then
            CalculateExciseValue = 0
            Exit Function
        End If

        With grid

            .Row = pintRowNo
            .Col = EnumInv.Excise
            rsGetTaxRate = New ClsResultSetDB
            strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
            rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            If rsGetTaxRate.GetNoRows > 0 Then
                ldblTaxRate = rsGetTaxRate.GetValue("TxRt_Percentage")
            Else
                ldblTaxRate = 0
            End If
            rsGetTaxRate.ResultSetClose()
            If pblnEOU_FLAG Then
                .Col = EnumInv.CVD
                strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    ldblCVDRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                Else
                    ldblCVDRate = 0
                End If
                rsGetTaxRate.ResultSetClose()
                .Col = EnumInv.SAD
                strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    ldblSADRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                Else
                    ldblSADRate = 0
                End If
                rsGetTaxRate.ResultSetClose()
                ldblTempTotalExcise = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                strCompCode = "select plant_name from ProductionConf WHERE UNIT_CODE='" + gstrUNITID + "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strCompCode, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then

                    If rsGetTaxRate.GetValue("Plant_name") = "MSSLED" Then
                        rsGetTaxRate.ResultSetClose()
                        If Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                            strInvoiceType = "Select Invoice_Type,Sub_Category from Saleschallan_Dtl WHERE UNIT_CODE='" + gstrUNITID + "' AND  doc_no='" & Trim(txtChallanNo.Text) & "' "
                            rsGetTaxRate = New ClsResultSetDB
                            rsGetTaxRate.GetResult(strInvoiceType, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)

                            If UCase(Trim(rsGetTaxRate.GetValue("Invoice_Type"))) = "INV" And UCase(Trim(rsGetTaxRate.GetValue("sub_Category"))) = "L" Then
                                ldblTempTotalExcise = (ldblTempTotalExcise * 25) / 100
                            End If
                            rsGetTaxRate.ResultSetClose()
                        ElseIf Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                            If UCase(Trim(CmbInvType.Text)) = "NORMAL INVOICE" And UCase(Trim(CmbInvSubType.Text)) = "SCRAP" Then
                                ldblTempTotalExcise = (ldblTempTotalExcise * 25) / 100
                            End If
                        End If
                    Else
                        rsGetTaxRate.ResultSetClose()
                    End If
                Else
                    rsGetTaxRate.ResultSetClose()
                End If
                If blnExciseFlag = True Then
                    ldblTempTotalExcise = System.Math.Round(ldblTempTotalExcise, 0)
                End If
                ldblTempAllExcise = ldblTempTotalExcise * (Val(Me.txtEouExcisePer.Text) / 100)
                ldblTempTotalCVD = (((ldblTempTotalExcise + (pdblAccessibleValue + pdblLoadingCharges)) * ldblCVDRate) / 100)
                If blnExciseFlag = True Then
                    ldblTempTotalCVD = System.Math.Round(ldblTempTotalCVD, 0)
                End If
                ldblTempAllExcise = ldblTempAllExcise + (ldblTempTotalCVD * (Val(Me.txtEouExcisePer.Text) / 100))
                ldblTempTotalSAD = (((ldblTempTotalCVD + ldblTempTotalExcise + (pdblAccessibleValue + pdblLoadingCharges)) * ldblSADRate) / 100)
                If blnExciseFlag = True Then
                    ldblTempTotalSAD = System.Math.Round(ldblTempTotalSAD, 0)
                End If
                ldblTempEcssOnCVD = (ldblTempTotalCVD * Val(Me.lblEcessCVDPer.Text)) / 100
                ldblSTempEcssOnCVD = (ldblTempTotalCVD * Val(Me.lblSEcessCVDPer.Text)) / 100
                If blnExciseFlag = True Then
                    ldblTempEcssOnCVD = System.Math.Round(ldblTempEcssOnCVD, 0)
                    ldblSTempEcssOnCVD = System.Math.Round(ldblSTempEcssOnCVD, 0)
                End If
                ldblTempAllExcise = ldblTempAllExcise + (ldblTempTotalSAD * (Val(Me.txtEouExcisePer.Text) / 100))
                If blnExciseFlag = True Then
                    ldblTempAllExcise = System.Math.Round(ldblTempAllExcise, 0)
                End If
                If penumTaxType = enumExciseType.RETURN_EXCISE Then
                    CalculateExciseValue = (ldblTempTotalExcise)
                ElseIf penumTaxType = enumExciseType.RETURN_CVD Then
                    CalculateExciseValue = ldblTempTotalCVD
                ElseIf penumTaxType = enumExciseType.RETURN_SAD Then
                    CalculateExciseValue = ldblTempTotalSAD
                Else
                    CalculateExciseValue = ldblTempAllExcise + (ldblTempEcssOnCVD) + (ldblSTempEcssOnCVD)
                End If
            Else
                If penumTaxType = enumExciseType.RETURN_EXCISE Then
                    CalculateExciseValue = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                ElseIf penumTaxType = enumExciseType.RETURN_CVD Then
                    CalculateExciseValue = 0
                ElseIf penumTaxType = enumExciseType.RETURN_SAD Then
                    .Col = EnumInv.SAD
                    strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
                    rsGetTaxRate = New ClsResultSetDB
                    rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly) ' adOpenStatic, adLockReadOnly)
                    If rsGetTaxRate.GetNoRows > 0 Then
                        ldblSADRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                    Else
                        ldblSADRate = 0
                    End If
                    rsGetTaxRate.ResultSetClose()
                    If mstrInvoiceType = "TRF" Then
                        CalculateExciseValue = (((pdblAccessibleValue) * ldblSADRate) / 100)
                    Else
                        CalculateExciseValue = 0
                    End If
                Else
                    CalculateExciseValue = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                End If
            End If
        End With
        strSql = "select dbo.UFN_ROUNDOFF_DECIMAL(" & CalculateExciseValue & " )"
        CalculateExciseValue = SqlConnectionclass.ExecuteScalar(strSql)

        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateSalesTaxValue(ByVal pdblTotalBasicValue As Double, ByVal pdblTotalExciseValue As Double, ByRef pblnIncStax As Boolean, ByRef pdblInsurance As Double, ByRef pdblcustsuppexcisevalue As Double, ByRef pdblTotalCustMtrl As Double, ByRef PblnblnCSIEX_Inc As Boolean, ByRef pdblTotalamort As Double) As Double
        On Error GoTo ErrHandler
        Dim dbldiscountamount As Double
        Dim rsCustomer As New ClsResultSetDB
        Dim strInvoiceType As String
        Dim rsChallanEntry As ClsResultSetDB

        If CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
            strInvoiceType = UCase(Trim(CmbInvType.Text))
        ElseIf CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
            rsChallanEntry = New ClsResultSetDB
            rsChallanEntry.GetResult("Select a.Description,a.Sub_Type_Description from SaleConf a,SalesChallan_Dtl b where A.UNIT_CODE=B.UNIT_CODE AND A.UNIT_CODE='" + gstrUNITID + "' AND Doc_No = " & txtChallanNo.Text & " and a.Invoice_Type = b.Invoice_type and a.Sub_type = b.Sub_Category and a.Location_code = b.Location_code and (fin_start_date <= getdate() and fin_end_date >= getdate())")
            strInvoiceType = UCase(rsChallanEntry.GetValue("Description"))
            rsChallanEntry.ResultSetClose()
        End If

        'to calculate discount only id discount amount is available
        If System.Math.Round(Val(txtDiscountAmt.Text)) > 0 Then
            'to calculate Discount Amount by value
            If OptDiscountValue.Checked = True Then
                dbldiscountamount = System.Math.Round(Val(txtDiscountAmt.Text), 0)
            Else
                If chkExciseExumpted.CheckState = System.Windows.Forms.CheckState.Unchecked Then
                    'to calculate Discount Amount by Percentage if Excise Duty is available
                    dbldiscountamount = ((pdblTotalBasicValue + pdblTotalExciseValue) * Val(txtDiscountAmt.Text)) / 100
                Else
                    'to calculate Discount Amount by Percentage if Excise Duty is not available
                    dbldiscountamount = ((pdblTotalBasicValue) * Val(txtDiscountAmt.Text)) / 100
                End If
            End If
        Else
            If mblnDiscountFunctionality = True And mblnDiscount_invoicewise = True Then
                dbldiscountamount = TOTALDISCOUNT_ITEMWISE
            Else
                dbldiscountamount = 0
            End If
        End If
        If UCase(Trim(strInvoiceType)) <> "REJECTION" Then
            rsCustomer.GetResult("Select CST_EVAL,CST_AMT from Customer_Mst WHERE UNIT_CODE='" + gstrUNITID + "' AND  Customer_code = '" & Trim(txtCustCode.Text) & "'")
            If rsCustomer.GetNoRows > 0 Then
                If rsCustomer.GetValue("CST_EVAL") = True And rsCustomer.GetValue("CST_AMT") = True Then
                    CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue + pdblTotalamort + pdblTotalCustMtrl - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
                End If
                If rsCustomer.GetValue("CST_EVAL") = True And rsCustomer.GetValue("CST_AMT") = False Then
                    CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue + pdblTotalCustMtrl + pdblTotalCustMtrl) * Val(lblSaltax_Per.Text)) / 100
                End If
                If rsCustomer.GetValue("CST_EVAL") = False And rsCustomer.GetValue("CST_AMT") = True Then
                    CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue + pdblTotalamort + pdblTotalCustMtrl - pdblTotalamort - dbldiscountamount - pdblcustsuppexcisevalue) * Val(lblSaltax_Per.Text)) / 100
                End If
                If rsCustomer.GetValue("CST_EVAL") <> True And rsCustomer.GetValue("CST_AMT") <> True Then
                    CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue + pdblTotalCustMtrl - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
                End If
            Else
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            End If
            rsCustomer.ResultSetClose()
        Else
            CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue) * Val(lblSaltax_Per.Text)) / 100
        End If


        If pblnIncStax = True Then
            If chkExciseExumpted.CheckState = System.Windows.Forms.CheckState.Unchecked Then
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue + pdblInsurance - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            Else
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblInsurance - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            End If
        Else
            If chkExciseExumpted.CheckState = System.Windows.Forms.CheckState.Unchecked Then
                CalculateSalesTaxValue = ((pdblTotalBasicValue + pdblTotalExciseValue - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            Else
                CalculateSalesTaxValue = ((pdblTotalBasicValue - dbldiscountamount) * Val(lblSaltax_Per.Text)) / 100
            End If
        End If

        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
