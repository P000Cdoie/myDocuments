    Private Function AllowASNTextFileGeneration(ByVal pstraccountcode As String) As Boolean
        'Issue ID       : 1043649
        'Reason         : Check ASNTextFileGeneration from Customer Master
        '--------------------------------------------------------------------------------------
        On Error GoTo ErrHandler

        Dim strQry As String
        Dim Rs As ClsResultSetDB
        AllowASNTextFileGeneration = False

        If (UCase(Trim(CmbInvType.Text)) = "NORMAL INVOICE" And UCase(Trim(CmbInvSubType.Text)) = "FINISHED GOODS") Then
            strQry = "Select isnull(AllowASNTextGeneration,0) as AllowASNTextGeneration from customer_mst where UNIT_CODE='" + gstrUNITID + "' AND  Customer_Code='" & Trim(pstraccountcode) & "'"
            Rs = New ClsResultSetDB
            If Rs.GetResult(strQry) = False Then GoTo ErrHandler

            If Rs.GetValue("AllowASNTextGeneration") = "True" Then
                AllowASNTextFileGeneration = True
            Else
                AllowASNTextFileGeneration = False
            End If

            Rs.ResultSetClose()
            Rs = Nothing
        End If
        Exit Function

ErrHandler:
        Rs = Nothing
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
    Private Function CalculateExciseValue_WMART(ByVal pintRowNo As Short, ByVal pdblAccessibleValue As Double, ByVal penumTaxType As enumExciseType, ByRef pblnEOU_FLAG As Boolean, ByRef blnExciseFlag As Boolean, ByRef pdblLoadingCharges As Double, ByRef grid As AxFPSpreadADO.AxfpSpread, ByRef blnExciseFlagWMART As Boolean, ByRef pintExcisedecimalvalueWMart As Integer) As Double


        Dim strTableSql As String 'Declared To Make Select Query
        Dim rsGetTaxRate As ClsResultSetDB
        Dim ldblTaxRate As Double
        Dim ldblCVDRate As Double
        Dim ldblSADRate As Double
        Dim ldblTempTotalExcise As Double
        Dim ldblTempTotalCVD As Double
        Dim ldblTempTotalSAD As Double
        Dim ldblTempAllExcise As Double
        Dim ldblTempEcssOnCVD As Double
        Dim ldblSTempEcssOnCVD As Double

        On Error GoTo ErrHandler
        If gblnGSTUnit And blnEOU_FLAG Then
            CalculateExciseValue_WMART = 0
            Exit Function
        End If
        ldblTempTotalExcise = 0
        ldblTempTotalCVD = 0
        ldblTempTotalSAD = 0
        ldblTempAllExcise = 0
        ldblTempEcssOnCVD = 0
        ldblSTempEcssOnCVD = 0

        Dim strCompCode As String
        Dim strInvoiceType As String

        With grid
            .Row = pintRowNo
            .Col = EnumInv.Excise

            rsGetTaxRate = New ClsResultSetDB
            strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
            rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            If rsGetTaxRate.GetNoRows > 0 Then
                ldblTaxRate = rsGetTaxRate.GetValue("TxRt_Percentage")
            Else
                ldblTaxRate = 0
            End If
            rsGetTaxRate.ResultSetClose()

            If pblnEOU_FLAG Then
                .Col = EnumInv.CVD
                strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    ldblCVDRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                Else
                    ldblCVDRate = 0
                End If
                rsGetTaxRate.ResultSetClose()

                .Col = EnumInv.SAD
                strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    ldblSADRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                Else
                    ldblSADRate = 0
                End If
                rsGetTaxRate.ResultSetClose()
                ldblTempTotalExcise = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)

                strCompCode = "select plant_name from ProductionConf WHERE UNIT_CODE='" + gstrUNITID + "'"
                rsGetTaxRate = New ClsResultSetDB
                rsGetTaxRate.GetResult(strCompCode, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                If rsGetTaxRate.GetNoRows > 0 Then
                    If rsGetTaxRate.GetValue("Plant_name") = "MSSLED" Then
                        rsGetTaxRate.ResultSetClose()
                        If Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT Then
                            strInvoiceType = "Select Invoice_Type,Sub_Category from Saleschallan_Dtl WHERE UNIT_CODE='" + gstrUNITID + "' AND  doc_no='" & Trim(txtChallanNo.Text) & "' "
                            rsGetTaxRate = New ClsResultSetDB
                            rsGetTaxRate.GetResult(strInvoiceType, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
                            If UCase(Trim(rsGetTaxRate.GetValue("Invoice_Type"))) = "INV" And UCase(Trim(rsGetTaxRate.GetValue("sub_Category"))) = "L" Then
                                ldblTempTotalExcise = (ldblTempTotalExcise * 25) / 100
                            End If
                            rsGetTaxRate.ResultSetClose()
                        ElseIf Me.CmdGrpChEnt.Mode = UCActXCtl.clsDeclares.ModeEnum.MODE_ADD Then
                            If UCase(Trim(CmbInvType.Text)) = "NORMAL INVOICE" And UCase(Trim(CmbInvSubType.Text)) = "SCRAP" Then
                                ldblTempTotalExcise = (ldblTempTotalExcise * 25) / 100
                            End If
                        End If
                    Else
                        rsGetTaxRate.ResultSetClose()
                    End If
                Else
                    rsGetTaxRate.ResultSetClose()
                End If
                If blnExciseFlag = True Then
                    ldblTempTotalExcise = System.Math.Round(ldblTempTotalExcise, 0)
                End If

                ldblTempAllExcise = ldblTempTotalExcise * (Val(Me.txtEouExcisePer.Text) / 100)

                ldblTempTotalCVD = (((ldblTempTotalExcise + (pdblAccessibleValue + pdblLoadingCharges)) * ldblCVDRate) / 100)
                If blnExciseFlag = True Then
                    If blnExciseFlagWMART = True Then
                        ldblTempTotalCVD = System.Math.Round(ldblTempTotalCVD, pintExcisedecimalvalueWMart)
                    Else
                        ldblTempTotalCVD = System.Math.Round(ldblTempTotalCVD, 0)
                    End If
                Else
                    If blnExciseFlagWMART = True Then
                        ldblTempTotalCVD = System.Math.Round(ldblTempTotalCVD, pintExcisedecimalvalueWMart)
                    Else
                        ldblTempTotalCVD = System.Math.Round(ldblTempTotalCVD, 0)
                    End If
                End If


                ldblTempAllExcise = ldblTempAllExcise + (ldblTempTotalCVD * (Val(Me.txtEouExcisePer.Text) / 100))
                ldblTempTotalSAD = (((ldblTempTotalCVD + ldblTempTotalExcise + (pdblAccessibleValue + pdblLoadingCharges)) * ldblSADRate) / 100)
                If blnExciseFlag = True Then
                    ldblTempTotalSAD = System.Math.Round(ldblTempTotalSAD, 0)
                End If

                ldblTempEcssOnCVD = (ldblTempTotalCVD * Val(Me.lblEcessCVDPer.Text)) / 100

                ldblSTempEcssOnCVD = (ldblTempTotalCVD * Val(Me.lblSEcessCVDPer.Text)) / 100

                If blnExciseFlag = True Then
                    ldblTempEcssOnCVD = System.Math.Round(ldblTempEcssOnCVD, 0)
                    ldblSTempEcssOnCVD = System.Math.Round(ldblSTempEcssOnCVD, 0)
                End If
                ldblTempAllExcise = ldblTempAllExcise + (ldblTempTotalSAD * (Val(Me.txtEouExcisePer.Text) / 100))
                If blnExciseFlag = True Then
                    ldblTempAllExcise = System.Math.Round(ldblTempAllExcise, 0)
                End If


                If penumTaxType = enumExciseType.RETURN_EXCISE Then
                    CalculateExciseValue_WMART = (ldblTempTotalExcise)
                ElseIf penumTaxType = enumExciseType.RETURN_CVD Then
                    CalculateExciseValue_WMART = ldblTempTotalCVD
                ElseIf penumTaxType = enumExciseType.RETURN_SAD Then
                    CalculateExciseValue_WMART = ldblTempTotalSAD
                Else
                    CalculateExciseValue_WMART = ldblTempAllExcise + (ldblTempEcssOnCVD) + (ldblSTempEcssOnCVD)
                End If
            Else
                If penumTaxType = enumExciseType.RETURN_EXCISE Then
                    CalculateExciseValue_WMART = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                ElseIf penumTaxType = enumExciseType.RETURN_CVD Then
                    CalculateExciseValue_WMART = 0
                ElseIf penumTaxType = enumExciseType.RETURN_SAD Then
                    .Col = EnumInv.SAD
                    strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
                    rsGetTaxRate = New ClsResultSetDB
                    rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly) ' adOpenStatic, adLockReadOnly)
                    If rsGetTaxRate.GetNoRows > 0 Then
                        ldblSADRate = rsGetTaxRate.GetValue("TxRt_Percentage")
                    Else
                        ldblSADRate = 0
                    End If
                    rsGetTaxRate.ResultSetClose()

                    If mstrInvoiceType = "TRF" Then
                        CalculateExciseValue_WMART = (((pdblAccessibleValue) * ldblSADRate) / 100)
                    Else
                        CalculateExciseValue_WMART = 0
                    End If

                Else
                    CalculateExciseValue_WMART = (((pdblAccessibleValue + pdblLoadingCharges) * ldblTaxRate) / 100)
                End If
            End If

        End With

        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function
