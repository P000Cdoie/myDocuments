    Private Sub txtCreditTerms_Validating(ByVal eventSender As System.Object, ByVal eventArgs As System.ComponentModel.CancelEventArgs) Handles txtCreditTerms.Validating
        Dim Cancel As Boolean = eventArgs.Cancel
        Dim intCtr As Short
        Dim blnflag As Boolean
        blnflag = False
        On Error GoTo ErrHandler
        Select Case Me.CmdGrpChEnt.Mode
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_ADD, UCActXCtl.clsDeclares.ModeEnum.MODE_EDIT
                If Len(txtCreditTerms.Text) > 0 Then
                    If Not CheckExistanceOfFieldData(Trim(txtCreditTerms.Text), "crtrm_termID", "Gen_CreditTrmMaster") Then
                        Cancel = True
                        MsgBox("Credit Term doesn't exist.", MsgBoxStyle.Information, ResolveResString(100))
                        txtCreditTerms.Text = ""
                        lblCreditTermDesc.Text = ""
                        txtCreditTerms.Focus()
                    Else
                        For intCtr = 1 To UBound(mItemSODtlArr) Step 1
                            If Trim(txtCreditTerms.Text) = mItemSODtlArr(intCtr).CreditTerm Then
                                blnflag = True
                            End If
                        Next
                        If blnflag = True Then
                            Call SelectDescriptionForField("crTrm_desc", "crtrm_termID", "Gen_CreditTrmMaster", lblCreditTermDesc, (txtCreditTerms.Text))
                        Else
                            MsgBox("Only selected SO Credit term allowed here.", MsgBoxStyle.Information, ResolveResString(100))
                            txtCreditTerms.Text = ""
                            lblCreditTermDesc.Text = ""
                            txtCreditTerms.Focus()
                            Cancel = True
                        End If
                    End If
                End If
            Case UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW
                Call SelectDescriptionForField("crTrm_desc", "crtrm_termID", "Gen_CreditTrmMaster", lblCreditTermDesc, (txtCreditTerms.Text))
        End Select
        GoTo EventExitSub
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection) 'Function called, if error occurred
EventExitSub:
