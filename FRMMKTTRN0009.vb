                                        sadtype = Find_Value("SELECT ISNULL(TXRT_RATE_NO,'') TXRT_RATE_NO FROM GEN_TAXRATE WHERE UNIT_CODE='" + gstrUNITID + "' AND  TX_TAXEID='SAD' AND  TXRT_PERCENTAGE =0 ")
                                        Call .SetText(EnumInv.Packing, intLoopCounter, packingtype)
