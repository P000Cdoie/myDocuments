    Private Function CalculateGSTtaxes(ByVal pintRowNo As Short, ByVal pdblAccessibleValue As Double, ByVal pTaxType As String, ByRef pblnEOU_FLAG As Boolean) As Double

        Dim strTableSql As String 'Declared To Make Select Query
        Dim rsGetTaxRate As ClsResultSetDB
        Dim ldblTaxRate As Double
        Dim ldblTempTotalgsttax As Double

        On Error GoTo ErrHandler

        ldblTempTotalgsttax = 0
        Dim strCompCode As String
        Dim strInvoiceType As String
        Dim strsql As String

        With SpChEntry

            .Row = pintRowNo
            If UCase(pTaxType) = "CGST" Then
                .Col = EnumInv.CGSTTXRT_TYPE
            ElseIf UCase(pTaxType) = "SGST" Then
                .Col = EnumInv.SGSTTXRT_TYPE
            ElseIf UCase(pTaxType) = "UTGST" Then
                .Col = EnumInv.UTGSTTXRT_TYPE
            ElseIf UCase(pTaxType) = "IGST" Then
                .Col = EnumInv.IGSTTXRT_TYPE
            Else
                .Col = EnumInv.COMPENSATION_CESS_TYPE
            End If

            rsGetTaxRate = New ClsResultSetDB
            strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUNITID + "' AND  TxRt_Rate_No='" & Trim(.Text) & "'"
            rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
            If rsGetTaxRate.GetNoRows > 0 Then
                ldblTaxRate = rsGetTaxRate.GetValue("TxRt_Percentage")
            Else
                ldblTaxRate = 0
            End If
            rsGetTaxRate.ResultSetClose()
            CalculateGSTtaxes = (pdblAccessibleValue * ldblTaxRate) / 100
        End With


        Exit Function 'This is to avoid the execution of the error handler
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Function

    Private Function CalculateBasicCustomDuty(ByVal intRowIndex As Integer, ByVal dblBasicValue As Double, ByRef grid As AxFPSpreadADO.AxfpSpread) As Double
        If Not gblnGSTUnit Then
            CalculateBasicCustomDuty = 0
            Exit Function
        End If
        If gblnGSTUnit And Not _blnEOUFlag Then
            CalculateBasicCustomDuty = 0
            Exit Function
        End If
        Dim rsGetTaxRate As ClsResultSetDB
        Dim ldblTaxRate As Double = 0
        Dim strTableSql As String = String.Empty
        grid.Row = intRowIndex : grid.Col = EnumInv.Excise
        rsGetTaxRate = New ClsResultSetDB
        strTableSql = "SELECT TxRt_Percentage FROM Gen_TaxRate WHERE UNIT_CODE='" + gstrUnitId + "' AND  TxRt_Rate_No='" & Trim(grid.Text) & "'"
        rsGetTaxRate.GetResult(strTableSql, ADODB.CursorTypeEnum.adOpenStatic, ADODB.LockTypeEnum.adLockReadOnly)
        If rsGetTaxRate.GetNoRows > 0 Then
            ldblTaxRate = rsGetTaxRate.GetValue("TxRt_Percentage")
        Else
            ldblTaxRate = 0
        End If
        rsGetTaxRate.ResultSetClose()
        CalculateBasicCustomDuty = (dblBasicValue * ldblTaxRate) / 100
    End Function
    Private Function CalculateECESS(ByVal dblBasicCustomDuty As Double, ByVal IsECESS As Boolean) As Double
        If Not gblnGSTUnit Then
            CalculateECESS = 0
            Exit Function
        End If
        If gblnGSTUnit And Not _blnEOUFlag Then
            CalculateECESS = 0
            Exit Function
        End If
        Dim ldblTaxRate As Double = 0
        If IsECESS Then
            ldblTaxRate = Val(lblECSStax_Per.Text)
        Else
            ldblTaxRate = Val(lblSECSStax_Per.Text)
        End If
        CalculateECESS = (dblBasicCustomDuty * ldblTaxRate) / 100
    End Function

