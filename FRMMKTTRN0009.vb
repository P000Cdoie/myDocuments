    Public Sub FillCurrentScheduleQuantityInArray()
        On Error GoTo ErrHandler
        Dim intArrIndex As Short
        Dim intRow As Short
        Dim Intcounter As Short
        Dim blnExist As Boolean
        Dim var_ItemCode As Object
        Dim var_CustItemCode As Object
        Dim var_Qty As Object
        Dim VarDelete As Object
        With spitems
            ReDim marrCurQty(0)
            For intRow = 1 To .MaxRows Step 1
                var_ItemCode = Nothing
                Call .GetText(EnumInv.enumItemCode, intRow, var_ItemCode)
                var_CustItemCode = Nothing
                Call .GetText(EnumInv.CustPartNo, intRow, var_CustItemCode)
                var_Qty = Nothing
                Call .GetText(EnumInv.EnumQuantity, intRow, var_Qty)
                VarDelete = Nothing
                Call .GetText(EnumInv.enumDelete, intRow, VarDelete) '****Delete Flag Check
                If UCase(VarDelete) <> "D" Then
                    If UBound(marrCurQty) > 0 Then
                        For Intcounter = 1 To UBound(marrCurQty)


                            If StrComp(var_ItemCode, marrCurQty(Intcounter).ItemCode, CompareMethod.Text) = 0 And StrComp(var_CustItemCode, marrCurQty(Intcounter).CustItemCode, CompareMethod.Text) = 0 Then

                                marrCurQty(Intcounter).CurQuantity = CDec(marrCurQty(Intcounter).CurQuantity + var_Qty)
                                blnExist = True
                                Exit For
                            Else
                                blnExist = False
                            End If
                        Next
                    End If
                    If blnExist = False Or UBound(marrCurQty) = 0 Then
                        ReDim Preserve marrCurQty(UBound(marrCurQty) + 1)
                        intArrIndex = UBound(marrCurQty)

                        marrCurQty(intArrIndex).ItemCode = var_ItemCode

                        marrCurQty(intArrIndex).CustItemCode = var_CustItemCode

                        marrCurQty(intArrIndex).CurQuantity = var_Qty
                    End If
                End If
            Next
        End With
        Exit Sub
ErrHandler:
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Sub
