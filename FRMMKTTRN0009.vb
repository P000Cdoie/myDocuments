                        End If
                    End If
                ElseIf e.col = EnumInv.Packing Then
                    .Col = EnumInv.Packing
                    .Row = .ActiveRow
                    If Trim(.Text) <> "" Then
                        strWhereClause = " WHERE UNIT_CODE='" + gstrUNITID + "'  and ((isnull(deactive_flag,0) <> 1) OR (CAST(getdate() AS DATE) <= deactive_date)) AND  TxRt_Rate_No='" & Trim(.Text) & "' AND Tx_TaxeID='PKT'"
                        lstrReturnVal = SelectDataFromTable("TxRt_Rate_No", "Gen_TaxRate", strWhereClause)
