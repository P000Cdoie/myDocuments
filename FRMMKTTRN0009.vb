                                    End If
                                End If
                            End If
                            If mDefaultZerovalues = True Then
                                sdtaxtype = Find_Value("SELECT ISNULL(TXRT_RATE_NO,'') TXRT_RATE_NO FROM GEN_TAXRATE WHERE UNIT_CODE='" + gstrUNITID + "' AND  TX_TAXEID='SDT' AND  TXRT_PERCENTAGE =0")
                                txtSDTType.Text = sdtaxtype
                                txtSDTType_Validating(txtSDTType, New System.ComponentModel.CancelEventArgs(False))
