        Dim lstrReturnVal As String
        Dim strWhereClause As String
        If e.newRow = -1 Then Exit Sub
        Item_Description(e.newRow, SpChEntry)
        lstrReturnVal = ""
        If CmdGrpChEnt.Mode <> UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW Then
            With SpChEntry
                If e.col = 8 Then
                    .Col = EnumInv.CVD
                    .Row = .ActiveRow
                    If Trim(.Text) <> "" Then
                        strWhereClause = " WHERE UNIT_CODE='" + gstrUNITID + "'  and ((isnull(deactive_flag,0) <> 1) OR (CAST(getdate() AS DATE) <= deactive_date)) AND  TxRt_Rate_No='" & Trim(.Text) & "' AND Tx_TaxeID='CVD'"
