    Private Sub FillGSTAllTaxDetails(ByVal strItemCode As String, ByVal strVendorCode As String, ByVal strPOType As String, ByVal strTaxHead As String, ByVal intRow As Integer)
        Try

            Dim strQry As String = String.Empty
            Dim strTaxes() As String

            strQry = "SELECT TXRT_TYPE,TXRT_PER FROM UDF_GET_PO_GST_ALLTAXES ('" + gstrUNITID + "','" + strVendorCode + "','" + strItemCode + "','" + getDateForDB(dtpDateDesc.Value) + "','" + strPOType + "','" + strTaxHead + "')"
            strTaxes = ctlHelp.ShowList(gstrCONNECTIONSERVER, gstrDSNName, gstrDatabaseName, strQry)
            If UBound(strTaxes) = -1 Then Exit Sub
            If strTaxes(0) = "0" Then
                MsgBox("Tax details not found for the tax head [" & strTaxHead & "] !", MsgBoxStyle.Exclamation, ResolveResString(100))
                Exit Sub
            End If

            If strTaxes(0) <> "0" Then
                If (strTaxHead = "IGST") Then

                    With SpChEntry
                        .Row = intRow
                        .Col = EnumInv.IGSTTXRT_TYPE
                        .Text = strTaxes(0).ToString()
                    End With
                End If
                If (strTaxHead = "SGST") Then
                    With SpChEntry
                        .Row = intRow
                        .Col = EnumInv.SGSTTXRT_TYPE
                        .Text = strTaxes(0).ToString()
                    End With
                End If
                If (strTaxHead = "CGST") Then
                    With SpChEntry
                        .Row = intRow
                        .Col = EnumInv.CGSTTXRT_TYPE
                        .Text = strTaxes(0).ToString()
                    End With
                End If
                If (strTaxHead = "UTGST") Then
                    With SpChEntry
                        .Row = intRow
                        .Col = EnumInv.UTGSTTXRT_TYPE
                        .Text = strTaxes(0).ToString()
                    End With
                End If
            End If
        Catch ex As Exception
            Throw ex
        End Try
    End Sub
    Private Sub SpChEntry_KeyPressEvent(ByVal sender As Object, ByVal e As AxFPSpreadADO._DSpreadEvents_KeyPressEvent) Handles SpChEntry.KeyPressEvent
        On Error GoTo ErrHandler
        Select Case e.keyAscii
            Case 39, 34, 96, 45
                e.keyAscii = 0
        End Select
        Exit Sub
ErrHandler:  'The Error Handling Code Starts here
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection) 'Function called, if error occurred
    End Sub
    Private Sub SpChEntry_KeyUpEvent(ByVal sender As Object, ByVal e As AxFPSpreadADO._DSpreadEvents_KeyUpEvent) Handles SpChEntry.KeyUpEvent
        Dim intRow As Short
        Dim intDelete As Short
        Dim intLoopCount As Short
        Dim intMaxLoop As Short
        Dim VarDelete As Object
        'GST CHANGES
        If (gblnGSTUnit And Not _blnEOUFlag) And SpChEntry.ActiveCol = EnumInv.Excise Then
            For intLoopCount = 1 To SpChEntry.MaxRows
                VarDelete = Nothing
                Call SpChEntry.GetText(EnumInv.Excise, intLoopCount, VarDelete)
                If VarDelete <> "" Then
                    MsgBox("Excise Tax not allowed", MsgBoxStyle.Critical, ResolveResString(100))
                    Call SpChEntry.SetText(EnumInv.Excise, intLoopCount, "")
                    Exit For
                End If


            Next

        End If
        'GST CHANGES

        If ((e.shift = 2) And (e.keyCode = System.Windows.Forms.Keys.D)) Then
            If CmdGrpChEnt.Mode <> UCActXCtl.clsDeclares.ModeEnum.MODE_VIEW Then
                With SpChEntry
                    If .MaxRows > 1 Then
                        intRow = .ActiveRow : intMaxLoop = SpChEntry.MaxRows
                        For intLoopCount = 1 To intMaxLoop
                            If intLoopCount <> intRow Then
                                VarDelete = Nothing
                                Call .GetText(EnumInv.enumDelete, intLoopCount, VarDelete)
                                If UCase(VarDelete) = "D" Then
                                    intDelete = intDelete + 1
                                End If
                            End If
                        Next
                        If (intMaxLoop - intDelete) > 1 Then
                            Call .SetText(EnumInv.enumDelete, intRow, "D")
                            .Row = .ActiveRow : .Row2 = .ActiveRow : .BlockMode = True : .RowHidden = True : .BlockMode = False
                        End If
                    End If
                End With
            End If
        End If
    End Sub
