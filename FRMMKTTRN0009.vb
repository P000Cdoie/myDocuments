    Private Sub cmdPrint_Click(ByVal eventSender As System.Object, ByVal eventArgs As System.EventArgs) Handles cmdPrint.Click
        On Error GoTo ErrHandler
        Dim intCount As Short
        Dim varTemp As Object
        Dim strFileName As String
        Dim strBCFilename As String
        Dim dblWaitingTime As Double
        'Kill App.Path & "\TypeToPrn.bat"
        Kill(gstrLocalCDrive & "TypeToPrn.bat")
        If objInvoicePrint Is Nothing Then
            strFileName = gstrLocalCDrive & "InvoicePrint.txt"
            strBCFilename = gstrLocalCDrive & "BarCode.txt"
        Else
            If Len(objInvoicePrint.FileName) > 0 Then

                strFileName = objInvoicePrint.FileName
                strBCFilename = objInvoicePrint.BCFileName
            End If
            objInvoicePrint = Nothing
        End If
        If intNoCopies = 0 Then intNoCopies = 1
        dblWaitingTime = Val(Find_Value("select waitingTime from sales_parameter WHERE UNIT_CODE='" + gstrUNITID + "'"))
        If dblWaitingTime = 0 Then
            dblWaitingTime = 5000
        End If
TypeFileNotFoundCreateRetry:
        For intCount = 1 To intNoCopies
            varTemp = Shell("cmd.exe /c " & gstrLocalCDrive & "TypeToPrn.bat " & strFileName, AppWinStyle.Hide)
            Sleep(dblWaitingTime)
            Call printBarCode(strBCFilename)
            Sleep(dblWaitingTime)

            varTemp = Shell("cmd.exe /c " & gstrLocalCDrive & "TypeToPrn.bat " & gstrLocalCDrive & "PageFeed.txt", AppWinStyle.Hide)
        Next
        Exit Sub
ErrHandler:
        If Err.Number = 53 Then
            FileOpen(1, gstrLocalCDrive & "TypeToPrn.bat", OpenMode.Append)
            PrintLine(1, "Type %1> prn") '& Printer.Port
            FileClose(1)
            GoTo TypeFileNotFoundCreateRetry
        End If
        Call gobjError.RaiseError(Err.Number, Err.Source, Err.Description, mP_Connection)
    End Sub
