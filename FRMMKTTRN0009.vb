                        End If
                    End If
                ElseIf e.col = 9 Then
                    .Col = EnumInv.SAD
                    .Row = .ActiveRow
                    If Trim(.Text) <> "" Then
                        strWhereClause = " WHERE UNIT_CODE='" + gstrUNITID + "'  and ((isnull(deactive_flag,0) <> 1) OR (CAST(getdate() AS DATE) <= deactive_date)) AND  TxRt_Rate_No='" & Trim(.Text) & "' AND Tx_TaxeID='SAD'"
