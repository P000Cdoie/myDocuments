    Function CreateNRPGString(ByVal pstrCriteria As String, ByRef pStrInvoiceNo As String) As String
        Dim strMain() As String
        Dim strDet() As String
        Dim intOuterCount As Short
        Dim intInnerCount As Short
        Dim strDocNo As String
        Dim strCustomerLocation As String 'Used for to_location in RGP
        Dim dtGrinDate As Date
        Dim strCheckItem As String
        Dim strGRINNo As String
        Dim strFromLocation As String
        Dim StrItemCode As String
        Dim strItemDesc As String
        Dim dblQuantity As Double
        Dim dblItemRate As Double
        Dim strUOMPur As String
        Dim dblSelectedQuantity As Double
        Dim dblSelectedNRGPQuantity As Double
        Dim i As Short
        Dim strtemp As String
        Dim rsBatch As New ADODB.Recordset
        Dim blnBatchTracking As Boolean
        Dim strSql As String
        blnBatchTracking = CBool(Find_Value("Select FormLevelBatch_Tracking From FORM_LEVEL_FLAGS WHERE UNIT_CODE='" + gstrUNITID + "' AND  Form_Name='frmSTRTRN0009'"))
        mstrRGPHdr = ""
        mstrRGPDtl = ""
        mstrNRGPDetail = ""
        CreateNRPGString = ""
        mstrItemBatch = ""
        With SpChEntry
            For i = 1 To .maxRows
                .Col = EnumInv.EnumQuantity
                .Row = i
                strtemp = .Text
                If mblnBatchTrack = True Then
                    .Col = EnumInv.MaxQuantity
                Else
                    .Col = EnumInv.BatchCol
                End If
                .Text = strtemp
            Next
            strDocNo = Find_Value("SELECT NRGPNoInCaseOfServiceInvoice FROM SALESCHALLAN_DTL WHERE UNIT_CODE='" + gstrUNITID + "' AND  DOC_NO='" & Trim(txtChallanNo.Text) & "'")
            pstrCriteria = Mid(pstrCriteria, 1, Len(pstrCriteria) - 1)
            strMain = Split(pstrCriteria, ",")
            For intOuterCount = 0 To UBound(strMain)
                strDet = Split(strMain(intOuterCount), "|")
                If Trim(strDocNo) = "" Then
                    If SelectDocumentNumber(strDet(1)) Then
                        strDocNo = CStr(Val(GenerateDocNO(23, dtpDateDesc.Text, eMPowerFunctions.DocTypeEnum.Doc_NRGP, False, True, strDet(1))))
                    Else
                        MsgBox("No Document Series have been Defined. First define the Series.", MsgBoxStyle.Information, ResolveResString(100))
                        CreateNRPGString = ""
                        Exit Function
                    End If
                    strCustomerLocation = Find_Value("SELECT CUST_LOCATION FROM CUSTOMER_MST WHERE UNIT_CODE='" + gstrUNITID + "' AND  CUSTOMER_CODE='" & txtCustCode.Text & "'")
                    If Len(strDocNo) = 0 Then
                        MsgBox("No Document Series have been Defined. First define the Series.", MsgBoxStyle.Information, ResolveResString(100))
                        Exit Function
                    End If
                End If
                strGRINNo = strDet(0)
                strFromLocation = strDet(1)
                StrItemCode = strDet(2)
                strItemDesc = strDet(3)
                dblQuantity = CDbl(strDet(7))
                dblItemRate = CDbl(strDet(5))
                strUOMPur = strDet(6)
                'Quantity check
                SpChEntry.Col = EnumInv.enumItemCode
                'RGP Header Starts
                If Len(mstrRGPHdr) = 0 Then
                    mstrRGPHdr = " DELETE FROM Rgp_Hdr WHERE UNIT_CODE='" + gstrUNITID + "' AND  Doc_Type='23' AND Doc_No='" & strDocNo & "' AND From_location='" & strFromLocation & "'" & vbCrLf
                    mstrRGPHdr = mstrRGPHdr & " Insert Rgp_Hdr(Doc_Type, Doc_No, Pur_Order_No, Amendment_no, From_location, Doc_category, RGP_date, To_location, Emp_code, exciseTax_flag, Acknowledgement, rgp_closure, Location_to_type, NRGPAgainstServiceInvoice, InvoiceNo, Ent_dt,Ent_UserId,Upd_dt,Upd_UserId,UNIT_CODE)"
                    mstrRGPHdr = mstrRGPHdr & " values('23','" & strDocNo & "','','0','" & strFromLocation & "','J','" & getDateForDB(dtpDateDesc.Value) & "','" & strCustomerLocation & "','" & mP_User & "','0','0','0','C','1','" & pStrInvoiceNo & "', getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "')"
                End If
                'RGP Header Ends
                'RGP Detail Starts
                If Len(mstrRGPDtl) = 0 Then
                    mstrRGPDtl = " DELETE FROM Rgp_Dtl WHERE UNIT_CODE='" + gstrUNITID + "' AND  Doc_Type='23' AND Doc_No='" & strDocNo & "' AND From_location='" & strFromLocation & "'" & vbCrLf
                    mstrRGPDtl = mstrRGPDtl & " insert Rgp_Dtl(Doc_Type, Doc_No, Item_code, Grin_no, From_location, GRIN_rate, Actual_quantity, description, Excise_duty, UOM_pur, Item_rate, Ent_dt,Ent_UserId,Upd_dt,Upd_UserId,UNIT_CODE)"
                    mstrRGPDtl = mstrRGPDtl & " values('23','" & strDocNo & "','" & StrItemCode & "','0','" & strFromLocation & "'," & dblQuantity * dblItemRate & "," & dblQuantity & ",'" & strItemDesc & "',0,'" & strUOMPur & "'," & dblItemRate & ",getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "')" & vbCrLf

                Else
                    If strCheckItem = StrItemCode Then
                        mstrRGPDtl = mstrRGPDtl & " Update Rgp_Dtl set Actual_quantity= Actual_quantity + " & dblQuantity & ", GRIN_rate=GRIN_rate + " & dblQuantity * dblItemRate & " WHERE UNIT_CODE='" + gstrUNITID + "' AND  Doc_Type='23' AND Doc_No='" & strDocNo & "' AND From_location='" & strFromLocation & "'" & vbCrLf
                    Else
                        mstrRGPDtl = mstrRGPDtl & " Insert Rgp_Dtl(Doc_Type, Doc_No, Item_code, Grin_no, From_location, GRIN_rate, Actual_quantity, description, Excise_duty, UOM_pur, Item_rate, Ent_dt,Ent_UserId,Upd_dt,Upd_UserId,UNIT_CODE)"
                        mstrRGPDtl = mstrRGPDtl & " values('23','" & strDocNo & "','" & StrItemCode & "','0','" & strFromLocation & "'," & dblQuantity * dblItemRate & "," & dblQuantity & ",'" & strItemDesc & "',0,'" & strUOMPur & "'," & dblItemRate & ",getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "') " & vbCrLf
                    End If
                End If
                'RGP Details ends
                dtGrinDate = CDate(Find_Value("SELECT CONVERT(VARCHAR(11),GRN_Date,106) FROM GRN_HDR WHERE UNIT_CODE='" + gstrUNITID + "' AND  doc_category='Z' AND DOC_NO='" & strDet(0) & "'"))
                'NRGP Starts
                If Len(mstrNRGPDetail) = 0 Then
                    mstrNRGPDetail = mstrNRGPDetail & " DELETE FROM NRGP_GRIN_Dtl WHERE UNIT_CODE='" + gstrUNITID + "' AND  NRGP_No='" & strDocNo & "'" & vbCrLf
                    mstrItemBatch = mstrItemBatch & " DELETE FROM ItemBatch_Dtl WHERE UNIT_CODE='" + gstrUNITID + "' AND  DOC_TYPE=23 AND DOC_No='" & strDocNo & "' AND FROM_LOCATION='" & strFromLocation & "'" & vbCrLf
                    mstrNRGPDetail = mstrNRGPDetail & " Insert NRGP_GRIN_Dtl(NRGP_No, NRGP_Date, GRIN_No, GRIN_Date, Item_code, Item_qty, Item_Rate, Ent_dt,Ent_User,Upd_dt,Upd_User,UNIT_CODE)"
                    mstrNRGPDetail = mstrNRGPDetail & " values('" & strDocNo & "','" & getDateForDB(dtpDateDesc.Value) & "','" & strGRINNo & "','" & getDateForDB(dtGrinDate) & "','" & StrItemCode & "'," & dblQuantity & "," & dblItemRate & ", getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "')" & vbCrLf
                    'Batch Tracking
                    If blnBatchTracking Then
                        strSql = "SELECT Doc_Type,Doc_No,Doc_Date,From_Location,To_Location,Item_Code,Batch_No,Batch_Date,Batch_Qty,Batch_Accepted_Qty,Batch_Rejected_Qty,Batch_ReInspected_Qty,Serial_No,CUST_ITEM_CODE,cancel_flag,Temp_qty FROM ITEMBATCH_DTL WHERE UNIT_CODE='" + gstrUNITID + "' AND  DOC_TYPE=10 AND "
                        strSql = strSql & " ITEM_CODE ='" & StrItemCode & "' AND DOC_NO='" & strGRINNo & "'"
                        If rsBatch.State = ADODB.ObjectStateEnum.adStateOpen Then rsBatch.Close()
                        rsBatch.Open(strSql, mP_Connection)
                        mstrItemBatch = mstrItemBatch & "SET DATEFORMAT 'DMY' Insert Into ItemBatch_Dtl(Doc_type, Doc_no, Doc_date, From_Location, To_location, Item_code, Batch_No, Batch_Date, Batch_qty, Batch_Accepted_Qty, Serial_no,Ent_dt,Ent_userId , Upd_dt, Upd_userId,UNIT_CODE) "
                        mstrItemBatch = mstrItemBatch & " Values(23,'" & strDocNo & "','" & getDateForDB(dtpDateDesc.Value) & "','" & strFromLocation & "','" & strCustomerLocation & "','" & StrItemCode & "','" & rsBatch.Fields("Batch_no").Value & "','" & rsBatch.Fields("Batch_Date").Value & "'," & dblQuantity & "," & dblQuantity & ",0" & ", getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "')" & vbCrLf
                    End If

                Else
                    mstrNRGPDetail = mstrNRGPDetail & " Insert NRGP_GRIN_Dtl(NRGP_No, NRGP_Date, GRIN_No, GRIN_Date, Item_code, Item_qty, Item_Rate, Ent_dt,Ent_User,Upd_dt,Upd_User,UNIT_CODE)"
                    mstrNRGPDetail = mstrNRGPDetail & " values('" & strDocNo & "','" & getDateForDB(dtpDateDesc.Value) & "','" & strGRINNo & "','" & getDateForDB(dtGrinDate) & "','" & StrItemCode & "'," & dblQuantity & "," & dblItemRate & ", getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "')" & vbCrLf
                    If blnBatchTracking Then
                        strSql = "SELECT Doc_Type,Doc_No,Doc_Date,From_Location,To_Location,Item_Code,Batch_No,Batch_Date,Batch_Qty,Batch_Accepted_Qty,Batch_Rejected_Qty,Batch_ReInspected_Qty,Serial_No,CUST_ITEM_CODE,cancel_flag,Temp_qty FROM ITEMBATCH_DTL WHERE UNIT_CODE='" + gstrUNITID + "' AND  DOC_TYPE=10 AND "
                        strSql = strSql & " ITEM_CODE ='" & StrItemCode & "' AND DOC_NO='" & strGRINNo & "'"
                        If rsBatch.State = ADODB.ObjectStateEnum.adStateOpen Then rsBatch.Close()
                        rsBatch.Open(strSql, mP_Connection)
                        mstrItemBatch = mstrItemBatch & "SET DATEFORMAT 'DMY'  Insert Into ItemBatch_Dtl(Doc_type, Doc_no, Doc_date, From_Location, To_location, Item_code, Batch_No, Batch_Date, Batch_qty, Batch_Accepted_Qty, Serial_no,Ent_dt,Ent_userId , Upd_dt, Upd_userId,UNIT_CODE) "
                        mstrItemBatch = mstrItemBatch & " Values(23,'" & strDocNo & "','" & getDateForDB(dtpDateDesc.Value) & "','" & strFromLocation & "','" & strCustomerLocation & "','" & StrItemCode & "','" & rsBatch.Fields("Batch_no").Value & "','" & rsBatch.Fields("Batch_Date").Value & "'," & dblQuantity & "," & dblQuantity & ",0" & ", getdate() ,'" & Trim(mP_User) & "',getdate(),'" & Trim(mP_User) & "','" + gstrUNITID + "')" & vbCrLf
                    End If

                End If
                'NRGP Ends
                strCheckItem = StrItemCode
            Next intOuterCount
        End With
        CreateNRPGString = strDocNo
    End Function
    Private Function SelectDocumentNumber(Optional ByRef pstrLocation As String = "") As Boolean
        On Error GoTo ErrHandler
        SelectDocumentNumber = False
        Dim rsDocNo As ClsResultSetDB 'To fetch the max.document no acc.to doc type
        Dim strDocSql As String
        Dim blnLocationWiseNRGPSeries As Boolean
        rsDocNo = New ClsResultSetDB
        blnLocationWiseNRGPSeries = LocationWiseNRGPSeries()
        If blnLocationWiseNRGPSeries = True Then
            strDocSql = "SELECT Current_no from documenttype_mst WHERE UNIT_CODE='" + gstrUNITID + "' AND  doc_type=23 and location_code = '" & Trim(pstrLocation)
            strDocSql = strDocSql & "' AND fin_start_date <= '" & getDateForDB(dtpDateDesc.Value) & "'"
            strDocSql = strDocSql & " And Fin_End_date >= '" & getDateForDB(dtpDateDesc.Value) & "'"
        Else
